import { motion } from "framer-motion";
import { Map as MapIcon, Check, type LucideIcon } from "lucide-react";

export interface MindNodeView {
  Icon: LucideIcon;
  label: string;
}

interface Props {
  nodes: MindNodeView[];
  activeNode: number;
  onJump: (node: number) => void;
  tone?: "teal" | "indigo";
}

/** Sticky left rail: the fixed mind map. Highlights the current node, click to jump. */
export default function MindMap({ nodes, activeNode, onJump, tone = "teal" }: Props) {
  const activeGrad =
    tone === "indigo"
      ? "bg-gradient-to-br from-indigo to-indigo-tx text-white shadow-lift"
      : "bg-gradient-to-br from-teal to-teal-d text-white shadow-lift";
  const doneChip = tone === "indigo" ? "bg-indigo-sk text-indigo-tx" : "bg-teal-sk text-teal-d";

  return (
    <aside className="sticky top-4 self-start rounded-2xl border border-line bg-white/75 p-5 shadow-lift backdrop-blur">
      <h3 className="mb-3.5 flex items-center gap-1.5 px-1.5 text-[12px] font-extrabold uppercase tracking-wider text-soft">
        <MapIcon size={14} strokeWidth={2.4} /> Bản đồ tư duy
      </h3>
      <ol className="relative flex flex-col gap-0.5">
        <span
          className="pointer-events-none absolute left-[26px] top-[34px] bottom-[18px] w-0.5"
          style={{ background: "repeating-linear-gradient(rgb(var(--line)) 0 5px, transparent 5px 11px)" }}
        />
        {nodes.map((m, i) => {
          const active = i === activeNode;
          const done = i < activeNode;
          const Icon = m.Icon;
          return (
            <li key={i} className="relative z-10">
              <button
                onClick={() => onJump(i)}
                aria-current={active ? "step" : undefined}
                className={
                  "flex w-full items-center gap-2.5 rounded-xl px-2.5 py-2 text-left text-[13.5px] font-extrabold transition " +
                  (active
                    ? activeGrad
                    : done
                      ? "text-ink hover:bg-[#f1ece0]"
                      : "text-soft hover:bg-[#f1ece0] hover:text-ink")
                }
              >
                <motion.span
                  className={
                    "grid h-7 w-7 shrink-0 place-items-center rounded-lg " +
                    (active
                      ? "mind-ping bg-white/20"
                      : done
                        ? doneChip
                        : "bg-[rgb(var(--paper-line)/0.28)] text-soft")
                  }
                  animate={active ? { y: [0, -3, 0] } : { y: 0 }}
                  transition={active ? { repeat: Infinity, duration: 2.4 } : {}}
                >
                  {done ? <Check size={15} strokeWidth={3} /> : <Icon size={16} strokeWidth={2.3} />}
                </motion.span>
                <span className="leading-tight">{m.label}</span>
              </button>
            </li>
          );
        })}
      </ol>
    </aside>
  );
}
