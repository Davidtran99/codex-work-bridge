      </div>
      <p className="mt-3 rounded-lg bg-[#f4f6ff] px-3 py-2 text-[12.5px] leading-relaxed text-soft">
        Luồng nạp: thả file vào <b className="text-indigo-tx">inbox/</b> → Claude đọc, cô đọng thành bản gốc ở{" "}
        <b className="text-indigo-tx">raw/</b> → sinh note ở <b className="text-indigo-tx">wiki/</b> và tự nối vào note cũ.
      </p>
    </section>
  );
}
