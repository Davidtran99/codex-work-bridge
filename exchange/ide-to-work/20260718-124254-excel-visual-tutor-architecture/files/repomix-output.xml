<file path="src/components/ExcelGrid.tsx">
import { motion } from "framer-motion";
import type { GridModel, Cell } from "../lib/grid";

const CELL_CLS: Record<string, string> = {
  "": "text-ink/40",
  data: "text-ink font-bold",
  calc: "bg-teal-sk text-teal-d font-extrabold",
  key: "bg-violet-sk text-violet-tx font-extrabold",
  filled: "bg-grass-sk text-grass-tx font-extrabold",
  na: "bg-rose-sk text-rose font-extrabold",
  hero: "bg-amber-sk text-amber-tx font-extrabold ring-2 ring-inset ring-amber",
  dim: "text-ink/25",
  stop: "bg-rose-sk text-rose font-extrabold ring-2 ring-inset ring-rose",
  spot: "bg-amber-sk text-amber-tx font-extrabold ring-2 ring-inset ring-amber",
  blank: "text-transparent",
  colh: "bg-[#e7edf7] text-[#8592ab] font-extrabold text-[10.5px]",
};

interface Props {
  model: GridModel;
  hlGroup: number | null;
  onHoverCell?: (hl: string | undefined) => void;
}

function cellMatches(cell: Cell, hlGroup: number | null): boolean {
  if (hlGroup == null || !cell.hl) return false;
  return cell.hl.split(" ").includes(String(hlGroup));
}

export default function ExcelGrid({ model, hlGroup }: Props) {
  return (
    <div className="flex flex-wrap items-start gap-4">
      {model.tables.map((t, ti) => (
        <div key={ti} className="min-w-0">
          {t.caption && (
            <div className="mb-1.5 text-[11px] font-extrabold uppercase tracking-wide text-soft">
              {t.caption}
            </div>
          )}
          <table
            className="border-separate border-spacing-0 overflow-hidden rounded-lg bg-white text-[13px] shadow-soft"
            style={{ minWidth: t.minWidth }}
          >
            <thead>
              <tr>
                {t.headers.map((h, hi) => {
                  const on = hlGroup != null && h.hl != null && h.hl.split(" ").includes(String(hlGroup));
                  return (
                    <th
                      key={hi}
                      className={
                        "h-[31px] min-w-[40px] border-b border-r border-line px-2.5 text-[11px] font-extrabold " +
                        (hi === 0
                          ? "bg-[#f4f6fc] text-[#a3aec2] w-[26px] min-w-[26px]"
                          : "bg-[#eff3fa] text-soft") +
                        (on ? " ring-2 ring-inset ring-teal" : "")
                      }
                    >
                      {h.label}
                    </th>
                  );
                })}
              </tr>
            </thead>
            <tbody>
              {t.rows.map((r, ri) => (
                <tr key={ri}>
                  <td className="h-[31px] w-[26px] min-w-[26px] border-b border-r border-line bg-[#f4f6fc] px-2.5 text-center text-[10.5px] font-extrabold text-[#a3aec2]">
                    {r.num}
                  </td>
                  {r.cells.map((c, ci) => {
                    const on = cellMatches(c, hlGroup);
                    const cls = CELL_CLS[c.cls] ?? "";
                    return (
                      <motion.td
                        key={ci}
                        initial={c.pop ? { scale: 0.5, opacity: 0 } : false}
                        animate={c.pop ? { scale: 1, opacity: 1 } : {}}
                        transition={{ type: "spring", stiffness: 420, damping: 18 }}
                        className={
                          "h-[31px] min-w-[40px] border-b border-r border-line px-2.5 text-center align-middle " +
                          cls +
                          (on ? " ring-[3px] ring-inset ring-teal-d z-10 relative" : "") +
                          (c.range ? " ring-2 ring-inset ring-teal/70" : "") +
                          (c.fade ? " !text-white transition-colors duration-700" : "")
                        }
                      >
                        {c.v === "" ? "\u00A0" : c.v}
                      </motion.td>
                    );
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}
    </div>
  );
}
</file>

<file path="src/components/FormulaMicroscope.tsx">
import { Microscope } from "lucide-react";
import type { Scene } from "../data/types";
import { FTOKENS } from "../lib/ftokens";

interface Props {
  scene: Scene;
  hlGroup: number | null;
  setHlGroup: (g: number | null) => void;
}

/** Formula shown as colored tokens; hovering a token/chip highlights the linked table region. */
export default function FormulaMicroscope({ scene, hlGroup, setHlGroup }: Props) {
  if (!scene.microscope || !scene.formula) return null;
  const chips = scene.microscope;
  const toks = FTOKENS[scene.table];

  return (
    <section className="rounded-2xl border border-line bg-white/70 p-4 shadow-soft">
      <h4 className="mb-1 flex items-center gap-1.5 text-[13px] font-extrabold uppercase tracking-wide text-soft">
        <Microscope size={15} strokeWidth={2.4} className="text-teal-d" /> Kính hiển vi công thức
      </h4>
      <p className="mb-3 text-[11.5px] font-semibold text-soft/80">
        Di chuột vào từng phần công thức để soi đúng vùng ô.
      </p>

      <div className="formula-shine mb-3 overflow-x-auto rounded-xl bg-[#0f1b33] px-4 py-3 font-mono text-[14px] font-bold text-[#e7ecf5]">
        {toks
          ? toks.map(([txt, g], i) =>
              g == null ? (
                <span key={i} className="text-[#aeb8cc]">{txt}</span>
              ) : (
                <span
                  key={i}
                  onMouseEnter={() => setHlGroup(g)}
                  onMouseLeave={() => setHlGroup(null)}
                  onClick={() => setHlGroup(g)}
                  className={
                    "cursor-pointer rounded px-1 py-0.5 font-extrabold transition " +
                    (hlGroup === g ? "bg-white/20 -translate-y-px" : "hover:bg-white/10")
                  }
                  style={{ color: chips[g][2] }}
                >
                  {txt}
                </span>
              ),
            )
          : scene.formula}
      </div>

      <div className="flex flex-col gap-2">
        {chips.map((c, i) => (
          <div
            key={i}
            onMouseEnter={() => setHlGroup(i)}
            onMouseLeave={() => setHlGroup(null)}
            onClick={() => setHlGroup(i)}
            className={
              "flex cursor-pointer items-start gap-2.5 rounded-lg px-2 py-1 text-[13.5px] transition " +
              (hlGroup === i ? "translate-x-0.5 bg-[#f2f6fc]" : "hover:bg-[#f6f8fd]")
            }
          >
            <span
              className="shrink-0 rounded-md px-2 py-0.5 font-mono text-[12px] font-extrabold text-white"
              style={{ background: c[2] }}
            >
              {c[0]}
            </span>
            <span className="pt-0.5 text-[#39445a]">{c[1]}</span>
          </div>
        ))}
      </div>
    </section>
  );
}
</file>

