import { Layers } from "lucide-react";
import {
  Files, Table2, Database, Copy, Rows3, ListChecks, DownloadCloud, MousePointerClick, RefreshCw,
  type LucideIcon,
} from "lucide-react";
import { MERGE_STEPS, MERGE_MIND } from "./steps";
import LessonScaffold from "../../components/LessonScaffold";
import StepView from "./StepView";

/** Icon mỗi bước (cùng thứ tự MERGE_STEPS). */
const STEP_ICON: LucideIcon[] = [
  Files,               // goal: 3 sheet rời
  Table2,              // table: Ctrl+T
  Database,            // from-table: mở Power Query
  Copy,                // duplicate
  Rows3,               // append
  ListChecks,          // add-tables
  DownloadCloud,       // close & load
  MousePointerClick,   // pivot
  RefreshCw,           // refresh
];

/** "Tạo Pivot Table từ nhiều sheets" — gộp bằng Power Query Append. */
export default function MergeLesson() {
  const scenes = MERGE_STEPS.map((s, i) => ({ id: s.id, tag: s.tag, node: i }));
  const sceneIcons = MERGE_STEPS.map((_, i) => STEP_ICON[i]);
  const mindNodes = MERGE_MIND.map((label, i) => ({
    Icon: STEP_ICON[i] ?? Layers,
    label,
  }));

  const head = (
    <header className="relative px-1 pb-1 pt-2 text-center">
      <span className="inline-flex items-center gap-2 rounded-full bg-gradient-to-br from-teal-sk to-[#e9fbf8] px-4 py-2 text-[12.5px] font-black uppercase tracking-wider text-teal-d shadow-soft">
        <Layers size={15} strokeWidth={2.6} /> Power Query · Append
      </span>
      <h1 className="mx-auto mt-3 max-w-3xl bg-gradient-to-r from-ink via-ink to-teal-d bg-clip-text text-[clamp(24px,3.6vw,38px)] font-black leading-tight tracking-tight text-transparent">
        Pivot Table từ nhiều sheet
      </h1>
      <p className="mx-auto mt-1.5 max-w-2xl text-[clamp(14px,1.8vw,16px)] text-soft">
        Nối ba sheet rời thành một báo cáo toàn quốc bằng Power Query, sửa dữ liệu chỉ cần Refresh.
      </p>
    </header>
  );

  return (
    <LessonScaffold
      scenes={scenes}
      sceneIcons={sceneIcons}
      mindNodes={mindNodes}
      renderScene={(i) => <StepView step={MERGE_STEPS[i]} />}
      head={head}
    />
  );
}
