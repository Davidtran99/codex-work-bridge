/** RichText — quét sáng dần các cụm nhấn mạnh (<b>, <code>). */
function RichText({ html, className }: { html: string; className?: string }) {
  const ref = useRef<HTMLParagraphElement | null>(null);
  useEffect(() => {
    const root = ref.current;
    if (!root) return;
    if (
      typeof window !== "undefined" &&
      window.matchMedia?.("(prefers-reduced-motion: reduce)").matches
    ) return;
    const marks = Array.from(root.querySelectorAll("b, strong, code")) as HTMLElement[];
    if (marks.length < 2) return;
    const delay = marks.length <= 6 ? 0.7 : marks.length <= 12 ? 0.55 : 0.45;
    const cycle = Math.max(5, marks.length * delay + 2.2);
    marks.forEach((el, i) => {
      el.classList.add("ff-read");
      el.style.setProperty("--ff-cycle", cycle.toFixed(2) + "s");
      el.style.setProperty("--ff-read-delay", (i * delay).toFixed(2) + "s");
    });
    return () => {
      marks.forEach((el) => {
        el.classList.remove("ff-read");
        el.style.removeProperty("--ff-cycle");
        el.style.removeProperty("--ff-read-delay");
      });
    };
  }, [html]);
  return <p ref={ref} className={className} dangerouslySetInnerHTML={{ __html: html }} />;
}

function MediaBoard({ images, caption, story }: {
  images: string[]; caption: string; story: string;
}) {
  const [active, setActive] = useState(0);
  const [zoomed, setZoomed] = useState(false);
  const [scale, setScale] = useState(1);
  const [pan, setPan] = useState({ x: 0, y: 0 });
  const drag = useRef<{ x: number; y: number; px: number; py: number } | null>(null);
  const many = images.length > 1;
  const tilt = useTilt<HTMLButtonElement>({ max: 1.2, scale: 1 });

  const resetZoom = () => { setScale(1); setPan({ x: 0, y: 0 }); };

  useEffect(() => {
    if (!zoomed) return;
    const previous = document.body.style.overflow;
    document.body.style.overflow = "hidden";
    const onKey = (event: KeyboardEvent) => {
      if (event.key === "Escape") setZoomed(false);
      if (event.key === "ArrowLeft") { setActive((value) => (value - 1 + images.length) % images.length); resetZoom(); }
      if (event.key === "ArrowRight") { setActive((value) => (value + 1) % images.length); resetZoom(); }
      if (event.key === "+" || event.key === "=") setScale((z) => Math.min(z + 0.4, 5));
      if (event.key === "-" || event.key === "_") setScale((z) => Math.max(z - 0.4, 1));
      if (event.key === "0") resetZoom();
    };
    window.addEventListener("keydown", onKey);
    return () => {
      document.body.style.overflow = previous;
      window.removeEventListener("keydown", onKey);
    };
  }, [images.length, zoomed]);

  // reset zoom whenever the fullscreen closes or the image changes
  useEffect(() => { resetZoom(); }, [zoomed, active]);

  const shift = (direction: number) => {
    setActive((value) => (value + direction + images.length) % images.length);
    resetZoom();
  };

  const onWheelZoom = (e: React.WheelEvent) => {
    e.preventDefault();
    setScale((z) => Math.min(Math.max(z + (e.deltaY < 0 ? 0.3 : -0.3), 1), 5));
  };
  const onDragStart = (e: React.MouseEvent) => {
    if (scale <= 1) return;
    drag.current = { x: pan.x, y: pan.y, px: e.clientX, py: e.clientY };
  };
  const onDragMove = (e: React.MouseEvent) => {
    if (!drag.current) return;
    setPan({ x: drag.current.x + (e.clientX - drag.current.px), y: drag.current.y + (e.clientY - drag.current.py) });
  };
  const onDragEnd = () => { drag.current = null; };

  const picture = (
    <img
      src={images[active]}
      alt={`${caption}${many ? ` — ảnh ${active + 1}/${images.length}` : ""}`}
      className="block aspect-video w-full object-contain"
    />
  );

  return (
    <div className="wiki-media-board overflow-hidden rounded-[20px] border border-indigo/15 bg-[#fbfbff] shadow-[0_16px_44px_rgb(35_42_92_/_0.10)]">
      <figure className="story-frame scene-3d relative p-4 sm:p-6">
        <span className="story-frame-corner story-frame-corner--tl" aria-hidden="true" />
        <span className="story-frame-corner story-frame-corner--tr" aria-hidden="true" />
        <span className="story-frame-corner story-frame-corner--bl" aria-hidden="true" />
        <span className="story-frame-corner story-frame-corner--br" aria-hidden="true" />
        <button
          type="button"
          ref={tilt.ref}
          onMouseMove={tilt.onMouseMove}
          onMouseLeave={tilt.onMouseLeave}
          onClick={() => setZoomed(true)}
          className="tilt-3d group relative z-10 block w-full cursor-zoom-in overflow-hidden rounded-2xl bg-white shadow-[0_16px_40px_rgb(35_42_92_/_0.14)] ring-1 ring-indigo/12 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-indigo/70"
          aria-label="Phóng to ảnh minh họa"
        >
          <span className="block">
            {picture}
          </span>
          <span className="pointer-events-none absolute inset-0 rounded-2xl ring-1 ring-inset ring-white/40" />
          <span className="pointer-events-none absolute bottom-3 right-3 grid h-10 w-10 place-items-center rounded-xl border border-indigo/15 bg-white/90 text-indigo-tx shadow-soft backdrop-blur-sm transition group-hover:border-indigo group-hover:text-indigo">
            <Maximize2 size={18} strokeWidth={2.6} />
          </span>
        </button>
        {many && (
          <>
            <button type="button" onClick={() => shift(-1)} aria-label="Ảnh trước" className="absolute left-5 top-1/2 z-10 grid h-11 w-11 -translate-y-1/2 place-items-center rounded-full border border-indigo/15 bg-white/95 text-indigo-tx shadow-soft transition hover:bg-indigo hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo">
              <ChevronLeft size={20} strokeWidth={2.7} />
            </button>
            <button type="button" onClick={() => shift(1)} aria-label="Ảnh tiếp theo" className="absolute right-5 top-1/2 z-10 grid h-11 w-11 -translate-y-1/2 place-items-center rounded-full border border-indigo/15 bg-white/95 text-indigo-tx shadow-soft transition hover:bg-indigo hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo">
              <ChevronRight size={20} strokeWidth={2.7} />
            </button>
            <span className="absolute left-5 top-5 z-10 rounded-lg border border-indigo/15 bg-white/90 px-2.5 py-1 text-[12px] font-black text-indigo-tx shadow-soft">
              {active + 1}/{images.length}
            </span>
          </>
        )}
      </figure>

      {many && (
        <div className="flex gap-2 overflow-x-auto border-t border-indigo/10 bg-indigo-sk/25 px-3 py-3 sm:justify-center" aria-label="Chọn ảnh">
          {images.map((src, index) => (
            <button
              key={index}
              type="button"
              onClick={() => setActive(index)}
              aria-label={`Xem ảnh ${index + 1}`}
              aria-current={active === index}
              className={`relative w-[92px] shrink-0 overflow-hidden rounded-lg bg-white transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo sm:w-[116px] ${active === index ? "ring-2 ring-indigo shadow-soft" : "opacity-60 ring-1 ring-indigo/15 hover:opacity-100"}`}
            >
              <img src={src} alt="" className="block aspect-video w-full object-cover" />
              <span className={`absolute bottom-1 right-1 rounded bg-white/90 px-1.5 py-0.5 text-[10px] font-black ${active === index ? "text-indigo-tx" : "text-soft"}`}>{index + 1}</span>
            </button>
          ))}
        </div>
      )}

      <div className="border-t border-indigo/10 bg-white">
        <figcaption className="flex items-start gap-3 border-b border-indigo/10 bg-indigo-sk/20 px-[clamp(18px,2.4vw,30px)] py-4 text-[14px] font-extrabold leading-relaxed text-indigo-tx sm:text-[15px]">
          <span className="mt-2 block h-2 w-2 shrink-0 rounded-full bg-indigo" aria-hidden="true" />
          <span>
            <span className="mr-2 text-[10.5px] font-black uppercase tracking-[0.14em] text-indigo-tx/65">Trong khung hình</span>
            {caption}
          </span>
        </figcaption>
        <div className="px-[clamp(18px,3vw,38px)] py-[clamp(20px,2.6vw,30px)]">
          <span className="mb-2.5 block text-[10.5px] font-black uppercase tracking-[0.14em] text-soft">Điều cần hiểu</span>
          <RichText html={story} className="max-w-[100ch] text-[clamp(15.5px,1.35vw,17.5px)] leading-[1.8] text-[#333c54] [&_b]:text-ink [&_code]:rounded-md [&_code]:bg-indigo-sk/60 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-[.86em]" />
        </div>
      </div>

      {zoomed && createPortal(
        <div role="dialog" aria-modal="true" aria-label="Ảnh minh họa phóng to" className="fixed inset-0 z-[100] flex flex-col bg-[#090b16]/95 p-3 backdrop-blur-md sm:p-5">
          <div className="mb-3 flex items-center justify-between gap-4 text-white">
            <span className="text-[13px] font-extrabold">Ảnh {active + 1}/{images.length} · cuộn hoặc +/− để phóng to · kéo để di chuyển</span>
            <div className="flex items-center gap-2">
              <button type="button" onClick={() => setScale((z) => Math.max(z - 0.4, 1))} aria-label="Thu nhỏ" className="grid h-10 w-10 place-items-center rounded-lg border border-white/20 bg-white/10 text-white transition hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white">
                <ZoomOut size={18} strokeWidth={2.6} />
              </button>
              <span className="min-w-[52px] text-center text-[13px] font-black tabular-nums">{Math.round(scale * 100)}%</span>
              <button type="button" onClick={() => setScale((z) => Math.min(z + 0.4, 5))} aria-label="Phóng to" className="grid h-10 w-10 place-items-center rounded-lg border border-white/20 bg-white/10 text-white transition hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white">
                <ZoomIn size={18} strokeWidth={2.6} />
              </button>
              <button autoFocus type="button" onClick={() => setZoomed(false)} aria-label="Đóng" className="grid h-10 w-10 place-items-center rounded-lg border border-white/20 bg-white/10 text-white transition hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white">
                <X size={18} strokeWidth={2.6} />
              </button>
            </div>
          </div>
          <div
            className="relative flex min-h-0 flex-1 items-center justify-center overflow-hidden rounded-xl bg-black/30"
            onWheel={onWheelZoom}
            onMouseDown={onDragStart}
            onMouseMove={onDragMove}
            onMouseUp={onDragEnd}
            onMouseLeave={onDragEnd}
            onDoubleClick={() => (scale > 1 ? resetZoom() : setScale(2))}
            style={{ cursor: scale > 1 ? (drag.current ? "grabbing" : "grab") : "zoom-in" }}
          >
            <img
              src={images[active]}
              alt={`${caption} — ảnh phóng to`}
              draggable={false}
              className="max-h-full w-auto max-w-full select-none rounded-lg object-contain shadow-2xl transition-transform duration-150"
              style={{ transform: `translate(${pan.x}px, ${pan.y}px) scale(${scale})` }}
            />
            {many && <>
              <button type="button" onClick={() => shift(-1)} aria-label="Ảnh trước" className="absolute left-2 top-1/2 grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full bg-black/65 text-white transition hover:bg-indigo"><ChevronLeft size={24} /></button>
              <button type="button" onClick={() => shift(1)} aria-label="Ảnh tiếp theo" className="absolute right-2 top-1/2 grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full bg-black/65 text-white transition hover:bg-indigo"><ChevronRight size={24} /></button>
            </>}
          </div>
        </div>, document.body,
      )}
    </div>
  );
}

export default function StepView({ step }: { step: WikiStep }) {
  const [open, setOpen] = useState<number | null>(0);

  return (
    <motion.div
      key={step.id}
      initial={{ opacity: 0, y: 16 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.4, ease: [0.2, 0.7, 0.2, 1] }}
    >
      <div className="mb-1 flex items-center gap-3">
        <div className="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-indigo-sk text-indigo-tx ring-1 ring-inset ring-indigo/20">
          <LightbulbGlow size={25} weight="duotone" aria-hidden="true" />
        </div>
        <div>
          <span className="inline-block rounded-full bg-indigo-sk px-2.5 py-0.5 text-[11.5px] font-extrabold uppercase tracking-wide text-indigo-tx">
            {step.tag}
          </span>
          <h2 className="mt-1.5 text-[clamp(20px,2.7vw,27px)] font-black leading-tight tracking-tight text-ink">
            {step.title}
          </h2>
        </div>
      </div>

      <div className="mt-5 space-y-5">
        <MediaBoard images={step.images} caption={step.caption} story={step.story} />

        {step.demo === "structure" && <StructureDemo />}
        {step.demo === "graph" && <GraphDemo />}
        {step.demo === "query" && (
          <QueryDemo initialMode={step.id === "maintenance" ? "lint" : "query"} />
        )}

        {step.examples && step.examples.length > 0 && (
          <ExampleBlock examples={step.examples} />
        )}

        {(step.tiers || step.why) && (
          <div className={step.tiers && step.why ? "grid gap-4 xl:grid-cols-2" : ""}>
            {step.tiers && <TiersPanel tiers={step.tiers} />}
            {step.why && (
              <div className="space-y-2">
                {step.why.map(([q, a], i) => {
                  const on = open === i;
                  return (
                    <div key={i} className="overflow-hidden rounded-xl border border-indigo/15 bg-white/75">
                      <button
                        onClick={() => setOpen(on ? null : i)}
                        className="flex w-full items-center justify-between gap-2 px-4 py-2.5 text-left text-[13.5px] font-extrabold text-ink transition hover:bg-white"
                      >
                        {q}
                        <ChevronDown size={16} strokeWidth={2.8} className={"shrink-0 transition-transform " + (on ? "rotate-180" : "")} />
                      </button>
                      {on && (
                        <p className="border-t border-indigo/15 px-4 py-2.5 text-[13.5px] leading-relaxed text-[#39445a]">{a}</p>
                      )}
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        )}
      </div>

      <div className="mt-6 flex items-center gap-3 rounded-2xl border border-indigo/20 bg-indigo-sk/40 px-5 py-4">
        <span className="grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-indigo text-white shadow-soft">
          <LightbulbGlow size={20} weight="fill" aria-hidden="true" />
        </span>
        <span className="text-[15px] font-extrabold text-ink">{step.summary}</span>
      </div>
    </motion.div>
  );
}
