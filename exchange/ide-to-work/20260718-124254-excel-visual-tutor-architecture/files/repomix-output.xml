<file path="src/lib/grid.ts">
import type { Row, TableKind, Spot } from "../data/types";
import { sttOf, keyOf, lookupKey, MAXN } from "./excel";

export type CellClass =
  | "" | "data" | "calc" | "key" | "filled" | "na"
  | "hero" | "dim" | "stop" | "spot" | "blank" | "colh";

export interface Cell {
  v: string | number;
  cls: CellClass;
  hl?: string;     // space separated group indices for formula highlight
  pop?: boolean;   // pop-in animation (just-computed)
  fade?: boolean;  // fade to white (conditional formatting)
  range?: boolean; // running-range ring
}

export interface GridTable {
  caption?: string;
  headers: { label: string; hl?: string }[];
  rows: { num: number | ""; cells: Cell[] }[];
  minWidth?: number;
}

export interface GridModel {
  tables: GridTable[];
}

const HERO = "L1A";

function head(labels: (string | [string, string])[]): { label: string; hl?: string }[] {
  return labels.map((l) => (Array.isArray(l) ? { label: l[0], hl: l[1] } : { label: l }));
}

export function buildGrid(
  table: TableKind,
  src: Row[],
  uniq: string[],
  opts: { step?: number; spot?: Spot } = {},
): GridModel {
  const step = opts.step ?? -1;

  // ---- source-style tables ----
  if (table === "raw_hint" || table === "raw_stop" || table === "idea_preview") {
    const extra = table === "idea_preview";
    const headers = head(extra ? ["", "Mã Phòng", "Số Lượng", "Lần thứ?"] : ["", "Mã Phòng", "Số Lượng"]);
    const rows = src.map((r, i) => {
      const isHero = r[0] === HERO;
      let cls: CellClass = "data";
      if (table === "raw_stop") cls = i === 0 ? "stop" : isHero ? "dim" : "data";
      else if (table === "raw_hint" && opts.spot) {
        const inSpot = opts.spot.col === "A" && opts.spot.rows.includes(i);
        cls = inSpot ? "spot" : "data";
      }
      const cells: Cell[] = [
        { v: r[0], cls },
        { v: r[1], cls: "data" },
      ];
      if (extra) cells.push(isHero ? { v: sttOf(src, i), cls: "calc" } : { v: "", cls: "" });
      return { num: i + 2, cells };
    });
    return { tables: [{ headers, rows, minWidth: 240 }] };
  }

  // ---- COUNTIF running count ----
  if (table === "countif_anim") {
    const headers = head(["", "Mã", "SL", "STT"]);
    const rows = src.map((r, i) => {
      const active = step >= 0 && i <= step;
      const cCls: CellClass = active ? "calc" : "";
      return {
        num: i + 2,
        cells: [
          { v: r[0], cls: (active ? "data" : "data") as CellClass, hl: "1 2", range: active },
          { v: r[1], cls: "data" as CellClass },
          { v: active ? sttOf(src, i) : "", cls: cCls, hl: "0", pop: i === step },
        ],
      };
    });
    return { tables: [{ headers, rows, minWidth: 300 }] };
  }

  // ---- key concat ----
  if (table === "key_anim") {
    const headers = head(["", "Mã", "SL", "STT", "Khoá"]);
    const rows = src.map((r, i) => {
      const active = step >= 0 && i <= step;
      return {
        num: i + 2,
        cells: [
          { v: r[0], cls: "data" as CellClass, hl: "0" },
          { v: r[1], cls: "data" as CellClass },
          { v: sttOf(src, i), cls: "calc" as CellClass, hl: "2" },
          { v: active ? keyOf(src, i) : "", cls: (active ? "key" : "") as CellClass, hl: "1", pop: i === step },
        ],
      };
    });
    return { tables: [{ headers, rows, minWidth: 360 }] };
  }

  // ---- build result frame: type header numbers, then fill codes ----
  if (table === "frame_build") {
    const headers = head(["", "Mã", "1", "2", "3"]);
    // headers typed one-by-one for step 0..MAXN-1; codes filled at step >= MAXN
    const hdrShown = step < 0 ? 0 : Math.min(step + 1, MAXN);
    const headers2 = headers.map((h, idx) => {
      if (idx === 0 || idx === 1) return h;
      const nth = idx - 1; // 1..3
      return { label: nth <= hdrShown ? h.label : "" };
    });
    const codesShown = step >= MAXN;
    const rows = uniq.map((code, ci) => ({
      num: ci + 2,
      cells: [
        { v: codesShown ? code : "", cls: (codesShown ? "key" : "") as CellClass, pop: codesShown && ci === uniq.length - 1 },
        { v: "", cls: "" as CellClass },
        { v: "", cls: "" as CellClass },
        { v: "", cls: "" as CellClass },
      ],
    }));
    return { tables: [{ headers: headers2, rows, minWidth: 300 }] };
  }

  // ---- VLOOKUP / IFERROR: helper table + result matrix ----
  if (table === "vlookup_anim" || table === "iferror_anim") {
    const isIfe = table === "iferror_anim";
    const helper: GridTable = {
      caption: "Bảng khoá",
      headers: head(["", "Khoá", "SL"]),
      minWidth: 170,
      rows: src.map((r, i) => ({
        num: i + 2,
        cells: [
          { v: keyOf(src, i), cls: "key", hl: "1" },
          { v: r[1], cls: "data", hl: isIfe ? "1" : "1 2" },
        ],
      })),
    };
    const hdrHl = isIfe ? undefined : "0";
    const matrix: GridTable = {
      caption: "Bảng kết quả",
      headers: [
        { label: "" },
        { label: "Mã" },
        { label: "1", hl: hdrHl },
        { label: "2", hl: hdrHl },
        { label: "3", hl: hdrHl },
      ],
      minWidth: 230,
      rows: [],
    };
    let flat = 0;
    matrix.rows = uniq.map((code, ci) => {
      const cells: Cell[] = [{ v: code, cls: "key", hl: isIfe ? undefined : "0" }];
      for (let n = 1; n <= MAXN; n++) {
        const v = lookupKey(src, code, n);
        let cls: CellClass = "";
        let val: string | number = "";
        const shown = step >= 0 && flat <= step;
        if (shown) {
          if (v == null) {
            cls = isIfe ? "blank" : "na";
            val = isIfe ? "" : "#N/A";
          } else {
            cls = "filled";
            val = v;
          }
        }
        const hl = isIfe ? (v == null ? "0 2" : "0") : undefined;
        cells.push({ v: val, cls, hl, pop: flat === step });
        flat++;
      }
      return { num: ci + 2, cells };
    });
    return { tables: [helper, matrix] };
  }

  // ---- conditional formatting: fade #N/A cells to white ----
  if (table === "condfmt_anim") {
    // fade order: each null cell in flat order gets faded when its index < step+1
    let naSeen = 0;
    const matrix: GridTable = {
      headers: head(["", "Mã", "1", "2", "3"]),
      minWidth: 230,
      rows: uniq.map((code, ci) => {
        const cells: Cell[] = [{ v: code, cls: "key" }];
        for (let n = 1; n <= MAXN; n++) {
          const v = lookupKey(src, code, n);
          if (v == null) {
            const faded = naSeen <= step;
            naSeen++;
            cells.push({ v: "#N/A", cls: faded ? "blank" : "na", fade: faded, hl: "0" });
          } else {
            cells.push({ v, cls: "filled" });
          }
        }
        return { num: ci + 2, cells };
      }),
    };
    return { tables: [matrix] };
  }

  // ---- test with a wrong code ----
  if (table === "test_wrong") {
    const changed = step >= 0;
    const src2: Row[] = src.map((r, i) => (i === 0 && changed ? (["L9X", r[1]] as Row) : r));
    const helper: GridTable = {
      caption: "Bảng khoá (mã đầu đổi thành L9X)",
      headers: head(["", "Khoá", "SL"]),
      minWidth: 200,
      rows: src2.map((r, i) => ({
        num: i + 2,
        cells: [
          { v: keyOf(src2, i), cls: "key", pop: changed && i === 0 },
          { v: r[1], cls: "data" },
        ],
      })),
    };
    const uniq2 = [] as string[];
    src2.forEach((r) => { if (!uniq2.includes(r[0])) uniq2.push(r[0]); });
    const matrix: GridTable = {
      caption: "Bảng kết quả",
      headers: head(["", "Mã", "1", "2", "3"]),
      minWidth: 230,
      rows: uniq2.map((code, ci) => {
        const cells: Cell[] = [{ v: code, cls: "key" }];
        for (let n = 1; n <= MAXN; n++) {
          const v = lookupKey(src2, code, n);
          cells.push({ v: v == null ? "" : v, cls: v == null ? "blank" : "filled" });
        }
        return { num: ci + 2, cells };
      }),
    };
    return { tables: [helper, matrix] };
  }

  return { tables: [] };
}

export function frameCount(table: TableKind, src: Row[], uniq: string[]): number {
  if (table === "countif_anim" || table === "key_anim") return src.length;
  if (table === "vlookup_anim" || table === "iferror_anim") return uniq.length * MAXN;
  if (table === "frame_build") return MAXN + 1;
  if (table === "condfmt_anim") {
    let c = 0;
    uniq.forEach((code) => { for (let n = 1; n <= MAXN; n++) if (lookupKey(src, code, n) == null) c++; });
    return c;
  }
  if (table === "test_wrong") return 1;
  return 0;
}
