        <div className="flex flex-1 items-center bg-white px-2.5 py-1 font-mono text-ink">
          {f.formula || <span className="text-[#b7c0d6]">&nbsp;</span>}
        </div>
      </div>

      {/* grid: column letters + row-number gutter */}
      <div className="overflow-x-auto">
        <div className={"inline-block overflow-hidden rounded-md " + gridBorder}>
          <table className="border-separate border-spacing-0 bg-white text-[13px]">
            <thead>
              <tr>
                <th className="h-[24px] w-[26px] min-w-[26px] border-b border-r border-[#dfe5f1] bg-[#eef2fa] text-[10.5px] font-extrabold text-[#9aa6c4]" />
                {(["A", "B", "C", "D"] as const).map((col, i) => {
                  const on = focusCol === col;
                  return (
                    <th
                      key={i}
