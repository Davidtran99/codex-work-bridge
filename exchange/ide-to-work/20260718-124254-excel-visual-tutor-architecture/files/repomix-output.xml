import { useState } from "react";
import { motion } from "framer-motion";

type Kind = "raw" | "concept" | "entity";
interface GNode { id: string; label: string; x: number; y: number; kind: Kind; src: 1 | 2; }
interface GLink { a: string; b: string; }

/** Hai đợt: nguồn 1 (trang web AI coding) rồi nguồn 2 (cuốn sách) — thấy graph tự nối. */
const NODES: GNode[] = [
  { id: "raw1", label: "raw: AI Coding", x: 300, y: 175, kind: "raw", src: 1 },
  { id: "c-agent", label: "AI coding agent", x: 300, y: 70, kind: "concept", src: 1 },
  { id: "c-mcp", label: "Model Context Protocol", x: 470, y: 130, kind: "concept", src: 1 },
  { id: "e-claude", label: "Claude Code", x: 150, y: 70, kind: "entity", src: 1 },
  { id: "e-cursor", label: "Cursor", x: 90, y: 175, kind: "entity", src: 1 },
  { id: "e-copilot", label: "GitHub Copilot", x: 500, y: 240, kind: "entity", src: 1 },
  { id: "e-gemini", label: "Gemini", x: 470, y: 40, kind: "entity", src: 1 },

  { id: "raw2", label: "raw: Sách Mastering", x: 200, y: 300, kind: "raw", src: 2 },
  { id: "c-react", label: "React", x: 70, y: 300, kind: "concept", src: 2 },
  { id: "c-python", label: "Python", x: 130, y: 385, kind: "concept", src: 2 },
  { id: "e-agent2", label: "AI agent (sách)", x: 320, y: 360, kind: "entity", src: 2 },
];

const LINKS: GLink[] = [
  { a: "raw1", b: "c-agent" }, { a: "raw1", b: "c-mcp" },
  { a: "c-agent", b: "e-claude" }, { a: "c-agent", b: "e-cursor" },
  { a: "c-mcp", b: "e-copilot" }, { a: "c-mcp", b: "e-claude" },
  { a: "c-agent", b: "e-gemini" },
  { a: "raw2", b: "c-react" }, { a: "raw2", b: "c-python" }, { a: "raw2", b: "e-agent2" },
  // cầu nối liên nguồn — điểm mấu chốt: kiến thức mới tự khớp vào cũ
  { a: "e-agent2", b: "c-agent" },
];

const COLOR: Record<Kind, string> = {
  raw: "rgb(var(--indigo))",
  concept: "rgb(var(--violet))",
  entity: "rgb(var(--teal))",
};

export default function GraphDemo() {
  const [imported, setImported] = useState(false);
  const byId = Object.fromEntries(NODES.map((n) => [n.id, n]));
  const visible = (n: GNode) => n.src === 1 || imported;
  const linkVisible = (l: GLink) => visible(byId[l.a]) && visible(byId[l.b]);

  return (
    <section className="card-frost rounded-2xl p-4">
      <div className="mb-3 flex flex-wrap items-center justify-between gap-2">
        <p className="text-[12.5px] font-extrabold uppercase tracking-wide text-indigo-tx">
          Graph view — tri thức tự nối
        </p>
        <button
          onClick={() => setImported((v) => !v)}
          className="rounded-lg border border-indigo bg-indigo px-3 py-1.5 text-[12.5px] font-extrabold text-white transition hover:brightness-110"
        >
          {imported ? "↩ Chỉ nguồn 1" : "+ Import cuốn sách (nguồn 2)"}
        </button>
      </div>

      <svg viewBox="0 0 560 430" className="w-full rounded-xl border border-line bg-[#fbfcff]">
        {LINKS.map((l, i) => {
          const a = byId[l.a], b = byId[l.b];
          const on = linkVisible(l);
          const bridge = l.a === "e-agent2" && l.b === "c-agent";
          return (
            <motion.line
              key={i}
              x1={a.x} y1={a.y} x2={b.x} y2={b.y}
              stroke={bridge ? "rgb(var(--honey))" : "rgb(var(--line))"}
              strokeWidth={bridge ? 2.4 : 1.4}
              strokeDasharray={bridge ? "5 4" : undefined}
              initial={false}
              animate={{ opacity: on ? 1 : 0 }}
              transition={{ duration: 0.35 }}
            />
          );
        })}
        {NODES.map((n) => {
          const on = visible(n);
          const r = n.kind === "raw" ? 9 : 6;
          return (
            <motion.g
              key={n.id}
              initial={false}
              animate={{ opacity: on ? 1 : 0, scale: on ? 1 : 0.6 }}
              transition={{ duration: 0.35 }}
              style={{ transformOrigin: `${n.x}px ${n.y}px` }}
            >
              <circle cx={n.x} cy={n.y} r={r} fill={COLOR[n.kind]} />
              <text
                x={n.x} y={n.y - r - 5}
                textAnchor="middle"
                className="fill-ink font-mono"
                style={{ fontSize: 10, fontWeight: 700 }}
              >
                {n.label}
              </text>
            </motion.g>
          );
        })}
      </svg>

      <div className="mt-3 flex flex-wrap gap-3 text-[12px] font-bold text-soft">
        <span className="flex items-center gap-1.5"><i className="inline-block h-2.5 w-2.5 rounded-full" style={{ background: COLOR.raw }} /> raw (nguồn)</span>
        <span className="flex items-center gap-1.5"><i className="inline-block h-2.5 w-2.5 rounded-full" style={{ background: COLOR.concept }} /> concept</span>
        <span className="flex items-center gap-1.5"><i className="inline-block h-2.5 w-2.5 rounded-full" style={{ background: COLOR.entity }} /> entity</span>
        <span className="flex items-center gap-1.5"><i className="inline-block h-2.5 w-4 rounded" style={{ background: "rgb(var(--honey))" }} /> cầu nối liên nguồn</span>
      </div>
      <p className="mt-2 rounded-lg bg-[#f4f6ff] px-3 py-2 text-[12.5px] leading-relaxed text-soft">
        {imported
          ? "Nạp cuốn sách vào, Claude không dựng đảo riêng: nó phát hiện 'AI agent' trong sách trùng với 'AI coding agent' đã có, rồi bắc cầu (đường cam) — mật độ tri thức càng dày, hệ thống càng thông minh."
          : "Đây là graph sau nguồn 1: một trang web về AI coding được bung ra thành concept + entity, nối quanh nút raw ở giữa. Bấm nút để import thêm nguồn 2."}
      </p>
    </section>
  );
}
