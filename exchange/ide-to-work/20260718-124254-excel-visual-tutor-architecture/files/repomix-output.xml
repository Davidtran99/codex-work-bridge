  pointer-events:none;
}
@keyframes shimmer{0%{background-position:-380px 0}100%{background-position:380px 0}}

@media (prefers-reduced-motion: reduce){
  *{animation:none !important; scroll-behavior:auto !important; transition:none !important}
  .aurora::before,.aurora::after,.aurora .blob3{animation:none !important}
}

/* ---- Button flourishes (theme: ink on paper) ---- */
/* sheen sweep across a primary button face */
.btn-sheen{position:relative; overflow:hidden}
.btn-sheen::after{
  content:""; position:absolute; top:0; bottom:0; left:0; width:40%;
  background:linear-gradient(105deg, transparent, rgb(255 255 255 / .38), transparent);
  transform:translateX(-160%) skewX(-12deg);
  transition:none; pointer-events:none;
}
.btn-sheen:hover::after{ animation:sheen 1.1s ease-out }
@keyframes sheen{0%{transform:translateX(-160%) skewX(-12deg)}100%{transform:translateX(260%) skewX(-12deg)}}

/* ink underline that draws in on hover, like a pen stroke */
.ink-underline{position:relative}
.ink-underline::before{
  content:""; position:absolute; left:10%; right:10%; bottom:6px; height:2px;
  background:currentColor; border-radius:2px;
  transform:scaleX(0); transform-origin:left center;
  transition:transform .28s cubic-bezier(.2,.7,.2,1); opacity:.65;
}
.ink-underline:hover::before{ transform:scaleX(1) }

@media (prefers-reduced-motion: reduce){
  .btn-sheen:hover::after{ animation:none }
  .ink-underline::before{ transition:none }
}

/* ============================================================
   3D depth kit: perspective scenes, hover tilt, floating chips
   ============================================================ */

/* wrapper that gives children a shared vanishing point */
.scene-3d{ perspective:1600px; perspective-origin:50% 30%; }

/* the card that tilts toward the cursor (JS sets --rx / --ry) */
.tilt-3d{
  transform-style:preserve-3d;
  transform:
    perspective(1200px)
    rotateX(var(--rx, 0deg))
    rotateY(var(--ry, 0deg))
    translateZ(0);
  transition:transform .18s cubic-bezier(.2,.7,.2,1), box-shadow .25s ease;
  will-change:transform;
}
.tilt-3d:hover{
  box-shadow:0 26px 60px rgb(20 26 43 / .16), 0 4px 14px rgb(20 26 43 / .08);
}
/* content sits slightly forward so the tilt reads as real depth */
.tilt-lift{ transform:translateZ(38px); }

/* glare that follows the tilt (JS sets --mx / --my) */
.tilt-glare{
  position:absolute; inset:0; border-radius:inherit; pointer-events:none;
  background:radial-gradient(
    240px circle at var(--mx, 50%) var(--my, 0%),
    rgb(255 255 255 / .35), transparent 60%);
  opacity:0; transition:opacity .25s ease; mix-blend-mode:soft-light;
}
.tilt-3d:hover .tilt-glare{ opacity:1; }

/* gentle continuous 3D bob for badges/icons */
@keyframes float3d{
  0%,100%{ transform:translateZ(0) translateY(0) rotateX(0); }
  50%{ transform:translateZ(30px) translateY(-6px) rotateX(6deg); }
}
.float-3d{ animation:float3d 5s ease-in-out infinite; transform-style:preserve-3d; }

/* pop-in with a little Z depth, for chips/cells */
@keyframes pop3d{
  0%{ opacity:0; transform:perspective(700px) rotateX(-24deg) translateY(10px); }
  100%{ opacity:1; transform:perspective(700px) rotateX(0) translateY(0); }
}
.pop-3d{ animation:pop3d .5s cubic-bezier(.2,.8,.2,1) both; }

/* raised, tactile chip surface */
.chip-3d{
  transition:transform .2s cubic-bezier(.2,.7,.2,1), box-shadow .2s ease;
  transform:translateZ(0);
}
.chip-3d:hover{
  transform:translateY(-3px) translateZ(12px) scale(1.03);
  box-shadow:0 10px 22px rgb(20 26 43 / .14);
}

@media (prefers-reduced-motion: reduce){
  .tilt-3d{ transform:none !important; }
  .float-3d,.pop-3d{ animation:none !important; }
  .chip-3d:hover{ transform:none !important; }
}


/* ============================================================
   Idle loop flourishes: bring the page to life without noise
   ============================================================ */

/* animated gradient title — slow, pleasant color drift */
@keyframes titleFlow{
  0%,100%{ background-position:0% 50%; }
  50%{ background-position:100% 50%; }
}
.title-flow{
  background-size:220% 220%;
  animation:titleFlow 9s ease-in-out infinite;
}

/* badge that gently breathes + glows */
@keyframes badgeGlow{
  0%,100%{ box-shadow:0 4px 14px rgb(var(--violet) / .18); transform:translateY(0); }
  50%{ box-shadow:0 10px 28px rgb(var(--violet) / .42); transform:translateY(-2px); }
}
.badge-glow{ animation:badgeGlow 3.6s ease-in-out infinite; will-change:transform; }

/* sparkle icon: soft rotate + pulse loop */
@keyframes sparkleSpin{
  0%,100%{ transform:rotate(0) scale(1); opacity:.9; }
  50%{ transform:rotate(16deg) scale(1.18); opacity:1; }
}
.sparkle-loop{ animation:sparkleSpin 2.8s ease-in-out infinite; transform-origin:center; }

/* subtitle words drift a shimmering highlight across, on loop */
@keyframes textShimmer{
  0%{ background-position:200% 0; }
  100%{ background-position:-200% 0; }
}
.text-shimmer{
  background:linear-gradient(90deg,
    rgb(var(--soft)) 0%, rgb(var(--soft)) 42%,
    rgb(var(--violet-tx)) 50%,
    rgb(var(--soft)) 58%, rgb(var(--soft)) 100%);
  background-size:220% auto;
  -webkit-background-clip:text; background-clip:text;
  -webkit-text-fill-color:transparent; color:transparent;
  animation:textShimmer 7s linear infinite;
}

/* CTA idle pulse — draws the eye to the "Next" key, loops a glow + sheen */
@keyframes ctaPulse{
  0%,100%{ box-shadow:0 4px 0 rgb(var(--teal-edge)), 0 9px 18px rgb(var(--teal) / .32); }
  50%{ box-shadow:0 4px 0 rgb(var(--teal-edge)), 0 13px 30px rgb(var(--teal) / .55); }
}
.cta-pulse:not(:disabled){ animation:ctaPulse 2.6s ease-in-out infinite; }
.cta-pulse:not(:disabled)::after{
  animation:sheen 4.2s ease-in-out infinite 1.2s;
}
/* the right chevron nudges outward on loop, hinting "go on" */
@keyframes nudgeX{
  0%,72%,100%{ transform:translateX(0); }
  84%{ transform:translateX(3px); }
}
.cta-pulse:not(:disabled) .nudge-x{ animation:nudgeX 2.6s ease-in-out infinite; }

@media (prefers-reduced-motion: reduce){
  .title-flow,.badge-glow,.sparkle-loop,.text-shimmer,
  .cta-pulse:not(:disabled),.cta-pulse:not(:disabled)::after,
  .cta-pulse:not(:disabled) .nudge-x{ animation:none !important; }
  .text-shimmer{ -webkit-text-fill-color:rgb(var(--soft)); color:rgb(var(--soft)); }
}


/* ============================================================
   Idle loop v2 — subtle micro-motion for chips, bars, images
   ============================================================ */

/* progress bar: base + a moving highlight streak on loop */
@keyframes barSweep{
  0%{ transform:translateX(-30%); opacity:0; }
  15%{ opacity:.9; }
  85%{ opacity:.9; }
  100%{ transform:translateX(230%); opacity:0; }
}
.bar-streak{
  position:absolute; inset:0; pointer-events:none;
  background:linear-gradient(90deg,
    transparent 0%,
    rgb(255 255 255 / .6) 45%,
    rgb(255 255 255 / .9) 50%,
    rgb(255 255 255 / .6) 55%,
    transparent 100%);
  mix-blend-mode:overlay;
  animation:barSweep 3.6s cubic-bezier(.55,.05,.2,.95) infinite;
}

/* active scene chip: gentle heartbeat (scale + shadow) */
@keyframes chipBeat{
  0%,100%{ transform:translateY(-2px) scale(1); box-shadow:0 10px 22px rgb(20 26 43 / .22); }
  50%{ transform:translateY(-3px) scale(1.035); box-shadow:0 14px 30px rgb(20 26 43 / .32); }
}
.chip-active{ animation:chipBeat 2.6s ease-in-out infinite; }

/* image frame: very slow breath (barely-there scale) — invites the eye */
@keyframes frameBreath{
  0%,100%{ transform:scale(1); }
  50%{ transform:scale(1.008); }
}
.frame-breath{ animation:frameBreath 6.5s ease-in-out infinite; transform-origin:center; }

/* mind-map active node: soft ping ring */
@keyframes mindPing{
  0%{ box-shadow:0 0 0 0 rgb(var(--violet) / .55); }
  70%{ box-shadow:0 0 0 14px rgb(var(--violet) / 0); }
  100%{ box-shadow:0 0 0 0 rgb(var(--violet) / 0); }
}
.mind-ping{ animation:mindPing 2.4s ease-out infinite; }

/* subtle cursor for "typing" feels (used by sim etc, if wanted) */
@keyframes caretBlink{ 50%{ opacity:.15; } }
.caret-blink{ animation:caretBlink 1s steps(2,end) infinite; }

@media (prefers-reduced-motion: reduce){
  .bar-streak,.chip-active,.frame-breath,.mind-ping,.caret-blink{ animation:none !important; }
  .bar-streak{ display:none; }
}


/* ============================================================
   FormulaFlow — công thức tô màu + pop TỰ ĐỘNG theo thứ tự đọc
   (port từ office-exam-coach, cải tiến cho web bài giảng)
   ============================================================ */
.ff-flow{
  font-family:theme('fontFamily.mono');
  font-weight:700;
  letter-spacing:-.01em;
  line-height:1.9;
  word-break:break-word;
}
.ff-eq{ color:#475569; font-weight:800; margin-right:1px; }

/* syntax coloring — hợp tông ink-on-paper của app */
.ff-tok-func{ color:#1d4ed8; font-weight:800; }
.ff-tok-ref{ color:#6d28d9; font-weight:750; }
.ff-tok-sheet{ color:#0f766e; font-weight:750; }
.ff-tok-string{ color:#b45309; font-weight:750; }
.ff-tok-num{ color:#047857; font-weight:750; }
.ff-tok-punct{ color:#64748b; font-weight:650; }
.ff-tok-default{ color:#1e293b; font-weight:650; }

/* rainbow parentheses — thấy hàm nào lồng trong hàm nào */
.ff-paren{ font-weight:800; padding:0 .5px; border-radius:3px; }
.ff-paren-d0{ color:#2563eb; }
.ff-paren-d1{ color:#db2777; }
.ff-paren-d2{ color:#c2760a; }

/* Token pop theo THỨ TỰ ĐỌC:
   - delay = --ff-slot * --ff-delay  (hạng đọc thật, do JS gán)
   - tất cả token DÙNG CHUNG --ff-cycle -> chu kỳ bằng nhau nên thứ tự
     (độ lệch delay) GIỮ NGUYÊN qua mọi vòng lặp.
   - không transform -> layout đứng yên tuyệt đối (chỉ opacity + nền + shadow). */
.ff-pop{
  display:inline;
  border-radius:4px;
  padding:0 1px;
  opacity:.4;
  animation:ffPop var(--ff-cycle, 6s) ease-in-out infinite both;
  animation-delay:calc(var(--ff-slot, 0) * var(--ff-delay, .34s));
  will-change:opacity;
}
@keyframes ffPop{
  0%   { opacity:.4; background-color:transparent; }
  4%   { opacity:1;  background-color:rgb(var(--violet) / .16); }
  12%  { opacity:1;  background-color:rgb(var(--violet) / .08); }
  20%  { opacity:1;  background-color:transparent; }
  90%  { opacity:1;  background-color:transparent; }
  100% { opacity:.4; background-color:transparent; }
}

/* biến thể trên nền tối (kính hiển vi / mã Custom) */
.ff-on-dark .ff-eq{ color:#aeb8cc; }
.ff-on-dark .ff-tok-func{ color:#7aa2ff; }
.ff-on-dark .ff-tok-ref{ color:#c4b5fd; }
.ff-on-dark .ff-tok-sheet{ color:#5eead4; }
.ff-on-dark .ff-tok-string{ color:#fbbf24; }
.ff-on-dark .ff-tok-num{ color:#6ee7b7; }
.ff-on-dark .ff-tok-punct{ color:#9aa6bd; }
.ff-on-dark .ff-tok-default{ color:#e7ecf5; }
.ff-on-dark .ff-paren-d0{ color:#93c5fd; }
.ff-on-dark .ff-paren-d1{ color:#f9a8d4; }
.ff-on-dark .ff-paren-d2{ color:#fcd34d; }
.ff-on-dark .ff-pop{ opacity:.45; animation-name:ffPopDark; }
@keyframes ffPopDark{
  0%   { opacity:.45; background-color:transparent; }
  4%   { opacity:1;   background-color:rgb(255 255 255 / .13); }
  12%  { opacity:1;   background-color:rgb(255 255 255 / .06); }
  20%  { opacity:1;   background-color:transparent; }
  90%  { opacity:1;   background-color:transparent; }
  100% { opacity:.45; background-color:transparent; }
}

@media (prefers-reduced-motion: reduce){
  .ff-pop{ animation:none !important; opacity:1 !important; transform:none !important; }
}


/* ============================================================
   ff-read — "kính lúp đọc" quét qua các cụm nhấn mạnh trong LỜI GIẢNG
   (áp cho <b>/<code> trong story; nở nhẹ + sáng nền theo thứ tự đọc)
   ============================================================ */
.ff-read{
  display:inline;
  border-radius:4px;
  padding:0 2px;
  animation:ffRead var(--ff-cycle, 8s) ease-in-out infinite both;
  animation-delay:var(--ff-read-delay, 0s);
  will-change:background-color;
}
/* code giữ nền xám của nó khi "nghỉ", chỉ đổi lúc được đọc */
@keyframes ffRead{
  0%   { background-color:transparent; }
  3%   { background-color:rgb(var(--violet) / .16); }
  12%  { background-color:rgb(var(--violet) / .16); }
  20%  { background-color:rgb(var(--violet) / .07); }
  28%  { background-color:transparent; }
  92%  { background-color:transparent; }
  100% { background-color:transparent; }
}
@media (prefers-reduced-motion: reduce){
  .ff-read{ animation:none !important; transform:none !important; }
}


/* ============================================================
   FormulaFlow — GUIDED mode (kịch bản đọc): token đang đọc sáng
   ĐỒNG BỘ dòng chú thích. Gạch chân bút chì + dots tiến độ + thẻ caption.
   ============================================================ */
.ff-guided{ display:block; }
.ff-line{ display:block; line-height:2.05; }

/* token đang được đọc ở bước hiện tại */
.ff-here{
  position:relative;
  border-radius:5px;
  padding:0 2px;
  background-color:rgb(var(--violet) / .12);
  color:rgb(var(--violet-tx));
  transition:background-color .35s ease, color .35s ease, opacity .35s ease;
}
/* gạch chân "bút chì" vẽ từ trái sang dưới token đang đọc */
.ff-underline{
  position:absolute;
  left:2px; right:2px; bottom:-1px;
  height:2px; border-radius:2px;
  background:linear-gradient(90deg, rgb(var(--violet)), rgb(var(--violet-tx)));
  transform-origin:left center;
  animation:ffDraw .4s cubic-bezier(.2,.7,.2,1) both;
}
@keyframes ffDraw{ 0%{ transform:scaleX(0); opacity:.4; } 100%{ transform:scaleX(1); opacity:1; } }

/* token thuộc bước khác -> mờ nhẹ để mắt gom vào chỗ đang đọc */
.ff-dim{ opacity:.38; transition:opacity .35s ease; }

.ff-on-dark .ff-here{ background-color:rgb(255 255 255 / .12); color:#fff; }
.ff-on-dark .ff-underline{ background:linear-gradient(90deg, #93c5fd, #c4b5fd); }
.ff-on-dark .ff-dim{ opacity:.4; }

/* dots tiến độ các bước */
.ff-dots{ display:flex; gap:5px; margin-top:12px; }
.ff-dot{
  width:7px; height:7px; border-radius:999px;
  background:rgb(var(--violet) / .22);
  transition:all .35s ease;
}
.ff-dot-done{ background:rgb(var(--violet) / .45); }
.ff-dot-on{ width:20px; background:rgb(var(--violet)); }
.ff-on-dark .ff-dot{ background:rgb(255 255 255 / .22); }
.ff-on-dark .ff-dot-done{ background:rgb(255 255 255 / .45); }
.ff-on-dark .ff-dot-on{ background:#fff; }

/* thẻ chú thích đồng bộ token đang đọc */
.ff-caption{
  display:flex; align-items:flex-start; gap:9px;
  margin-top:9px; padding:9px 12px;
  border-radius:12px;
  background:rgb(var(--violet) / .07);
  border:1px solid rgb(var(--violet) / .16);
  font-family:theme('fontFamily.sans');
  font-size:13px; font-weight:600; line-height:1.55;
  color:#39445a;
  animation:ffCapIn .42s cubic-bezier(.2,.7,.2,1) both;
}
.ff-caption-step{
  flex-shrink:0;
  display:grid; place-items:center;
  width:22px; height:22px; border-radius:999px;
  font-size:12px; font-weight:800;
  background:rgb(var(--violet)); color:#fff;
  box-shadow:0 3px 8px rgb(var(--violet) / .35);
}
.ff-caption-text{ padding-top:1px; }
.ff-on-dark .ff-caption{
  background:rgb(255 255 255 / .06);
  border-color:rgb(255 255 255 / .14);
  color:#c7d0e0;
}
.ff-on-dark .ff-caption-step{ background:#7aa2ff; color:#0f1b33; box-shadow:none; }
@keyframes ffCapIn{
  0%{ opacity:0; transform:translateY(4px); }
  100%{ opacity:1; transform:translateY(0); }
}
@media (prefers-reduced-motion: reduce){
  .ff-here,.ff-dim{ background-color:transparent !important; opacity:1 !important; color:inherit !important; }
  .ff-underline{ display:none !important; }
  .ff-caption,.ff-dot,.ff-dot-on{ animation:none !important; transition:none !important; }
}


/* ============================================================
   Item 2 — Viền gradient động quanh figure ảnh
   conic-gradient xoay chậm, dùng ::before + mask (padding trick)
   để tạo viền mỏng mà không phá overflow-hidden bên trong.
   ============================================================ */
.figure-aura{ position:relative; }
.figure-aura::before{
  content:""; position:absolute; inset:0; z-index:2;
  padding:1.5px; border-radius:inherit; pointer-events:none;
  background:conic-gradient(from var(--aura-angle,0deg),
    rgb(var(--violet) / .85),
    rgb(var(--teal) / .8),
    rgb(var(--violet-tx) / .75),
    rgb(var(--teal-d) / .8),
    rgb(var(--violet) / .85));
  -webkit-mask:
    linear-gradient(#000 0 0) content-box,
    linear-gradient(#000 0 0);
  -webkit-mask-composite:xor;
          mask:
    linear-gradient(#000 0 0) content-box,
    linear-gradient(#000 0 0);
          mask-composite:exclude;
  animation:auraSpin 7s linear infinite;
  opacity:.9;
}
@property --aura-angle{ syntax:"<angle>"; inherits:false; initial-value:0deg; }
@keyframes auraSpin{ to{ --aura-angle:360deg; } }
@media (prefers-reduced-motion: reduce){
  .figure-aura::before{ animation:none; }
}

/* ============================================================
   Item 4 — Badge số thứ tự: gradient + inner ring + micro-pulse khi hover figure
   ============================================================ */
.badge-num{
  background:linear-gradient(140deg,
    rgb(var(--violet) / .96) 0%,
    rgb(var(--violet-tx) / .96) 100%);
  box-shadow:
    0 4px 12px rgb(var(--violet) / .42),
    0 0 0 1px rgb(var(--violet-tx) / .35),
    0 1px 0 rgb(255 255 255 / .55) inset;
  transition:transform .2s cubic-bezier(.2,.7,.2,1), box-shadow .2s ease;
}
.group:hover .badge-num{
  animation:badgePulse 1.4s ease-in-out infinite;
}
@keyframes badgePulse{
  0%,100%{ transform:scale(1); box-shadow:0 4px 12px rgb(var(--violet) / .42), 0 0 0 1px rgb(var(--violet-tx) / .35), 0 1px 0 rgb(255 255 255 / .55) inset; }
  50%{ transform:scale(1.09); box-shadow:0 6px 18px rgb(var(--violet) / .55), 0 0 0 4px rgb(var(--violet) / .18), 0 1px 0 rgb(255 255 255 / .6) inset; }
}
@media (prefers-reduced-motion: reduce){
  .badge-num{ transition:none; }
  .group:hover .badge-num{ animation:none; }
}


/* ============================================================
   Item 10 — Radial gauge số liệu (bài Peter, bước "vietnam")
   Vòng SVG + số đếm lên do JS điều khiển (rAF), đã tôn trọng
   prefers-reduced-motion ngay trong component (hiện thẳng giá trị).
   Ở đây chỉ đảm bảo không có transition CSS gây double-animate.
   ============================================================ */
.gauge-ring circle{ transition:none; }
@media (prefers-reduced-motion: reduce){
  .gauge-ring circle{ transition:none !important; animation:none !important; }
}


/* ============================================================
   LessonPicker — lưới thẻ phẳng (flat card grid)
   Thẻ đứng thẳng, không nghiêng 3D, để vùng bấm trùng đúng vị
   trí nhìn thấy. Hover nhấc nhẹ + dải màu accent chạy trên đỉnh.
   ============================================================ */
.lesson-card{
  --bar: var(--teal);
  position:relative;
  border-radius:16px;
  background:rgb(var(--panel) / .96);
  border:1px solid rgb(var(--line));
  padding:18px;
  overflow:hidden;
  cursor:pointer;
  transition:transform .28s cubic-bezier(.2,.8,.25,1), box-shadow .28s ease, border-color .28s ease;
  box-shadow:0 2px 10px rgb(20 26 43 / .05), 0 8px 24px rgb(20 26 43 / .05);
}
/* dải màu accent trên đỉnh thẻ */
.lesson-card::before{
  content:""; position:absolute; inset:0 0 auto 0; height:4px;
  background:linear-gradient(90deg, rgb(var(--bar)), rgb(var(--honey)));
  transform:scaleX(0); transform-origin:left center;
  transition:transform .3s cubic-bezier(.2,.7,.2,1);
  pointer-events:none;
}
.lesson-card:hover, .lesson-card:focus-visible{
  transform:translateY(-4px);
  border-color:rgb(var(--bar) / .55);
  box-shadow:0 6px 16px rgb(20 26 43 / .08), 0 18px 40px rgb(20 26 43 / .1);
  outline:none;
}
.lesson-card:hover::before, .lesson-card:focus-visible::before{ transform:scaleX(1); }
.lesson-card:focus-visible{ box-shadow:0 0 0 3px rgb(var(--teal) / .5); }
@media (prefers-reduced-motion: reduce){
  .lesson-card{ transition:none; }
  .lesson-card:hover, .lesson-card:focus-visible{ transform:none; }
  .lesson-card::before{ transition:none; }
}


/* ============================================================
   Item 14 — Comic-panel mode (chỉ bài Peter Principle)
   Khung ảnh hoá thành ô truyện tranh: viền mực dày, đổ bóng cứng
   lệch (không blur), lưới halftone góc, caption dạng hộp lời kể,
   số ô kiểu tem tròn. Hộp "aha" thành bong bóng thoại có đuôi.
   Mọi chuyển động đều có nhánh prefers-reduced-motion.
   ============================================================ */
.comic-panel{
  position:relative;
  border:3px solid rgb(var(--ink));
  border-radius:14px;
  background:#fff;
  box-shadow:6px 6px 0 rgb(var(--ink));
  transition:transform .28s cubic-bezier(.2,.8,.25,1), box-shadow .28s ease;
  will-change:transform;
}
.comic-panel:nth-child(odd){ transform:rotate(-.6deg); }
.comic-panel:nth-child(even){ transform:rotate(.6deg); }
.comic-panel:hover{
  transform:rotate(0deg) translate(-2px,-2px);
  box-shadow:9px 9px 0 rgb(var(--ink));
}
/* Lưới halftone mờ ở góc trên phải */
.comic-panel::after{
  content:""; position:absolute; inset:0; z-index:3; pointer-events:none;
  border-radius:inherit;
  background-image:radial-gradient(rgb(var(--ink) / .22) 1.4px, transparent 1.6px);
  background-size:7px 7px;
  -webkit-mask:linear-gradient(215deg, #000 0 26%, transparent 46%);
          mask:linear-gradient(215deg, #000 0 26%, transparent 46%);
  opacity:.55;
}
.comic-panel img{ border-radius:11px 11px 0 0; }
/* Số ô kiểu tem tròn viền mực */
.comic-num{
  position:absolute; left:-10px; top:-10px; z-index:4;
  display:grid; place-items:center;
  height:34px; min-width:34px; padding:0 7px;
  border-radius:999px;
  border:3px solid rgb(var(--ink));
  background:rgb(var(--honey));
  color:rgb(var(--ink));
  font-weight:900; font-size:15px; line-height:1;
  box-shadow:3px 3px 0 rgb(var(--ink));
  transform:rotate(-8deg);
}
/* Hộp lời kể (caption) kiểu narration box */
.comic-cap{
  position:relative; z-index:4;
  margin:0; border-top:3px solid rgb(var(--ink));
  background:rgb(var(--amber-sk));
  color:rgb(var(--ink));
  font-weight:800; font-size:13px;
  padding:9px 12px;
  border-radius:0 0 11px 11px;
}
/* Caption dạng dải chung cho step nhiều ảnh */
.comic-note{
  border:3px solid rgb(var(--ink));
  border-radius:12px;
  background:rgb(var(--amber-sk));
  box-shadow:4px 4px 0 rgb(var(--ink));
  color:rgb(var(--ink)); font-weight:800; font-size:13px;
  padding:9px 13px;
}
/* Bong bóng thoại cho câu "aha" */
.comic-bubble{
  position:relative;
  border:3px solid rgb(var(--ink));
  border-radius:18px;
  background:#fff;
  color:rgb(var(--ink));
  box-shadow:7px 7px 0 rgb(var(--ink));
}
.comic-bubble::before{
  content:""; position:absolute; left:38px; bottom:-17px;
  width:0; height:0;
  border:9px solid transparent;
  border-top-color:rgb(var(--ink));
  border-bottom:0;
}
.comic-bubble::after{
  content:""; position:absolute; left:41px; bottom:-11px;
  width:0; height:0;
  border:6px solid transparent;
  border-top-color:#fff;
  border-bottom:0;
}
@media (prefers-reduced-motion: reduce){
  .comic-panel,
  .comic-panel:nth-child(odd),
  .comic-panel:nth-child(even){ transform:none; transition:none; }
  .comic-panel:hover{ transform:none; box-shadow:6px 6px 0 rgb(var(--ink)); }
}


/* ============================================================
   Item 12 — Design tokens qua CSS @property
   Đăng ký custom prop có kiểu -> transition được cả gradient
   position + cường độ glow (không làm được với --var thường).
   Áp cho card-frost: hover thì vệt sáng accent trượt ngang mép
   trên + shadow tím ấm nở ra, mượt theo token.
   ============================================================ */
@property --tok-glow{ syntax:"<number>"; inherits:false; initial-value:0; }
@property --tok-pos{ syntax:"<percentage>"; inherits:false; initial-value:0%; }

.card-frost{
  --tok-glow:0;
  --tok-pos:0%;
  position:relative;
  transition:
    box-shadow .45s ease,
    transform .4s cubic-bezier(.2,.7,.2,1),
    --tok-glow .55s ease,
    --tok-pos .7s cubic-bezier(.2,.7,.2,1);
}
.card-frost::before{
  content:""; position:absolute; inset:0; z-index:0;
  border-radius:inherit; pointer-events:none;
  background:radial-gradient(130% 70% at var(--tok-pos) 0%,
    rgb(var(--violet) / calc(.16 * var(--tok-glow))) 0%,
    rgb(var(--teal) / calc(.1 * var(--tok-glow))) 38%,
    transparent 72%);
}
.card-frost > *{ position:relative; z-index:1; }
.card-frost:hover{
  --tok-glow:1;
  --tok-pos:100%;
  transform:translateY(-2px);
  box-shadow:
    0 1px 0 rgb(255 255 255 / .8) inset,
    0 16px 40px rgb(var(--violet) / .12),
    0 4px 12px rgb(20 26 43 / .07);
}
@media (prefers-reduced-motion: reduce){
  .card-frost{ transition:none; }
  .card-frost:hover{ transform:none; --tok-pos:100%; --tok-glow:1; }
}


/* ============================================================
   Headline gradient — tiêu đề bài học: gradient ink→indigo→violet
   trôi chậm, kèm reveal nhẹ khi vào cảnh. Dùng cùng Sora display.
   ============================================================ */
.headline-grad{
  background-image:linear-gradient(100deg,
    rgb(var(--ink)) 0%,
    rgb(var(--ink)) 30%,
    rgb(var(--indigo-tx)) 58%,
    rgb(var(--violet-tx)) 82%,
    rgb(var(--indigo-tx)) 100%);
  background-size:220% auto;
  -webkit-background-clip:text; background-clip:text;
  -webkit-text-fill-color:transparent; color:transparent;
  animation:headlineFlow 11s ease-in-out infinite;
}
@keyframes headlineFlow{
  0%,100%{ background-position:0% 50%; }
  50%{ background-position:100% 50%; }
}
/* reveal: chữ hiện lên + trượt nhẹ, chạy 1 lần khi mount */
@keyframes headlineReveal{
  0%{ opacity:0; transform:translateY(10px); filter:blur(6px); }
  100%{ opacity:1; transform:translateY(0); filter:blur(0); }
}
.headline-reveal{ animation:headlineReveal .7s cubic-bezier(.2,.7,.2,1) both; }

@media (prefers-reduced-motion: reduce){
  .headline-grad{ animation:none !important; }
  .headline-reveal{ animation:none !important; }
}


/* ============================================================
   Story frame — nền phía sau ảnh mang dáng "trang truyện":
   giấy kem ấm, chấm halftone rất nhẹ, viền mực tĩnh + ke góc.
   Không có hiệu ứng chạy để tránh gây rối mắt.
   ============================================================ */
.story-frame{
  border-radius:18px;
  /* giấy kem ấm, có chút ánh màu dịu ở hai góc cho sang hơn */
  background-color:#fcf8f1;
  background-image:
    radial-gradient(120% 90% at 0% 0%, rgb(var(--indigo) / .10), transparent 46%),
    radial-gradient(120% 90% at 100% 100%, rgb(var(--violet) / .10), transparent 46%),
    radial-gradient(rgb(60 52 40 / .045) 1px, transparent 1.4px),
    linear-gradient(165deg, #fefcf6, #f5f0e6 68%, #efe9db);
  background-size:100% 100%, 100% 100%, 12px 12px, 100% 100%;
  /* viền mực gọn kiểu panel truyện + bóng đổ nhẹ như trang giấy */
  box-shadow:
    inset 0 0 0 1.5px rgb(255 255 255 / .85),
    inset 0 0 0 3px rgb(41 37 54 / .82),
    0 16px 34px rgb(41 37 54 / .14);
  overflow:hidden;
}
/* ánh sáng dịu trôi chậm ngang trang giấy — animation tinh tế, không chói */
.story-frame::after{
  content:""; position:absolute; inset:0; z-index:0; pointer-events:none;
  background:linear-gradient(115deg,
    transparent 30%,
    rgb(255 255 255 / .5) 46%,
    rgb(255 255 255 / .5) 54%,
    transparent 70%);
  background-size:260% 100%;
  mix-blend-mode:soft-light;
  animation:storySheen 9s ease-in-out infinite;
}
@keyframes storySheen{
  0%{ background-position:130% 0; }
  60%,100%{ background-position:-30% 0; }
}
/* ke góc mực ở 4 góc — như đóng khung trang truyện, khẽ đổi màu theo nhịp */
.story-frame-corner{
  position:absolute; width:16px; height:16px; z-index:5; pointer-events:none;
  border:2.5px solid rgb(41 37 54 / .78);
  animation:storyCorner 6s ease-in-out infinite;
}
.story-frame-corner--tl{ top:11px; left:11px; border-right:0; border-bottom:0; border-top-left-radius:6px; }
.story-frame-corner--tr{ top:11px; right:11px; border-left:0; border-bottom:0; border-top-right-radius:6px; animation-delay:1.5s; }
.story-frame-corner--bl{ bottom:11px; left:11px; border-right:0; border-top:0; border-bottom-left-radius:6px; animation-delay:4.5s; }
.story-frame-corner--br{ bottom:11px; right:11px; border-left:0; border-top:0; border-bottom-right-radius:6px; animation-delay:3s; }
@keyframes storyCorner{
  0%,100%{ border-color:rgb(41 37 54 / .78); }
  50%{ border-color:rgb(var(--indigo-tx) / .85); }
}
@media (prefers-reduced-motion: reduce){
  .story-frame::after{ animation:none !important; }
  .story-frame-corner{ animation:none !important; }
}
