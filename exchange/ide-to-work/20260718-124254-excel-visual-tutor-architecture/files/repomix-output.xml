import { useMemo, useState } from "react";
import { AnimatePresence } from "framer-motion";
import { RotateCcw } from "lucide-react";
import {
  computePivot, fieldValues, FIELD_LABEL, AGG_LABEL, CUBE,
  type FieldKey, type Agg, type PivotConfig,
} from "./pivot";

const ALL_FIELDS: FieldKey[] = ["kv", "np", "sp", "yr"];
type Zone = "rows" | "cols" | "filters" | "none";

const ZONE_LABEL: Record<Exclude<Zone, "none">, string> = {
  filters: "Bộ lọc (Filters)",
  rows: "Hàng (Rows)",
  cols: "Cột (Columns)",
};

const FIELD_ACCENT: Record<FieldKey, string> = {
  kv: "--teal",
  np: "--honey",
  sp: "--violet",
  yr: "--green",
};

function fmt(n: number, agg: Agg): string {
  if (agg === "count") return n.toLocaleString("vi-VN");
  if (agg === "pct") return n.toFixed(1) + "%";
  return n.toLocaleString("vi-VN", { maximumFractionDigits: 1 });
}

interface Props {
  preset?: Partial<PivotConfig>;
  lockZones?: boolean;
}

export default function PivotPlayground({ preset, lockZones }: Props) {
  const [rows, setRows] = useState<FieldKey[]>(preset?.rows ?? ["kv"]);
  const [cols, setCols] = useState<FieldKey[]>(preset?.cols ?? []);
  const [filters, setFilters] = useState<FieldKey[]>(
    preset?.filters ? (Object.keys(preset.filters) as FieldKey[]) : [],
  );
  const [agg, setAgg] = useState<Agg>(preset?.agg ?? "sum");
  const [filterSel, setFilterSel] = useState<Partial<Record<FieldKey, Set<string>>>>({});

  const zoneOf = (f: FieldKey): Zone =>
    rows.includes(f) ? "rows" : cols.includes(f) ? "cols" : filters.includes(f) ? "filters" : "none";

  function place(f: FieldKey, zone: Zone) {
    if (lockZones) return;
    setRows((r) => r.filter((x) => x !== f));
    setCols((c) => c.filter((x) => x !== f));
    setFilters((fl) => fl.filter((x) => x !== f));
    if (zone === "rows") setRows((r) => [...r, f]);
    else if (zone === "cols") setCols((c) => [...c, f]);
    else if (zone === "filters") setFilters((fl) => [...fl, f]);
  }

  const cfg: PivotConfig = useMemo(() => {
    const fl: PivotConfig["filters"] = {};
    for (const f of filters) {
      const sel = filterSel[f];
      if (sel && sel.size > 0) fl[f] = sel;
    }
    return { rows, cols, agg, filters: fl };
  }, [rows, cols, agg, filters, filterSel]);

  const result = useMemo(() => computePivot(cfg), [cfg]);

  function toggleFilterVal(f: FieldKey, v: string) {
    setFilterSel((prev) => {
      const cur = new Set(prev[f] ?? []);
      if (cur.has(v)) cur.delete(v);
      else cur.add(v);
      return { ...prev, [f]: cur };
    });
  }

  function reset() {
    setRows(preset?.rows ?? ["kv"]);
    setCols(preset?.cols ?? []);
    setFilters(preset?.filters ? (Object.keys(preset.filters) as FieldKey[]) : []);
    setAgg(preset?.agg ?? "sum");
    setFilterSel({});
  }

  const dragProps = (f: FieldKey) =>
    lockZones
      ? {}
      : {
          draggable: true,
          onDragStart: (e: React.DragEvent) => e.dataTransfer.setData("field", f),
        };

  const dropProps = (zone: Zone) =>
    lockZones
      ? {}
      : {
          onDragOver: (e: React.DragEvent) => e.preventDefault(),
          onDrop: (e: React.DragEvent) => {
            const f = e.dataTransfer.getData("field") as FieldKey;
            if (f) place(f, zone);
          },
        };

  const Chip = ({ f }: { f: FieldKey }) => (
    <button
      {...dragProps(f)}
      onClick={() => {
        if (lockZones) return;
        const z = zoneOf(f);
        place(f, z === "none" ? "rows" : z === "rows" ? "cols" : z === "cols" ? "filters" : "none");
      }}
      className="inline-flex cursor-grab items-center gap-1.5 rounded-lg px-2.5 py-1.5 text-[12.5px] font-extrabold text-white shadow-soft transition-transform hover:-translate-y-px active:cursor-grabbing active:scale-95"
      style={{ backgroundColor: `rgb(var(${FIELD_ACCENT[f]}))` }}
    >
      <span className="h-1.5 w-1.5 rounded-full bg-white/70" />
      {FIELD_LABEL[f]}
    </button>
  );

  const unplaced = ALL_FIELDS.filter((f) => zoneOf(f) === "none");

  return (
    <div className="rounded-2xl border border-line bg-gradient-to-b from-[#fdfbf6] to-[#f7f3ea] p-4 shadow-[inset_0_1px_0_#fff]">
      <div className="mb-3 flex items-center justify-between gap-2">
        <div className="text-[12.5px] font-extrabold text-soft">
          Kéo trường vào các vùng, bảng Pivot tính lại ngay từ {CUBE.rawCount.toLocaleString("vi-VN")} dòng dữ liệu thật.
        </div>
        {!lockZones && (
          <button
            onClick={reset}
            className="inline-flex items-center gap-1.5 rounded-lg bg-[#efe8d8] px-2.5 py-1.5 text-[12px] font-extrabold text-soft transition hover:text-ink"
          >
            <RotateCcw size={13} strokeWidth={2.6} /> Đặt lại
          </button>
        )}
      </div>

      <div className="grid gap-3 lg:grid-cols-[260px_1fr]">
        {/* LEFT: field list + zones */}
        <div className="flex flex-col gap-2.5">
          {!lockZones && (
            <div className="rounded-xl border border-dashed border-line bg-white/60 p-2.5">
              <div className="mb-1.5 text-[11px] font-extrabold uppercase tracking-wide text-soft">
                Các trường
              </div>
              <div className="flex flex-wrap gap-1.5">
                {unplaced.length ? unplaced.map((f) => <Chip key={f} f={f} />)
                  : <span className="text-[12px] text-soft/70">Đã kéo hết vào vùng bên dưới</span>}
              </div>
            </div>
          )}

          {(["filters", "rows", "cols"] as const).map((zone) => {
            const fs = zone === "rows" ? rows : zone === "cols" ? cols : filters;
            return (
              <div key={zone} {...dropProps(zone)}
                className="rounded-xl border border-line bg-white/70 p-2.5 min-h-[58px]">
                <div className="mb-1.5 text-[11px] font-extrabold uppercase tracking-wide text-soft">
                  {ZONE_LABEL[zone]}
                </div>
                <div className="flex flex-wrap gap-1.5">
                  <AnimatePresence>
                    {fs.length ? fs.map((f) => <Chip key={f} f={f} />)
                      : <span className="text-[12px] text-soft/60">{lockZones ? "—" : "thả trường vào đây"}</span>}
                  </AnimatePresence>
                </div>
                {/* filter value chips */}
                {zone === "filters" && filters.map((f) => (
                  <div key={f} className="mt-2 flex flex-wrap gap-1">
                    {fieldValues(f).map((v) => {
                      const on = filterSel[f]?.has(v) ?? false;
                      return (
                        <button key={v} onClick={() => toggleFilterVal(f, v)}
                          className={"rounded-md px-1.5 py-0.5 text-[10.5px] font-bold transition " +
                            (on ? "bg-teal text-white" : "bg-[#efe8d8] text-soft hover:text-ink")}>
                          {v}
                        </button>
                      );
                    })}
                  </div>
                ))}
              </div>
            );
          })}

          {/* value aggregation */}
          <div className="rounded-xl border border-line bg-white/70 p-2.5">
            <div className="mb-1.5 text-[11px] font-extrabold uppercase tracking-wide text-soft">
              Giá trị (Values): Doanh thu
            </div>
            <div className="flex flex-wrap gap-1">
              {(Object.keys(AGG_LABEL) as Agg[]).map((a) => (
                <button key={a} onClick={() => setAgg(a)}
                  className={"rounded-md px-2 py-1 text-[11px] font-extrabold transition " +
                    (agg === a ? "bg-ink text-white" : "bg-[#efe8d8] text-soft hover:text-ink")}>
                  {AGG_LABEL[a]}
                </button>
              ))}
            </div>
          </div>
        </div>

        {/* RIGHT: pivot table */}
        <div className="overflow-auto rounded-xl border border-line bg-white p-2 shadow-soft">
          <PivotTable result={result} agg={agg} />
        </div>
      </div>
    </div>
  );
}

function PivotTable({ result, agg }: { result: ReturnType<typeof computePivot>; agg: Agg }) {
  const { rowKeys, colKeys, cells, rowTotals, colTotals, grand } = result;
  const hasCols = colKeys.length > 0 && colKeys[0].length > 0;

  return (
    <table className="w-full border-collapse text-[12.5px]">
      <thead>
        <tr>
          <th className="sticky left-0 z-10 border border-line bg-[#f3efe6] px-2.5 py-1.5 text-left font-extrabold text-soft">
            {result.rowFields.map((f) => FIELD_LABEL[f]).join(" / ") || "Tổng"}
          </th>
          {hasCols
            ? colKeys.map((ck, ci) => (
                <th key={ci} className="border border-line bg-[#eef3fa] px-2.5 py-1.5 font-extrabold text-ink">
                  {ck.join(" / ")}
                </th>
              ))
            : <th className="border border-line bg-[#eef3fa] px-2.5 py-1.5 font-extrabold text-ink">{AGG_LABEL[agg]}</th>}
          {hasCols && (
            <th className="border border-line bg-teal-sk px-2.5 py-1.5 font-extrabold text-teal-d">Tổng</th>
          )}
        </tr>
      </thead>
      <tbody>
        {rowKeys.map((rk, ri) => (
          <tr key={ri}>
            <td className="sticky left-0 z-10 border border-line bg-[#faf7f0] px-2.5 py-1.5 font-bold text-ink">
              {rk.join(" / ") || "Tất cả"}
            </td>
            {hasCols
              ? cells[ri].map((v, ci) => (
                  <td key={ci} className="border border-line px-2.5 py-1.5 text-right tabular-nums text-ink">
                    {fmt(v, agg)}
                  </td>
                ))
              : (
                <td className="border border-line px-2.5 py-1.5 text-right tabular-nums text-ink">
                  {fmt(rowTotals[ri], agg)}
                </td>
              )}
            {hasCols && (
              <td className="border border-line bg-teal-sk/40 px-2.5 py-1.5 text-right font-extrabold tabular-nums text-teal-d">
                {fmt(rowTotals[ri], agg)}
              </td>
            )}
          </tr>
        ))}
        {/* grand total row */}
        <tr>
          <td className="sticky left-0 z-10 border border-line bg-honey/15 px-2.5 py-1.5 font-extrabold text-ink">
            Tổng cộng
          </td>
          {hasCols
            ? colTotals.map((v, ci) => (
                <td key={ci} className="border border-line bg-honey/10 px-2.5 py-1.5 text-right font-extrabold tabular-nums text-ink">
                  {fmt(v, agg)}
                </td>
              ))
            : (
              <td className="border border-line bg-honey/10 px-2.5 py-1.5 text-right font-extrabold tabular-nums text-ink">
                {fmt(grand, agg)}
              </td>
            )}
          {hasCols && (
            <td className="border border-line bg-honey/25 px-2.5 py-1.5 text-right font-extrabold tabular-nums text-ink">
              {fmt(grand, agg)}
            </td>
          )}
        </tr>
      </tbody>
    </table>
  );
}
