<file path="src/lessons/peter-principle/RadialGauge.tsx">
import { useEffect, useRef, useState } from "react";

interface GaugeItem {
  value: number; // 0..100
  label: string;
}

/** Kiểm tra prefers-reduced-motion an toàn cho SSR. */
function prefersReduced() {
  return (
    typeof window !== "undefined" &&
    window.matchMedia?.("(prefers-reduced-motion: reduce)").matches === true
  );
}

/** Một vòng gauge: stroke chạy 0→value, số đếm lên khi cuộn vào tầm nhìn. */
function Gauge({ value, label, delay }: GaugeItem & { delay: number }) {
  const ref = useRef<SVGSVGElement | null>(null);
  const [shown, setShown] = useState(0);

  useEffect(() => {
    const node = ref.current;
    if (!node) return;

    if (prefersReduced()) {
      setShown(value);
      return;
    }

    let raf = 0;
    let started = false;
    const run = () => {
      const dur = 1100;
      const t0 = performance.now();
      const tick = (now: number) => {
        const p = Math.min(1, (now - t0) / dur);
        // easeOutCubic
        const e = 1 - Math.pow(1 - p, 3);
        setShown(Math.round(value * e));
        if (p < 1) raf = requestAnimationFrame(tick);
      };
      raf = requestAnimationFrame(tick);
    };

    const io = new IntersectionObserver(
      (entries) => {
        for (const en of entries) {
          if (en.isIntersecting && !started) {
            started = true;
            window.setTimeout(run, delay);
            io.disconnect();
          }
        }
      },
      { threshold: 0.4 }
    );
    io.observe(node);
    return () => {
      io.disconnect();
      cancelAnimationFrame(raf);
    };
  }, [value, delay]);

  const R = 30;
  const C = 2 * Math.PI * R;
  const off = C * (1 - shown / 100);

  return (
    <div className="flex flex-col items-center gap-2 text-center">
      <svg
        ref={ref}
        viewBox="0 0 76 76"
        className="gauge-ring h-[76px] w-[76px] -rotate-90"
        role="img"
        aria-label={`${value}% ${label}`}
      >
        <circle
          cx="38"
          cy="38"
          r={R}
          fill="none"
          stroke="rgb(var(--violet) / 0.14)"
          strokeWidth="7"
        />
        <circle
          cx="38"
          cy="38"
          r={R}
          fill="none"
          stroke="url(#gaugeGrad)"
          strokeWidth="7"
          strokeLinecap="round"
          strokeDasharray={C}
          strokeDashoffset={off}
        />
        <defs>
          <linearGradient id="gaugeGrad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stopColor="rgb(var(--violet))" />
            <stop offset="100%" stopColor="rgb(var(--teal))" />
          </linearGradient>
        </defs>
        <text
          x="38"
          y="38"
          transform="rotate(90 38 38)"
          textAnchor="middle"
          dominantBaseline="central"
          className="fill-violet-tx text-[19px] font-black"
        >
          {shown}%
        </text>
      </svg>
      <span className="max-w-[140px] text-[12px] font-semibold leading-snug text-soft">
        {label}
      </span>
    </div>
  );
}

/** Lưới 4 vòng số liệu, thay cho danh sách bullet phẳng. */
export default function RadialGauge({ items }: { items: GaugeItem[] }) {
  return (
    <div className="mt-1 grid grid-cols-2 gap-x-2 gap-y-4 rounded-2xl border border-line bg-white/70 px-3 py-4 sm:grid-cols-4">
      {items.map((it, i) => (
        <Gauge key={i} value={it.value} label={it.label} delay={i * 140} />
      ))}
    </div>
  );
}
</file>

<file path="src/lessons/peter-principle/ScriptDemo.tsx">
import { useState } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { MessageCircle, Copy, Check, Handshake, Route, BadgeCheck } from "lucide-react";
import type { LucideIcon } from "lucide-react";

/**
 * Sân chơi 3 — Ba script "tái định vị thay vì từ chối".
 * Ba tab, mỗi tab một mẫu lời thoại có thể copy nguyên văn.
 * Video: ba cách nói khi bạn không muốn nhận thăng chức mà không phá hoà khí.
 */

interface Script {
  id: "contribution" | "path" | "commitment";
  Icon: LucideIcon;
  label: string;
  tag: string;
  frame: string; // câu chốt "khung" mà video nhấn
  body: string;  // lời thoại có thể copy
  note: string;  // vì sao câu này hoạt động
}

const SCRIPTS: Script[] = [
  {
    id: "contribution",
    Icon: Handshake,
    label: "Nói bằng đóng góp",
    tag: "Cách 1",
    frame: "Không nói \"em không muốn\". Nói: giá trị em mang lại cho công ty đang nằm ở đâu.",
    body:
      "Anh chị ơi, em vô cùng trân trọng sự tin tưởng này. Qua đánh giá thực tế, em nhận thấy đóng góp lớn nhất mà em đang mang lại cho công ty nằm ở việc em trực tiếp làm ra sản phẩm. Nếu em chuyển sang quản lý, công ty sẽ mất đi một người tạo ra kết quả trực tiếp, đồng thời nhận về một quản lý còn đang tập sự. Em không chắc đó là điều tốt nhất cho công ty ở giai đoạn này.",
    note:
      "Bạn không từ chối. Bạn đang bảo vệ lợi ích của công ty. Đó là thứ ngôn ngữ mà sếp có thể tôn trọng, kể cả khi họ chưa đồng ý.",
  },
  {
    id: "path",
    Icon: Route,
    label: "Đề xuất lộ trình khác",
    tag: "Cách 2",
    frame: "Không đóng cửa. Đề xuất một lộ trình chuyên gia song song — cái ngành nhân sự gọi là individual contributor.",
    body:
      "Em có thể đề xuất một hướng khác không ạ? Em muốn được nhận những dự án khó nhất, phức tạp nhất, những thứ mà không ai khác trong team đủ năng lực xử lý. Em sẵn sàng nhận thêm vai trò mentor cho các bạn trẻ mới vào. Với đóng góp đó, liệu anh chị có thể xem xét điều chỉnh mức thù lao phù hợp trong khi em vẫn giữ nguyên vai trò chuyên môn không ạ?",
    note:
      "Ở các công ty công nghệ, lộ trình này đã có chức danh riêng: kỹ sư cấp cao, kiến trúc sư hệ thống, chuyên gia kỹ thuật chủ chốt. Mức lương thường không kém, có khi cao hơn quản lý cùng cấp.",
  },
  {
    id: "commitment",
    Icon: BadgeCheck,
    label: "Đóng khung cam kết dài hạn",
    tag: "Cách 3",
    frame: "Không nói không với hiện tại. Hứa một tương lai, mở ra một con đường khác.",
    body:
      "Anh chị ơi, đây là một cơ hội em trân trọng thật sự. Mục tiêu của em trong ba năm tới là trở thành chuyên gia giải quyết những bài toán kỹ thuật khó nhất mà công ty gặp phải. Nếu em nhận vai trò quản lý ngay lúc này, em lo team sẽ bị chậm tiến độ trong giai đoạn chuyển giao. Em hy vọng trong tương lai, khi đã đạt đủ năng lực, công ty sẽ xem xét em ở một vai trò cố vấn chiến lược phù hợp hơn.",
    note:
      "Trong văn hoá Việt Nam, đây là cách giải quyết mâu thuẫn giữ được thể diện cho cả hai phía. Bạn không đóng cửa hôm nay, bạn mở một cửa khác cho ngày mai.",
  },
];

export default function ScriptDemo() {
  const [cur, setCur] = useState<Script["id"]>("contribution");
  const [copied, setCopied] = useState<Script["id"] | null>(null);
  const script = SCRIPTS.find((s) => s.id === cur)!;

  async function copy(id: Script["id"], text: string) {
    try {
      await navigator.clipboard.writeText(text);
      setCopied(id);
      setTimeout(() => setCopied((c) => (c === id ? null : c)), 1600);
    } catch {
      // fallback: chọn textarea tạm
      const ta = document.createElement("textarea");
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand("copy"); } catch { /* ignore */ }
      document.body.removeChild(ta);
      setCopied(id);
      setTimeout(() => setCopied((c) => (c === id ? null : c)), 1600);
    }
  }

  return (
    <div className="mt-4 rounded-2xl border border-line bg-white/80 p-4 shadow-soft">
      <div className="mb-3 flex items-center gap-2">
        <MessageCircle size={16} strokeWidth={2.6} className="text-violet-tx" />
        <span className="text-[12.5px] font-black uppercase tracking-wider text-violet-tx">
          Ba script tái định vị · copy nguyên văn
        </span>
      </div>

      <div className="mb-3 flex flex-wrap gap-1.5">
        {SCRIPTS.map((s) => {
          const on = s.id === cur;
          return (
            <button
              key={s.id}
              onClick={() => setCur(s.id)}
              className={
                "inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 text-[12.5px] font-extrabold transition " +
                (on
                  ? "border-violet-tx bg-violet text-white"
                  : "border-line bg-white text-soft hover:border-violet hover:text-violet-tx")
              }
            >
              <s.Icon size={13} strokeWidth={2.6} />
              <span className="text-[11px] font-black uppercase tracking-wider opacity-70">{s.tag}</span>
              <span>·</span>
              {s.label}
            </button>
          );
        })}
      </div>

      <AnimatePresence mode="wait">
        <motion.div
          key={script.id}
          initial={{ opacity: 0, y: 8 }}
          animate={{ opacity: 1, y: 0 }}
          exit={{ opacity: 0, y: -6 }}
          transition={{ duration: 0.24 }}
          className="space-y-3"
        >
          <div className="rounded-xl bg-gradient-to-br from-[#f3f0ff] to-[#efeaff] p-3.5 text-[13.5px] font-bold leading-relaxed text-violet-tx">
            {script.frame}
          </div>

          <div className="relative rounded-xl border border-line bg-white p-4">
            <button
              onClick={() => copy(script.id, script.body)}
              className="absolute right-2 top-2 inline-flex items-center gap-1.5 rounded-full border border-line bg-white/95 px-2.5 py-1 text-[11.5px] font-extrabold text-soft transition hover:border-violet hover:text-violet-tx"
              aria-label="Copy lời thoại"
            >
