import { Sparkles, ArrowRight, Clock } from "lucide-react";
import { LESSONS } from "../lessons/registry";

/** Home screen: pick a lesson, rendered as a flat responsive card grid. */
/** accent var name -> { bar (dải màu trên thẻ), tx (màu icon) } */
const ACCENT: Record<string, { bar: string; tx: string }> = {
  teal: { bar: "teal", tx: "teal-d" },
  honey: { bar: "honey", tx: "honey" },
  violet: { bar: "violet", tx: "violet-tx" },
  indigo: { bar: "indigo", tx: "indigo-tx" },
};

export default function LessonPicker({ onPick }: { onPick: (id: string) => void }) {
  return (
    <div className="mx-auto max-w-[1100px] px-[clamp(16px,3vw,46px)] pb-20">
      <header className="relative px-1 pb-2 pt-10 text-center">
        <span className="inline-flex items-center gap-2 rounded-full bg-gradient-to-br from-teal-sk to-[#e9fbf8] px-4 py-2 text-[12.5px] font-black uppercase tracking-wider text-teal-d shadow-soft">
          <Sparkles size={15} strokeWidth={2.6} /> Excel Visual Tutor
        </span>
        <h1 className="mx-auto mt-4 max-w-3xl bg-gradient-to-r from-ink via-ink to-teal-d bg-clip-text text-[clamp(28px,4.6vw,46px)] font-black leading-tight tracking-tight text-transparent">
          Học Excel bằng mô phỏng
        </h1>
        <p className="mx-auto mt-2 max-w-xl text-[clamp(14.5px,2vw,17px)] text-soft">
          Mỗi bài là một sân chơi tương tác. Nhìn dữ liệu biến đổi từng bước, hiểu vì sao thay vì học vẹt.
        </p>
      </header>

      <div className="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {LESSONS.map((l) => {
          const Icon = l.Icon;
          const a = ACCENT[l.accent] ?? ACCENT.teal;
          return (
            <button
              key={l.id}
              onClick={() => onPick(l.id)}
              className="lesson-card group flex flex-col text-left"
              style={{ "--bar": `var(--${a.bar})` } as React.CSSProperties}
              aria-label={`Mở bài: ${l.title}`}
