import { useEffect, useRef, useState } from "react";
import { motion } from "framer-motion";
import { Lightbulb, ChevronDown } from "lucide-react";
import type { CuteStep } from "./steps";
import CuteDemo from "./CuteDemo";
import CuteSim from "./CuteSim";
import { CuteTiersPanel, CuteMicroscope } from "./CuteExplain";
import { useTilt } from "../../lib/useTilt";
import { FormulaFlow } from "../../lib/formulaFlow";

/**
 * RichText — render story HTML và cho "kính lúp đọc" tự quét qua các cụm
 * nhấn mạnh (<b>, <code>) theo đúng thứ tự xuất hiện: mỗi cụm nở to + sáng
 * lần lượt rồi lặp lại, giống hiệu ứng đọc công thức nhưng áp cho CHỮ.
 */
function RichText({ html, className }: { html: string; className?: string }) {
  const ref = useRef<HTMLParagraphElement | null>(null);

  useEffect(() => {
    const root = ref.current;
    if (!root) return;
    if (
      typeof window !== "undefined" &&
      window.matchMedia?.("(prefers-reduced-motion: reduce)").matches
    ) {
      return;
    }
    // Các cụm nhấn mạnh trong lời giảng = "token đọc" của phần chữ.
    const marks = Array.from(root.querySelectorAll("b, strong, code")) as HTMLElement[];
    if (marks.length < 2) return;
    const delay = marks.length <= 6 ? 0.7 : marks.length <= 12 ? 0.55 : 0.45;
    const cycle = Math.max(5, marks.length * delay + 2.2);
    marks.forEach((el, i) => {
      el.classList.add("ff-read");
      el.style.setProperty("--ff-cycle", cycle.toFixed(2) + "s");
      el.style.setProperty("--ff-read-delay", (i * delay).toFixed(2) + "s");
    });
    return () => {
      marks.forEach((el) => {
        el.classList.remove("ff-read");
        el.style.removeProperty("--ff-cycle");
        el.style.removeProperty("--ff-read-delay");
      });
    };
  }, [html]);

  return (
    <p ref={ref} className={className} dangerouslySetInnerHTML={{ __html: html }} />
  );
}

/** Renders one image-based teaching step: real frame + narration + technique. */
export default function CuteStepView({ step }: { step: CuteStep }) {
  const [open, setOpen] = useState<number | null>(0);
  const [focusCol, setFocusCol] = useState<"A" | "B" | "C" | "D" | null>(null);
  const imgTilt = useTilt({ max: 6 });

  return (
    <motion.div
      key={step.id}
      initial={{ opacity: 0, y: 16 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.4, ease: [0.2, 0.7, 0.2, 1] }}
    >
      <div className="mb-1 flex items-center gap-4">
        <div className="float-3d grid h-[58px] w-[58px] shrink-0 place-items-center rounded-2xl bg-[rgb(var(--violet)/0.14)] text-[rgb(var(--violet-tx))] shadow-soft ring-1 ring-inset ring-[rgb(var(--violet)/0.2)]">
          <Lightbulb size={28} strokeWidth={2} aria-hidden="true" />
        </div>
        <div>
          <span className="badge-glow inline-block rounded-full bg-[rgb(var(--violet-sk))] px-2.5 py-0.5 text-[11.5px] font-extrabold uppercase tracking-wide text-[rgb(var(--violet-tx))]">
            {step.tag}
          </span>
          <h2 className="mt-1.5 text-[clamp(20px,2.7vw,27px)] font-black leading-tight tracking-tight text-ink">
            {step.title}
          </h2>
        </div>
      </div>

      <div className="mt-5 grid gap-6 lg:grid-cols-[1.15fr_.85fr]">
        {/* left: interactive sandbox OR real frame + caption */}
        <div className="min-w-0 space-y-3">
          {step.demo ? (
            <CuteDemo />
          ) : (
            <>
              <div className="scene-3d">
                <figure
                  ref={imgTilt.ref}
                  onMouseMove={imgTilt.onMouseMove}
                  onMouseLeave={imgTilt.onMouseLeave}
                  className="figure-aura tilt-3d relative overflow-hidden rounded-2xl border border-line shadow-lift"
                >
                  <img
                    src={step.image}
                    alt={step.caption}
                    className="frame-breath block w-full"
                    loading="lazy"
                  />
                  <figcaption className="border-t border-line bg-white/70 px-4 py-2.5 text-[13px] font-semibold text-soft">
                    {step.caption}
                  </figcaption>
                  <span className="tilt-glare" aria-hidden="true" />
                </figure>
              </div>
              {step.sim && <CuteSim mode={step.sim} focusCol={focusCol} />}
            </>
          )}
        </div>

        {/* right: story + formula + why */}
        <div className="flex min-w-0 flex-col gap-4">
          <RichText
            html={step.story}
            className="max-w-none text-[clamp(15px,1.5vw,16.5px)] text-[#333c54] [&_b]:text-ink [&_code]:rounded [&_code]:bg-[#eef1f8] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-[.86em]"
          />

          {step.tiers && <CuteTiersPanel tiers={step.tiers} />}

          {step.micro && step.formula ? (
            <CuteMicroscope step={step} focusCol={focusCol} setFocusCol={setFocusCol} />
          ) : (
            step.formula && (
              <div className="rounded-2xl border border-[rgb(var(--violet)/0.25)] bg-[rgb(var(--violet-sk)/0.5)] p-4">
                <div className="block break-words text-[14.5px]">
                  <FormulaFlow formula={step.formula} steps={step.readingSteps} />
                </div>
                {step.chips && (
                  <ul className="mt-3 space-y-2">
                    {step.chips.map(([label, desc], i) => (
                      <li key={i} className="flex flex-col gap-0.5">
                        <code className="w-fit rounded bg-white/80 px-1.5 py-0.5 font-mono text-[12.5px] font-bold text-ink">
                          {label}
                        </code>
                        <span className="text-[13px] text-[#39445a]">{desc}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            )
          )}

          {step.why && (
            <div className="space-y-2">
              {step.why.map(([q, a], i) => {
                const on = open === i;
                return (
                  <div key={i} className="overflow-hidden rounded-xl border border-line bg-white/70">
                    <button
                      onClick={() => setOpen(on ? null : i)}
                      className="flex w-full items-center justify-between gap-2 px-4 py-2.5 text-left text-[13.5px] font-extrabold text-ink transition hover:bg-white"
                    >
                      {q}
                      <ChevronDown
                        size={16}
                        strokeWidth={2.8}
                        className={"shrink-0 transition-transform " + (on ? "rotate-180" : "")}
                      />
                    </button>
                    {on && (
                      <p className="border-t border-line px-4 py-2.5 text-[13.5px] leading-relaxed text-[#39445a]">
                        {a}
                      </p>
                    )}
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>

      <div className="formula-shine mt-6 flex items-center gap-3 overflow-hidden rounded-2xl bg-gradient-to-r from-[rgb(var(--violet))] to-[rgb(var(--violet-tx))] px-5 py-4 text-white shadow-[0_10px_24px_rgb(var(--violet)/0.28)]">
        <span className="float-3d grid h-8 w-8 shrink-0 place-items-center rounded-xl bg-white/20">
          <Lightbulb size={18} strokeWidth={2.2} aria-hidden="true" />
        </span>
        <span className="text-[15px] font-bold">{step.summary}</span>
      </div>
    </motion.div>
  );
}
