@tailwind base;
@tailwind components;
@tailwind utilities;

:root{
  --ink:20 26 43;
  --soft:90 104 131;
  --line:230 235 244;
  --panel:255 255 255;
  /* paper background palette */
  --paper:245 238 224;      /* warm cream base */
  --paper-2:250 244 232;    /* lighter cream */
  --paper-line:214 203 180; /* faint ruling */
  --paper-dot:203 190 165;  /* fiber speckle */
  --teal:13 167 152; --teal-d:9 128 117; --teal-sk:206 242 237; --teal-edge:7 100 91;
  --ink-teal:6 74 68;                 /* deep ink accent for text/underline */
  --amber:232 154 42; --amber-sk:255 238 205; --amber-tx:132 82 6; --amber-edge:176 108 12;
  --honey:224 138 32;                 /* warm secondary accent */
  --violet:123 108 241; --violet-sk:233 230 255; --violet-tx:73 58 182;
  --green:18 165 111; --green-sk:214 246 231; --green-tx:12 122 82;
  --red:229 72 77; --red-sk:255 225 226;
  --indigo:88 101 242; --indigo-sk:227 230 255; --indigo-tx:60 66 176;
}

*{box-sizing:border-box}
html{scroll-behavior:smooth}

/* ============================================================
   Typography — Sora cho tiêu đề, Plus Jakarta Sans cho nội dung.
   Heading cân dòng (balance), kerning chặt, chống "mồ côi" chữ.
   ============================================================ */
h1,h2,h3,h4,h5,h6{
  font-family:theme('fontFamily.display');
  font-weight:800;
  letter-spacing:-0.022em;
  text-wrap:balance;
  font-feature-settings:"ss01" 1, "kern" 1, "liga" 1;
}
h1{ letter-spacing:-0.03em; }
p{ text-wrap:pretty; }
/* Số liệu canh đều cột (tabular) khi cần bảng/gauge */
.nums-tabular{ font-variant-numeric:tabular-nums; font-feature-settings:"tnum" 1; }

body{
  margin:0;
  font-family:theme('fontFamily.sans');
  color:rgb(var(--ink));
  line-height:1.62;
  letter-spacing:-0.006em;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
  text-rendering:optimizeLegibility;
  font-feature-settings:"ss01" 1, "cv01" 1, "kern" 1, "liga" 1, "calt" 1;
  font-optical-sizing:auto;
  position:relative;
  overflow-x:hidden;
  background-color:rgb(var(--paper));
  background-image:
    /* soft vignette so edges feel like a real sheet */
    radial-gradient(120% 90% at 50% 0%, rgb(var(--paper-2) / .9), transparent 60%),
    radial-gradient(140% 120% at 100% 100%, rgb(233 222 200 / .55), transparent 55%),
    /* fine paper fibers (tiny speckle) */
    radial-gradient(rgb(var(--paper-dot) / .16) 1px, transparent 1.4px),
    /* faint horizontal ruling like notebook paper */
    repeating-linear-gradient(0deg, transparent 0 31px, rgb(var(--paper-line) / .18) 31px 32px);
  background-size:
    auto,
    auto,
    18px 18px,
    100% 32px;
  background-attachment:fixed, fixed, fixed, fixed;
}

/* ---- Soft aurora background: slow, low-contrast, non-distracting ---- */
.aurora{
  position:fixed; inset:0; z-index:-1; overflow:hidden; pointer-events:none;
}
.aurora::before,
.aurora::after{
  content:""; position:absolute; border-radius:50%;
  filter:blur(100px); opacity:.34; mix-blend-mode:multiply;
}
.aurora::before{
  width:60vw; height:60vw; top:-14vw; right:-10vw;
  background:radial-gradient(circle at 30% 30%, rgb(235 224 198), transparent 62%);
  animation:auroraA 26s ease-in-out infinite;
}
.aurora::after{
  width:56vw; height:56vw; bottom:-16vw; left:-12vw;
  background:radial-gradient(circle at 60% 40%, rgb(238 227 205), transparent 60%);
  animation:auroraB 32s ease-in-out infinite;
}
.aurora .blob3{
  position:absolute; width:44vw; height:44vw; left:40%; bottom:-24vw;
  border-radius:50%; filter:blur(90px); opacity:.4;
  background:radial-gradient(circle at 50% 50%, rgb(244 231 205), transparent 60%);
  animation:auroraA 30s ease-in-out infinite reverse;
}

@keyframes auroraA{0%,100%{transform:translate3d(0,0,0) scale(1)}50%{transform:translate3d(3%,4%,0) scale(1.08)}}
@keyframes auroraB{0%,100%{transform:translate3d(0,0,0) scale(1)}50%{transform:translate3d(-4%,-3%,0) scale(1.12)}}

/* frosted panel */
.glass{
  background:rgb(255 253 248 / .82);
  backdrop-filter:blur(14px) saturate(1.05);
  -webkit-backdrop-filter:blur(14px) saturate(1.05);
}

/* ============================================================
   Glass / frost card — nền mờ để thấy aurora phía sau, viền sáng
   (dùng cho card story / tiers / why; KHÔNG đổi layout)
   ============================================================ */
.card-frost{
  background:rgb(255 253 248 / .58);
  backdrop-filter:blur(12px) saturate(1.6);
  -webkit-backdrop-filter:blur(12px) saturate(1.6);
  border:1px solid rgb(255 255 255 / .55);
  box-shadow:
    0 1px 0 rgb(255 255 255 / .7) inset,
    0 10px 30px rgb(20 26 43 / .07),
    0 2px 8px rgb(20 26 43 / .05);
}
.card-frost-soft{
  background:rgb(255 253 248 / .5);
  backdrop-filter:blur(10px) saturate(1.5);
  -webkit-backdrop-filter:blur(10px) saturate(1.5);
  border:1px solid rgb(255 255 255 / .5);
}
@supports not ((backdrop-filter:blur(1px)) or (-webkit-backdrop-filter:blur(1px))){
  .card-frost,.card-frost-soft{ background:rgb(255 253 248 / .92); }
}

/* ============================================================
   Kbd 3D — phím giả lập bàn phím thật (bevel + đổ bóng đáy phím)
   ============================================================ */
.kbd-3d{
  display:inline-flex; align-items:center; justify-content:center;
  padding:2px 9px; min-width:24px;
  border-radius:7px;
  font-weight:800; line-height:1.5;
  color:rgb(var(--ink));
  background:linear-gradient(180deg, #ffffff 0%, #f2f4f9 62%, #e6eaf2 100%);
  border:1px solid #cfd6e4;
  border-bottom-color:#b6bfd1;
  box-shadow:
    0 1px 0 rgb(255 255 255 / .9) inset,
    0 -1px 0 rgb(182 191 209 / .5) inset,
    0 2px 0 #c3cbdb,
    0 3px 0 #b0b9cc,
    0 4px 6px rgb(20 26 43 / .18);
  transform:translateZ(0);
  transition:transform .09s ease, box-shadow .09s ease;
}
.kbd-3d:hover{
  transform:translateY(1px);
  box-shadow:
    0 1px 0 rgb(255 255 255 / .9) inset,
    0 2px 0 #c3cbdb,
    0 3px 5px rgb(20 26 43 / .16);
}
.kbd-3d:active{
  transform:translateY(2px);
  box-shadow:
    0 1px 0 rgb(255 255 255 / .8) inset,
    0 1px 0 #c3cbdb,
    0 2px 3px rgb(20 26 43 / .14);
}
@media (prefers-reduced-motion: reduce){
  .kbd-3d{ transition:none; }
  .kbd-3d:hover,.kbd-3d:active{ transform:none; }
}

code{font-family:theme('fontFamily.mono'); font-size:.9em}

/* formula shimmer accent */
.formula-shine{position:relative; overflow:hidden}
.formula-shine::after{
  content:""; position:absolute; inset:0;
  background:linear-gradient(105deg, transparent 30%, rgb(255 255 255 / .14) 50%, transparent 70%);
  background-size:380px 100%;
