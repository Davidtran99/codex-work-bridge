<file path="src/lessons/cute-format/CuteSim.tsx">
import { useCallback, useEffect, useRef, useState } from "react";
import { motion } from "framer-motion";
import { Play, StepForward, RotateCcw, Star, StarHalf, Table2 } from "lucide-react";

/** Which auto-running Excel mini-sim a step shows. */
export type SimMode =
  | "equals"
  | "custom"
  | "result"
  | "iconset"
  | "starlive"
  | "borders"
  | "gridlines"
  | "mod"
  | "newemp"
  | "painter";

/* ── data ─────────────────────────────────────────────────────────────── */

interface Emp {
  name: string;
  rev: number;
}

const EMP: Emp[] = [
  { name: "Lan", rev: 168 },
  { name: "Bình", rev: 92 },
  { name: "Cường", rev: 76 },
  { name: "Dung", rev: 145 },
  { name: "Hải", rev: 80 },
];

const NEW_EMP: Emp = { name: "Minh", rev: 150 };

type Star = "full" | "half" | "empty";

function rank(rev: number): { label: string; star: Star; branch: 0 | 1 | 2; tone: string } {
  if (rev >= 150) return { label: "Xuất sắc", star: "full", branch: 0, tone: "excellent" };
  if (rev >= 80) return { label: "Đạt", star: "half", branch: 1, tone: "pass" };
  return { label: "Kém", star: "empty", branch: 2, tone: "weak" };
}

/* ── frame model ──────────────────────────────────────────────────────── */

interface RowState {
  name: string;
  rev: number;
  showEval: boolean; // C shows the raw number (=doanh thu)
  showLabel: boolean; // C shows the text label (custom format)
  showStar: boolean; // D shows a star icon
  stripe: boolean; // zebra fill
  isNew: boolean; // newly added row (soft highlight)
  bordered: boolean; // this row has the hand-drawn border
  hot: "" | "A" | "B" | "C" | "D"; // the amber-pulse target cell in this row
  typing?: string; // value being typed into the hot cell
}

interface Frame {
  rows: RowState[];
  gridlines: boolean;
  border: 0 | 1 | 2; // table border stage
  active: string | null; // Name Box reference, e.g. "C2"
  formula: string; // formula-bar content
  note: string;
  codeBranch: 0 | 1 | 2 | null; // which custom-format branch is matching now
}

const cellRef = (col: "A" | "B" | "C" | "D", rowIdx: number) => `${col}${rowIdx + 2}`;

function baseRows(): RowState[] {
  return EMP.map((e) => ({
    name: e.name,
    rev: e.rev,
    showEval: false,
    showLabel: false,
    showStar: false,
    stripe: false,
    isNew: false,
    bordered: false,
    hot: "",
  }));
}

/* ── per-mode frame builders ──────────────────────────────────────────── */

function build(mode: SimMode, step: number): Frame {
  const rows = baseRows();
  const idle: Frame = {
    rows,
    gridlines: true,
    border: 0,
    active: null,
    formula: "",
    note: "Bấm Chạy để xem thao tác tự chạy trên bảng.",
    codeBranch: null,
  };

  switch (mode) {
    /* Gõ = doanh thu: ô đánh giá lấy đúng số, từng dòng. */
    case "equals": {
      if (step < 0) return { ...idle, note: "Bấm Chạy: ô Đánh giá sẽ trỏ sang ô Doanh thu từng dòng." };
      rows.forEach((r, i) => {
        if (i < step) r.showEval = true;
      });
      const r = rows[step];
      r.showEval = true;
      r.hot = "C";
      return {
        rows,
        gridlines: true,
        border: 0,
        active: cellRef("C", step),
        formula: `=${cellRef("B", step)}`,
        note: `Ô ${cellRef("C", step)} gõ =${cellRef("B", step)} → lấy đúng số ${r.rev} của ${r.name}.`,
        codeBranch: null,
      };
    }

    /* Mã Custom: số → chữ từng dòng, nhánh khớp được tô sáng. */
    case "custom": {
      if (step < 0)
        return { ...idle, note: "Bấm Chạy: mã Custom biến số thành chữ, nhánh nào khớp sẽ sáng lên." };
      rows.forEach((r, i) => {
        r.showEval = true;
        if (i < step) r.showLabel = true;
      });
      const r = rows[step];
      const rk = rank(r.rev);
      r.showLabel = true;
      r.hot = "C";
      const branchTxt = ["[>=150]\"Xuất sắc\"", "[>=80]\"Đạt\"", "\"Kém\""][rk.branch];
      return {
        rows,
        gridlines: true,
        border: 0,
        active: cellRef("C", step),
        formula: String(r.rev),
        note: `Số ${r.rev} khớp nhánh ${branchTxt} → ô ${cellRef("C", step)} hiện "${rk.label}" (số gốc vẫn là ${r.rev}).`,
        codeBranch: rk.branch,
      };
    }

    /* Sửa 76 → 90: Cường nhảy từ Kém sang Đạt. */
    case "result": {
      const CI = 2; // Cường
      rows.forEach((r) => (r.showLabel = true));
      if (step <= 0) {
        rows.forEach((r) => (r.showLabel = true));
        return {
          rows,
          gridlines: true,
          border: 0,
          active: cellRef("B", CI),
          formula: "76",
          note: 'Cường đang 76 → dưới 80 nên ô Đánh giá hiện "Kém".',
          codeBranch: 2,
        };
      }
      if (step === 1) {
        rows[CI].rev = 90;
        rows[CI].hot = "B";
        rows[CI].typing = "90";
        rows[CI].showLabel = false; // mid-edit, label chưa cập nhật
        return {
          rows,
          gridlines: true,
          border: 0,
          active: cellRef("B", CI),
          formula: "90",
          note: "Gõ 90 vào ô Doanh thu của Cường rồi Enter...",
          codeBranch: null,
        };
      }
      rows[CI].rev = 90;
      rows[CI].hot = "C";
      return {
        rows,
        gridlines: true,
        border: 0,
        active: cellRef("C", CI),
        formula: "90",
        note: '90 ≥ 80 → ô tự nhảy từ "Kém" sang "Đạt". Không sửa công thức, chỉ đổi số.',
        codeBranch: 1,
      };
    }

    /* Icon Set: gắn sao xếp hạng từng dòng. */
    case "iconset": {
      if (step < 0)
        return { ...idle, note: "Bấm Chạy: Icon Set gắn sao đầy / nửa / rỗng theo doanh thu." };
      rows.forEach((r, i) => {
        r.showLabel = true;
        if (i < step) r.showStar = true;
      });
      const r = rows[step];
      const rk = rank(r.rev);
      r.showStar = true;
      r.hot = "D";
      const desc = rk.star === "full" ? "sao đầy" : rk.star === "half" ? "nửa sao" : "sao rỗng";
      return {
        rows,
        gridlines: true,
        border: 0,
        active: cellRef("D", step),
        formula: "",
        note: `${r.name} doanh thu ${r.rev} → ${desc} (ngưỡng 150 / 80).`,
        codeBranch: null,
      };
    }

    /* Sửa số → sao đổi theo (Hải 80 → 155). */
    case "starlive": {
      const HI = 4; // Hải
      rows.forEach((r) => {
        r.showLabel = true;
        r.showStar = true;
      });
      if (step <= 0) {
        return {
          rows,
          gridlines: true,
          border: 0,
          active: cellRef("B", HI),
          formula: "80",
          note: "Hải đang 80 → đúng ngưỡng Đạt nên đang là nửa sao.",
          codeBranch: 1,
        };
      }
      if (step === 1) {
        rows[HI].rev = 155;
        rows[HI].hot = "B";
        rows[HI].typing = "155";
        rows[HI].showStar = false;
        rows[HI].showLabel = false;
        return {
          rows,
          gridlines: true,
          border: 0,
          active: cellRef("B", HI),
          formula: "155",
          note: "Gõ 155 vào ô Doanh thu của Hải rồi Enter...",
          codeBranch: null,
        };
      }
      rows[HI].rev = 155;
      rows[HI].hot = "D";
      return {
        rows,
        gridlines: true,
        border: 0,
        active: cellRef("D", HI),
        formula: "155",
        note: "155 ≥ 150 → sao tự đầy và chữ nhảy lên Xuất sắc. Sao đọc lại đúng số mới.",
        codeBranch: 0,
      };
    }

    /* Kẻ viền 3 bước: ngoài → trong → đổi màu. */
    case "borders": {
      rows.forEach((r) => {
        r.showLabel = true;
        r.showStar = true;
      });
      const stage = (step < 0 ? 0 : Math.min(step, 2)) as 0 | 1 | 2;
      const notes = [
        "Chưa kẻ viền: bảng chỉ có lưới xám mặc định.",
        "Format Cells → Border: kẻ khung ngoài (Outline) cho cả vùng.",
        "Kẻ tiếp đường trong (Inside) và đổi màu đường kẻ cho hợp mắt.",
      ];
      return {
        rows,
        gridlines: true,
        border: stage,
        active: null,
        formula: "",
        note: notes[stage],
        codeBranch: null,
      };
    }

    /* Ẩn Gridlines cho nền phẳng. */
    case "gridlines": {
      rows.forEach((r) => {
        r.showLabel = true;
        r.showStar = true;
        r.bordered = true;
      });
      const off = step >= 1;
      return {
        rows,
        gridlines: !off,
        border: 2,
        active: null,
        formula: "",
        note: off
          ? "Bỏ tick Gridlines: lưới xám biến mất, viền tự kẻ và màu nền nổi hẳn lên."
          : "Đang bật Gridlines (lưới xám mặc định). Bấm Bước tiếp để ẩn.",
        codeBranch: null,
      };
    }

    /* MOD(ROW(),2)=0: tô sọc hàng chẵn, hiện ROW()/MOD từng dòng. */
    case "mod": {
      if (step < 0)
        return {
          ...idle,
          note: "Bấm Chạy: quy tắc =MOD(ROW(),2)=0 quét từng hàng, hàng chẵn được tô.",
        };
      rows.forEach((r) => {
        r.showLabel = true;
        r.showStar = true;
      });
      for (let i = 0; i <= step && i < rows.length; i++) {
        const rowNo = i + 2; // hàng bảng tính
        if (rowNo % 2 === 0) rows[i].stripe = true;
      }
      const r = rows[step];
      r.hot = "A";
      const rowNo = step + 2;
      const mod = rowNo % 2;
      return {
        rows,
        gridlines: true,
        border: 0,
        active: cellRef("A", step),
        formula: "=MOD(ROW(),2)=0",
        note: `Hàng ${rowNo}: ROW()=${rowNo}, MOD(${rowNo},2)=${mod} → ${
          mod === 0 ? "= 0 ĐÚNG, tô nền." : "≠ 0, bỏ qua."
        }`,
        codeBranch: null,
      };
    }

    /* Thêm nhân viên mới: định dạng tự lan (trừ viền). */
    case "newemp": {
      rows.forEach((r, i) => {
        r.showLabel = true;
        r.showStar = true;
        r.bordered = true;
        if ((i + 2) % 2 === 0) r.stripe = true;
      });
      if (step <= 0) {
        return {
          rows,
          gridlines: false,
          border: 2,
          active: null,
          formula: "",
          note: "Bảng 5 người đã đẹp. Bấm Bước tiếp để thêm nhân viên mới.",
          codeBranch: null,
        };
      }
      const rk = rank(NEW_EMP.rev);
      const newRow: RowState = {
        name: NEW_EMP.name,
        rev: NEW_EMP.rev,
        showEval: false,
        showLabel: step >= 2,
        showStar: step >= 2,
        stripe: step >= 2 ? (rows.length + 2) % 2 === 0 : false,
        isNew: true,
        bordered: false, // viền chưa lan (không phải quy tắc)
        hot: step === 1 ? "C" : "",
      };
      const all = [...rows, newRow];
      const note =
        step === 1
          ? `Vừa thêm ${NEW_EMP.name} (doanh thu ${NEW_EMP.rev}) — dòng thô, chưa định dạng.`
          : `Custom Format + Icon Set áp cho cả vùng → ${NEW_EMP.name} tự hiện "${rk.label}", sao đầy, sọc nối tiếp. Chỉ viền là chưa lan.`;
      return {
        rows: all,
        gridlines: false,
        border: 2,
        active: step === 1 ? cellRef("C", rows.length) : null,
        formula: step === 1 ? String(NEW_EMP.rev) : "",
        note,
        codeBranch: null,
      };
    }

    /* Format Painter: chép viền sang dòng mới. */
    case "painter": {
      rows.forEach((r, i) => {
        r.showLabel = true;
        r.showStar = true;
        r.bordered = true;
        if ((i + 2) % 2 === 0) r.stripe = true;
      });
      const newRow: RowState = {
        name: NEW_EMP.name,
        rev: NEW_EMP.rev,
        showEval: false,
        showLabel: true,
        showStar: true,
        stripe: (rows.length + 2) % 2 === 0,
        isNew: true,
        bordered: step >= 1,
        hot: "",
      };
      const all = [...rows, newRow];
      return {
        rows: all,
        gridlines: false,
        border: 2,
        active: null,
        formula: "",
        note:
          step >= 1
            ? `Quét Format Painter từ hàng đã đẹp sang ${NEW_EMP.name}: viền, màu, canh lề khớp toàn bảng. Xong.`
            : `Viền của ${NEW_EMP.name} chưa khớp. Chọn hàng đẹp → bấm chổi Format Painter → quét sang.`,
        codeBranch: null,
      };
    }
  }
}

/* ── frame counts + captions ──────────────────────────────────────────── */

const FRAMES: Record<SimMode, number> = {
  equals: EMP.length,
  custom: EMP.length,
  result: 3,
  iconset: EMP.length,
  starlive: 3,
  borders: 3,
  gridlines: 2,
  mod: EMP.length,
  newemp: 3,
  painter: 2,
};

const META: Record<SimMode, [cap: string, play: string, step: string]> = {
  equals: ["Gõ = doanh thu vào ô Đánh giá", "Chạy từng dòng", "Dòng tiếp"],
  custom: ["Mã Custom: số hoá thành chữ", "Chạy mã", "Dòng tiếp"],
  result: ["Sửa số → chữ nhảy hạng", "Chạy sửa số", "Bước tiếp"],
  iconset: ["Icon Set gắn sao xếp hạng", "Gắn sao", "Dòng tiếp"],
  starlive: ["Sửa số → sao đổi theo", "Chạy sửa số", "Bước tiếp"],
  borders: ["Kẻ viền cho bảng", "Kẻ viền", "Bước tiếp"],
  gridlines: ["Ẩn lưới cho nền phẳng", "Ẩn lưới", "Bước tiếp"],
  mod: ["MOD(ROW(),2) tô sọc xen kẽ", "Quét sọc", "Hàng tiếp"],
  newemp: ["Thêm nhân viên, định dạng tự lan", "Thêm người", "Bước tiếp"],
  painter: ["Format Painter chép viền", "Quét chổi", "Bước tiếp"],
};

/* ── auto-play engine (mirrors useSimAnim) ────────────────────────────── */

function useAuto(mode: SimMode) {
  const total = FRAMES[mode];
  const [step, setStep] = useState(-1);
  const [playing, setPlaying] = useState(false);
  const timer = useRef<number | null>(null);

  const clear = useCallback(() => {
    if (timer.current !== null) {
      window.clearTimeout(timer.current);
      timer.current = null;
    }
  }, []);

  useEffect(() => {
    clear();
    setStep(-1);
    setPlaying(false);
    return clear;
  }, [mode, clear]);

  useEffect(() => {
    if (!playing) return;
    if (step >= total - 1) {
      setPlaying(false);
      return;
    }
    timer.current = window.setTimeout(() => setStep((s) => s + 1), 900);
    return clear;
  }, [playing, step, total, clear]);

  const play = useCallback(() => {
    setStep((s) => (s >= total - 1 ? -1 : s));
    setPlaying(true);
  }, [total]);
  const stepForward = useCallback(() => {
    clear();
    setPlaying(false);
    setStep((s) => Math.min(s + 1, total - 1));
  }, [total, clear]);
  const reset = useCallback(() => {
    clear();
    setPlaying(false);
    setStep(-1);
  }, [clear]);

  return { step, playing, play, stepForward, reset };
}

/* ── small pieces ─────────────────────────────────────────────────────── */

function StarIcon({ kind }: { kind: Star }) {
  const color =
    kind === "full" ? "text-amber-500" : kind === "half" ? "text-amber-400" : "text-gray-300";
  if (kind === "half")
    return (
      <span className={"inline-flex " + color} aria-label="nửa sao">
        <StarHalf size={16} strokeWidth={2} fill="currentColor" />
      </span>
    );
  return (
    <span className={"inline-flex " + color} aria-label={kind === "full" ? "sao đầy" : "sao rỗng"}>
      <Star size={16} strokeWidth={2} fill={kind === "full" ? "currentColor" : "none"} />
    </span>
  );
}

/** The Custom-format code, with the currently-matching branch lit up. */
function FormatCode({ branch }: { branch: 0 | 1 | 2 | null }) {
  const parts: [text: string, b: 0 | 1 | 2][] = [
    ['[>=150]"Xuất sắc"', 0],
    ['[>=80]"Đạt"', 1],
    ['"Kém"', 2],
  ];
  return (
    <div className="mt-2 flex flex-wrap items-center gap-1 rounded-lg bg-[#1e2536] px-2.5 py-1.5 font-mono text-[11.5px] text-[#c8d2ec]">
      {parts.map(([txt, b], i) => (
        <span key={b} className="inline-flex items-center">
          <span
            className={
              "rounded px-1 py-0.5 transition-colors " +
              (branch === b ? "bg-amber-400 font-bold text-[#1e2536]" : "text-[#9aa6c4]")
            }
          >
            {txt}
          </span>
          {i < parts.length - 1 && <span className="px-0.5 text-[#5e6a88]">;</span>}
        </span>
      ))}
    </div>
  );
}

/* ── main component ───────────────────────────────────────────────────── */

const labelTone = (tone: string) =>
  tone === "excellent"
    ? "text-green-700 font-black"
    : tone === "pass"
      ? "text-amber-700 font-bold"
      : "text-red-600 font-bold";

export default function CuteSim({
  mode,
  focusCol = null,
}: {
  mode: SimMode;
  focusCol?: "A" | "B" | "C" | "D" | null;
}) {
  const { step, playing, play, stepForward, reset } = useAuto(mode);
  const f = build(mode, step);
  const [cap, playLabel, stepLabel] = META[mode];
  const showCode = mode === "custom" || mode === "result";

  // border classes for the whole grid body
  const gridBorder =
    f.border === 0
      ? "border border-transparent"
      : f.border === 1
        ? "border-2 border-[#b9c2d6]"
        : "border-2 border-[rgb(var(--violet))]";

  return (
    <div className="rounded-2xl border border-line bg-gradient-to-b from-[#fbfcff] to-[#f5f8fd] p-4 shadow-[inset_0_1px_0_#fff]">
      <div className="mb-2.5 flex items-center gap-1.5 text-[12.5px] font-extrabold text-soft">
        <Table2 size={15} strokeWidth={2.4} className="text-[rgb(var(--violet-tx))]" /> {cap}
      </div>

      {/* Excel formula bar: Name Box • fx • content */}
      <div className="mb-2 flex items-stretch overflow-hidden rounded-md border border-[#c9d2e6] text-[12px]">
        <div className="flex min-w-[52px] items-center justify-center border-r border-[#c9d2e6] bg-[#f1f4fb] px-2 font-mono font-bold text-ink">
          {f.active ?? "—"}
