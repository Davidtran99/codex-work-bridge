import { useState } from "react";
import { AnimatePresence, motion } from "framer-motion";
import { FileText, Inbox, Database, BookOpen, Boxes, ListTree, ScrollText, Brain } from "lucide-react";
import type { LucideIcon } from "lucide-react";

interface Node {
  key: string;
  label: string;
  Icon: LucideIcon;
  depth: number;
  kind: "folder" | "file";
  desc: string;
}

/** Cây thư mục LLM Wiki mà Claude sinh ra — bấm từng mục để hiểu vai trò. */
const TREE: Node[] = [
  { key: "inbox", label: "inbox/", Icon: Inbox, depth: 0, kind: "folder",
    desc: "Hộp thư đến. Bạn quăng tài liệu thô vào đây (PDF, link web, ghi chú, transcript). Đây là cửa duy nhất để nạp kiến thức mới vào hệ thống." },
  { key: "raw", label: "raw/", Icon: Database, depth: 0, kind: "folder",
    desc: "Bản ghi BẤT BIẾN. Sau khi đọc inbox, Claude tổng hợp thành một file gốc và cất ở đây, không sửa về sau — để luôn truy vết được nguồn." },
  { key: "wiki", label: "wiki/", Icon: BookOpen, depth: 0, kind: "folder",
    desc: "Tầng tri thức đã tinh chế, tham chiếu ngược về raw/. Gồm ba loại note dưới đây." },
  { key: "concept", label: "concept/", Icon: Boxes, depth: 1, kind: "folder",
    desc: "Khái niệm — định nghĩa các ý niệm trừu tượng (vd: 'AI coding agent', 'Model Context Protocol'). Đây là các nút lớn trong graph." },
  { key: "entity", label: "entity/", Icon: ListTree, depth: 1, kind: "folder",
    desc: "Thực thể — từng đối tượng cụ thể (vd: Claude Code, Cursor, Gemini, GitHub Copilot). Mỗi thực thể là một note riêng." },
  { key: "summary", label: "summary/", Icon: FileText, depth: 1, kind: "folder",
    desc: "Bản tổng hợp gọn cho từng nguồn — đọc nhanh không cần mở raw." },
  { key: "claude", label: "CLAUDE.md", Icon: Brain, depth: 0, kind: "file",
    desc: "Bộ nhớ + luật chơi của agent. Claude đọc file này mỗi lần chạy để biết cách phân loại, đặt tên, liên kết note đúng chuẩn của bạn." },
  { key: "index", label: "INDEX.md", Icon: ListTree, depth: 0, kind: "file",
    desc: "Mục lục toàn hệ thống — điểm vào để Claude (và bạn) định vị mọi note." },
  { key: "log", label: "log.md", Icon: ScrollText, depth: 0, kind: "file",
    desc: "Nhật ký mọi thay đổi: tạo schema, ingest tài liệu, dọn link. Không mất dấu việc gì đã xảy ra." },
];

export default function StructureDemo() {
  const [sel, setSel] = useState("inbox");
  const cur = TREE.find((n) => n.key === sel)!;
  return (
    <section className="card-frost rounded-2xl p-4">
      <p className="mb-3 text-[12.5px] font-extrabold uppercase tracking-wide text-indigo-tx">
