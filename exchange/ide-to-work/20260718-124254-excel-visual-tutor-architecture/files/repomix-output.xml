import { useState } from "react";
import { AnimatePresence, motion } from "framer-motion";
import {
  Terminal, FileCode, MessageSquare, Sparkles, StickyNote,
  Copy, Check, ChevronDown, ArrowRight, type LucideIcon,
} from "lucide-react";
import type { Example } from "./steps";

const META: Record<Example["kind"], { Icon: LucideIcon; hue: string; ring: string; chipText: string }> = {
  prompt: { Icon: Sparkles,       hue: "from-violet/15 to-violet/5", ring: "border-violet/30",  chipText: "text-violet-tx" },
  file:   { Icon: FileCode,       hue: "from-indigo/15 to-indigo/5", ring: "border-indigo/30",  chipText: "text-indigo-tx" },
  chat:   { Icon: MessageSquare,  hue: "from-teal/15 to-teal/5",     ring: "border-teal/30",    chipText: "text-teal-d" },
  shell:  { Icon: Terminal,       hue: "from-ink/12 to-ink/4",       ring: "border-ink/25",     chipText: "text-ink" },
  note:   { Icon: StickyNote,     hue: "from-honey/18 to-honey/5",   ring: "border-honey/40",   chipText: "text-[#8a5a00]" },
};

function CodeCard({ ex }: { ex: Example }) {
  const [copied, setCopied] = useState(false);
  const meta = META[ex.kind];
  const Icon = meta.Icon;

  const copy = async () => {
    try {
      await navigator.clipboard.writeText(ex.body);
      setCopied(true);
      setTimeout(() => setCopied(false), 1600);
    } catch { /* clipboard blocked — bỏ qua */ }
  };

  return (
    <div className={`overflow-hidden rounded-xl border bg-white ${meta.ring}`}>
      <div className={`flex items-center gap-2 border-b ${meta.ring} bg-gradient-to-r ${meta.hue} px-3 py-2`}>
        <span className={`grid h-6 w-6 shrink-0 place-items-center rounded-md bg-white/70 ${meta.chipText}`}>
          <Icon size={14} strokeWidth={2.6} />
        </span>
        <span className={`text-[11px] font-black uppercase tracking-[0.12em] ${meta.chipText}`}>{ex.label}</span>
        {ex.filename && (
          <code className="ml-auto max-w-[52%] truncate rounded bg-white/70 px-2 py-0.5 font-mono text-[11px] font-bold text-soft" title={ex.filename}>
            {ex.filename}
          </code>
        )}
        <button
          type="button"
          onClick={copy}
          className={`inline-flex items-center gap-1 rounded-md border px-2 py-1 text-[11px] font-extrabold transition ${meta.ring} bg-white/80 ${meta.chipText} hover:bg-white ${ex.filename ? "" : "ml-auto"}`}
          aria-label="Sao chép nội dung ví dụ"
        >
          {copied ? <Check size={12} strokeWidth={3} /> : <Copy size={12} strokeWidth={2.6} />}
          {copied ? "Đã chép" : "Chép"}
        </button>
      </div>

      <pre className="max-h-[420px] overflow-auto bg-[#0f1220] px-4 py-3.5 text-[12.5px] leading-[1.65] text-[#e6e8f5]">
        <code className="font-mono whitespace-pre">{ex.body}</code>
      </pre>

      {ex.takeaways && ex.takeaways.length > 0 && (
        <ul className="space-y-1.5 border-t border-line bg-[#fbfcff] px-4 py-3">
          {ex.takeaways.map((t, i) => (
            <li key={i} className="flex items-start gap-2 text-[13px] leading-relaxed text-[#39445a]">
              <ArrowRight size={14} strokeWidth={2.8} className={`mt-0.5 shrink-0 ${meta.chipText}`} />
              <span>{t}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  );
}

/** Khối "Ví dụ thực tế" — mở/đóng, hiển thị 1..n ví dụ (prompt/file/chat/shell/note). */
export default function ExampleBlock({ examples }: { examples: Example[] }) {
  const [open, setOpen] = useState(true);
  if (!examples || examples.length === 0) return null;

  return (
    <section className="rounded-2xl border border-indigo/20 bg-gradient-to-b from-indigo-sk/40 to-white p-3.5">
      <button
        type="button"
        onClick={() => setOpen((v) => !v)}
        className="flex w-full items-center gap-2 text-left"
        aria-expanded={open}
      >
        <span className="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-indigo text-white shadow-soft">
          <FileCode size={17} strokeWidth={2.5} />
        </span>
        <span className="flex flex-col">
          <span className="text-[12.5px] font-black uppercase tracking-wide text-indigo-tx">Ví dụ thực tế</span>
          <span className="text-[12px] font-semibold text-soft">
            {examples.length > 1 ? `${examples.length} ví dụ có thể copy dùng ngay` : "Ví dụ có thể copy dùng ngay"}
          </span>
        </span>
        <ChevronDown size={18} strokeWidth={2.8} className={"ml-auto shrink-0 text-indigo-tx transition-transform " + (open ? "rotate-180" : "")} />
      </button>

      <AnimatePresence initial={false}>
        {open && (
          <motion.div
            initial={{ opacity: 0, height: 0 }}
            animate={{ opacity: 1, height: "auto" }}
            exit={{ opacity: 0, height: 0 }}
            transition={{ duration: 0.28, ease: [0.2, 0.7, 0.2, 1] }}
            className="overflow-hidden"
          >
            <div className="mt-3 grid gap-3">
              {examples.map((ex, i) => (
                <CodeCard key={i} ex={ex} />
              ))}
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </section>
  );
}
</file>

