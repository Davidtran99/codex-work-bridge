                    (on
                      ? "bg-indigo text-white shadow-soft"
                      : n.kind === "folder"
                      ? "text-ink hover:bg-indigo/10"
                      : "text-soft hover:bg-indigo/10")
                  }
                >
                  <Icon size={15} strokeWidth={2.4} className="shrink-0" />
                  <span className="font-mono">{n.label}</span>
                </button>
              </li>
            );
