<file path="src/lessons/peter-principle/SignalsDemo.tsx">
import { useMemo, useState } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { CheckCircle2, AlertTriangle, XCircle } from "lucide-react";
import { Compass } from "@phosphor-icons/react";

/**
 * Sân chơi 2 — 3 dấu hiệu tự chẩn.
 * User chọn câu trả lời cho 3 câu. Điểm 0..3 → verdict + note ngôn từ của video.
 */
type Choice = "a" | "b";

interface Q {
  id: string;
  question: string;
  a: string; // đáp án "đang ở đỉnh"
  b: string; // đáp án "có thể đã qua đỉnh"
}

const QUESTIONS: Q[] = [
  {
    id: "energy",
    question: "Cuối ngày làm việc, bạn cảm thấy…",
    a: "…giờ trôi nhanh, khó khăn thú vị, vẫn còn năng lượng.",
    b: "…như đang chạy trên máy chạy bộ không có nút dừng.",
  },
  {
    id: "skill",
    question: "Kỹ năng bạn dùng nhiều nhất ở vị trí này…",
    a: "…là thứ bạn tự hào và thích rèn luyện thêm.",
    b: "…là thứ bạn đang cố học để không lộ ra rằng mình chưa giỏi.",
  },
  {
    id: "expert",
    question: "Khi team có vấn đề khó, thường thấy bạn…",
    a: "…là người mà đồng nghiệp tìm đến để hỏi.",
    b: "…đang là người phải đi tìm câu trả lời từ người khác.",
  },
];

export default function SignalsDemo() {
  const [ans, setAns] = useState<Record<string, Choice | null>>({
    energy: null,
    skill: null,
    expert: null,
  });

  const answered = Object.values(ans).filter(Boolean).length;
  const bCount = Object.values(ans).filter((v) => v === "b").length;
  const done = answered === QUESTIONS.length;

  const verdict = useMemo(() => {
    if (!done) return null;
    if (bCount === 0) {
      return {
        tone: "peak" as const,
        Icon: CheckCircle2,
        color: "#0da798",
        title: "Có vẻ bạn đang ở đúng đỉnh",
        note: "Ba dấu hiệu đều nghiêng về vùng năng lượng. Trước khi ký thăng chức, hãy hỏi: vị trí mới có giữ được cả ba dấu hiệu này không?",
      };
    }
    if (bCount === 1) {
      return {
        tone: "yellow" as const,
        Icon: AlertTriangle,
        color: "#e08a20",
        title: "Đang ở đỉnh, nhưng có một tín hiệu cảnh báo",
        note: "Không phải là qua đỉnh. Nhưng có một chỗ đang bào mòn bạn. Ghi lại chỗ đó, tuần này để ý xem nó là tạm thời hay đã kéo dài.",
      };
    }
    if (bCount === 2) {
      return {
        tone: "warn" as const,
        Icon: AlertTriangle,
        color: "#e08a20",
        title: "Đây có thể là dấu hiệu bạn đã qua đỉnh",
        note: "Hai trên ba dấu hiệu đã ngả sang phía kiệt sức. Đừng vội ký thêm nấc thang. Ngồi xuống liệt kê việc thực tế của vị trí mới xem bao nhiêu phần trăm là thứ bạn hứng khởi khi nghĩ đến.",
      };
    }
    return {
      tone: "past" as const,
      Icon: XCircle,
      color: "#e5484d",
      title: "Ba dấu hiệu đều nghiêng: rất có thể đã qua đỉnh",
      note: "Đây không phải kết luận, đây là thông tin. Nếu vị trí mới lại cùng dạng công việc thì cái bẫy sẽ khép sâu hơn. Đọc tiếp phần 'Nghệ thuật từ chối' — có ba cách bảo vệ vừa quan hệ vừa sự nghiệp.",
    };
  }, [done, bCount]);

  return (
    <div className="mt-4 rounded-2xl border border-line bg-white/80 p-4 shadow-soft">
      <div className="mb-3 flex items-center gap-2">
        <Compass size={17} weight="duotone" className="text-violet-tx" />
        <span className="text-[12.5px] font-black uppercase tracking-wider text-violet-tx">
          Ba dấu hiệu · tự chẩn 30 giây
        </span>
      </div>

      <ol className="space-y-3">
        {QUESTIONS.map((q, i) => {
          const cur = ans[q.id];
          return (
            <li key={q.id} className="rounded-xl border border-line bg-white/60 p-3">
              <div className="mb-2 text-[13.5px] font-extrabold text-ink">
                {i + 1}. {q.question}
              </div>
              <div className="grid gap-2 sm:grid-cols-2">
                {(["a", "b"] as Choice[]).map((c) => {
                  const on = cur === c;
                  const text = c === "a" ? q.a : q.b;
                  return (
                    <button
                      key={c}
                      onClick={() => setAns((s) => ({ ...s, [q.id]: c }))}
                      className={
                        "rounded-lg border px-3 py-2 text-left text-[13px] leading-relaxed transition " +
                        (on
                          ? c === "a"
                            ? "border-teal bg-teal-sk font-bold text-teal-d"
                            : "border-rose bg-[rgb(var(--red-sk))] font-bold text-[rgb(var(--red))]"
                          : "border-line bg-white text-[#39445a] hover:border-violet hover:text-violet-tx")
                      }
                    >
                      {text}
                    </button>
                  );
                })}
              </div>
            </li>
          );
        })}
      </ol>

      <AnimatePresence mode="wait">
        {verdict && (
          <motion.div
            key={verdict.title}
            initial={{ opacity: 0, y: 8 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -6 }}
            transition={{ duration: 0.28 }}
            className="mt-3 flex items-start gap-3 rounded-xl border p-3.5"
            style={{ borderColor: verdict.color + "55", background: verdict.color + "12" }}
          >
            <verdict.Icon size={18} strokeWidth={2.4} style={{ color: verdict.color }} className="mt-0.5 shrink-0" />
            <div>
              <div className="text-[13.5px] font-black tracking-tight" style={{ color: verdict.color }}>
                {verdict.title}
              </div>
              <div className="mt-0.5 text-[13px] leading-relaxed text-[#39445a]">{verdict.note}</div>
            </div>
          </motion.div>
        )}
      </AnimatePresence>

      {!done && (
        <div className="mt-3 text-[12px] font-bold text-soft">
          Đã trả lời {answered}/{QUESTIONS.length}
        </div>
      )}
    </div>
  );
}
</file>

