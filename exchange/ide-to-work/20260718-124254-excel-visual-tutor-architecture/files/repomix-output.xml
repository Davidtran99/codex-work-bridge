import { useState } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { Microscope } from "lucide-react";
import type { CuteStep, CuteTiers } from "./steps";
import { FormulaFlow } from "../../lib/formulaFlow";

/* ── 3-depth explanation tabs (Dễ hiểu / Kỹ thuật / Chuyên sâu) ────────── */

const TABS: { key: keyof CuteTiers; label: string }[] = [
  { key: "easy", label: "Dễ hiểu" },
  { key: "tech", label: "Kỹ thuật" },
  { key: "deep", label: "Chuyên sâu" },
];

export function CuteTiersPanel({ tiers }: { tiers: CuteTiers }) {
  const [active, setActive] = useState<keyof CuteTiers>("easy");
  return (
    <section className="rounded-2xl border border-line bg-white/70 p-4 shadow-soft">
      <div className="mb-3 flex gap-1.5">
        {TABS.map((t) => (
          <button
            key={t.key}
            onClick={() => setActive(t.key)}
            className={
              "flex-1 rounded-lg border px-2 py-1.5 text-[12.5px] font-extrabold transition " +
              (active === t.key
                ? "border-[rgb(var(--violet))] bg-[rgb(var(--violet))] text-white"
                : "border-line bg-white text-soft hover:border-[rgb(var(--violet))] hover:text-[rgb(var(--violet-tx))]")
            }
          >
            {t.label}
          </button>
        ))}
      </div>
      <AnimatePresence mode="wait">
        <motion.div
          key={active}
          initial={{ opacity: 0, y: 8 }}
          animate={{ opacity: 1, y: 0 }}
          exit={{ opacity: 0, y: -6 }}
          transition={{ duration: 0.22 }}
          className="min-h-[96px] rounded-xl border border-line bg-[#fbfcff] p-3.5 text-[14px] leading-relaxed text-[#39445a]"
        >
          {tiers[active]}
        </motion.div>
      </AnimatePresence>
    </section>
  );
}

/* ── formula microscope: hover a token/chip → light up a grid column ───── */

interface MicroProps {
  step: CuteStep;
  focusCol: "A" | "B" | "C" | "D" | null;
  setFocusCol: (c: "A" | "B" | "C" | "D" | null) => void;
}

export function CuteMicroscope({ step, focusCol: _focusCol, setFocusCol }: MicroProps) {
  const [hl, setHl] = useState<number | null>(null);
  if (!step.micro || !step.formula) return null;
  const chips = step.micro;

  const focus = (g: number | null) => {
    setHl(g);
    setFocusCol(g == null ? null : chips[g]?.[3] ?? null);
  };

  return (
    <section className="rounded-2xl border border-line bg-white/70 p-4 shadow-soft">
      <h4 className="mb-1 flex items-center gap-1.5 text-[13px] font-extrabold uppercase tracking-wide text-soft">
        <Microscope size={15} strokeWidth={2.4} className="text-[rgb(var(--violet-tx))]" /> Kính hiển vi công thức
      </h4>
      <p className="mb-3 text-[11.5px] font-semibold text-soft/80">
        Công thức tự sáng theo đúng thứ tự đọc. Di chuột vào từng mảnh bên dưới để soi cột tương ứng.
      </p>

      <div className="mb-3 overflow-x-auto rounded-xl bg-[#0f1b33] px-4 py-3 text-[14px]">
        <FormulaFlow formula={step.formula} steps={step.readingSteps} onDark />
      </div>

      <div className="flex flex-col gap-2">
        {chips.map((c, i) => (
          <div
            key={i}
            onMouseEnter={() => focus(i)}
            onMouseLeave={() => focus(null)}
            onClick={() => focus(i)}
            style={{ animationDelay: i * 70 + "ms" }}
            className={
              "pop-3d chip-3d flex cursor-pointer items-start gap-2.5 rounded-lg px-2 py-1.5 text-[13.5px] " +
              (hl === i ? "translate-x-0.5 bg-[#f4f2fc]" : "hover:bg-[#f7f6fd]")
            }
          >
            <span
              className="shrink-0 rounded-md px-2 py-0.5 font-mono text-[12px] font-extrabold text-white"
              style={{ background: c[2] }}
            >
              {c[0]}
            </span>
            <span className="pt-0.5 leading-relaxed text-[#39445a]">{c[1]}</span>
          </div>
        ))}
      </div>
    </section>
  );
}
