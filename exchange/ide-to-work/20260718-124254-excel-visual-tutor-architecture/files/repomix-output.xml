      <div className="grid gap-4 sm:grid-cols-[minmax(0,220px)_1fr]">
        <ul className="flex flex-col gap-0.5 rounded-xl border border-line bg-[#fbfcff] p-2">
          {TREE.map((n) => {
            const on = n.key === sel;
            const Icon = n.Icon;
            return (
              <li key={n.key} style={{ paddingLeft: n.depth * 16 }}>
