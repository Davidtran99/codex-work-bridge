                      {col} · {["Nhân viên", "Doanh thu", "Đánh giá", "Sao"][i]}
                    </th>
                  );
                })}
              </tr>
            </thead>
            <tbody>
              {f.rows.map((r, i) => {
                const rowNo = i + 2;
                const rk = rank(r.rev);
                const stripeCls = r.stripe ? "bg-[rgb(var(--violet)/0.08)]" : "bg-white";
                const newCls = r.isNew ? " ring-1 ring-inset ring-[rgb(var(--violet)/0.5)]" : "";
                const gl = f.gridlines ? "border-[#e6ebf5]" : "border-transparent";
                const bord = r.bordered ? " !border-[rgb(var(--violet)/0.55)]" : "";
                const hot = (col: string) =>
                  r.hot === col
                    ? " outline outline-2 -outline-offset-2 outline-amber-400 bg-amber-100/70"
                    : "";
                const foc = (col: string) =>
                  focusCol === col ? " bg-teal-sk/70 ring-1 ring-inset ring-teal/40" : "";
                const cellBase = `border-b border-r ${gl} px-2.5 py-1.5${bord}`;
                return (
                  <tr key={i} className={stripeCls + newCls}>
                    {/* row number gutter */}
                    <td className="h-[30px] w-[26px] min-w-[26px] border-b border-r border-[#dfe5f1] bg-[#eef2fa] text-center text-[10.5px] font-extrabold text-[#9aa6c4]">
                      {rowNo}
                    </td>
                    {/* A: name */}
                    <td className={cellBase + " font-bold text-ink" + hot("A") + foc("A")}>{r.name}</td>
                    {/* B: revenue */}
                    <td className={cellBase + " font-mono font-bold text-ink" + hot("B") + foc("B")}>
                      {r.typing != null ? (
                        <motion.span
                          key={r.typing}
                          initial={{ opacity: 0.4 }}
                          animate={{ opacity: 1 }}
                          className="inline-flex items-center"
                        >
                          {r.typing}
                          <span className="ml-0.5 inline-block h-[13px] w-[1.5px] animate-pulse bg-ink" />
                        </motion.span>
                      ) : (
                        r.rev
                      )}
                    </td>
                    {/* C: evaluation */}
                    <td className={cellBase + hot("C") + foc("C")}>
                      {r.showLabel ? (
                        <motion.span
                          key={rk.label}
                          initial={{ opacity: 0, y: -4 }}
                          animate={{ opacity: 1, y: 0 }}
                          transition={{ duration: 0.2 }}
                          className={labelTone(rk.tone)}
                        >
                          {rk.label}
                        </motion.span>
                      ) : r.showEval ? (
                        <motion.span
                          key={"e" + r.rev}
                          initial={{ opacity: 0 }}
                          animate={{ opacity: 1 }}
                          className="font-mono font-bold text-ink"
                        >
                          {r.rev}
                        </motion.span>
                      ) : (
                        <span className="text-[#c4cadb]">—</span>
                      )}
                    </td>
                    {/* D: star */}
                    <td className={cellBase + " text-center" + hot("D") + foc("D")}>
                      {r.showStar ? (
                        <motion.span
                          key={rk.star}
