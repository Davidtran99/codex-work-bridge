import { useState } from "react";
import { Table2, HelpCircle } from "lucide-react";
import { motion, AnimatePresence } from "framer-motion";
import {
  Database, Layers, MousePointerClick, Sigma, LayoutList, SlidersHorizontal, Globe2,
} from "lucide-react";
import LessonScaffold from "../../components/LessonScaffold";
import PivotPlayground from "./PivotPlayground";
import { PIVOT_SCENES, PIVOT_MIND, type PivotScene } from "./scenes";

const NODE_ICONS = [Database, Layers, MousePointerClick, Sigma, LayoutList, SlidersHorizontal, Globe2];
const SCENE_ICONS = [Table2, Database, MousePointerClick, Sigma, LayoutList, SlidersHorizontal, Globe2];

function TierTabs({ tiers }: { tiers: PivotScene["tiers"] }) {
  const [t, setT] = useState<keyof PivotScene["tiers"]>("easy");
  const tabs: { k: keyof PivotScene["tiers"]; label: string }[] = [
    { k: "easy", label: "Dễ hiểu" },
    { k: "tech", label: "Kỹ thuật" },
    { k: "deep", label: "Chuyên sâu" },
  ];
  return (
    <section className="rounded-2xl border border-line bg-white/70 p-4 shadow-soft">
      <div className="mb-3 flex gap-1.5">
        {tabs.map((x) => (
          <button
            key={x.k}
            onClick={() => setT(x.k)}
            className={
              "flex-1 rounded-lg border px-2 py-1.5 text-[12.5px] font-extrabold transition " +
              (t === x.k
                ? "border-teal bg-teal text-white"
                : "border-line bg-white text-soft hover:border-teal hover:text-teal-d")
            }
          >
            {x.label}
          </button>
        ))}
      </div>
      <AnimatePresence mode="wait">
        <motion.div
          key={t}
          initial={{ opacity: 0, y: 8 }}
          animate={{ opacity: 1, y: 0 }}
          exit={{ opacity: 0, y: -6 }}
          transition={{ duration: 0.22 }}
          className="min-h-[80px] rounded-xl border border-line bg-[#fbfcff] p-3.5 text-[14.5px] text-[#39445a]"
        >
          {tiers[t]}
        </motion.div>
      </AnimatePresence>
    </section>
  );
}

function WhyList({ items }: { items: NonNullable<PivotScene["why"]> }) {
  const [open, setOpen] = useState<number | null>(0);
  return (
    <section className="rounded-2xl border border-line bg-white/70 p-4 shadow-soft">
      <h4 className="mb-3 flex items-center gap-1.5 text-[13px] font-extrabold uppercase tracking-wide text-soft">
        <HelpCircle size={14} strokeWidth={2.4} /> Vì sao?
      </h4>
      <div className="flex flex-col gap-2">
        {items.map(([q, a], i) => {
          const isOpen = open === i;
          return (
            <div key={i} className="overflow-hidden rounded-xl border border-line">
              <button
                onClick={() => setOpen(isOpen ? null : i)}
                aria-expanded={isOpen}
                className="flex w-full items-center justify-between gap-3 bg-[#fbfcff] px-3.5 py-2.5 text-left text-[14px] font-extrabold text-ink"
              >
                {q}
                <span className={"shrink-0 text-teal-d transition-transform " + (isOpen ? "rotate-45" : "")}>+</span>
              </button>
              <AnimatePresence initial={false}>
                {isOpen && (
                  <motion.div
                    initial={{ height: 0, opacity: 0 }}
                    animate={{ height: "auto", opacity: 1 }}
                    exit={{ height: 0, opacity: 0 }}
                    transition={{ duration: 0.24 }}
                  >
                    <p className="px-3.5 py-3 text-[14px] text-[#39445a]">{a}</p>
                  </motion.div>
                )}
              </AnimatePresence>
            </div>
          );
        })}
      </div>
    </section>
  );
}

function PivotScene({ scene }: { scene: PivotScene }) {
  const Icon = SCENE_ICONS[scene.node] ?? Table2;
  return (
    <div>
      <div className="mb-1 flex items-center gap-4">
        <div className="grid h-[58px] w-[58px] shrink-0 place-items-center rounded-2xl bg-gradient-to-br from-teal-sk to-[#e9fbf8] text-teal-d shadow-soft ring-1 ring-inset ring-teal/15">
          <Icon size={28} strokeWidth={2} aria-hidden="true" />
        </div>
        <div>
          <span className="inline-block rounded-full bg-teal-sk px-2.5 py-0.5 text-[11.5px] font-extrabold uppercase tracking-wide text-teal-d">
            {scene.tag}
          </span>
          <h2 className="mt-1.5 text-[clamp(20px,2.7vw,27px)] font-black leading-tight tracking-tight text-ink">
            {scene.title}
          </h2>
        </div>
      </div>

      <p
        className="mb-1 mt-4 max-w-none text-[clamp(15px,1.5vw,16.5px)] text-[#333c54] [&_b]:text-ink [&_code]:rounded [&_code]:bg-[#eef1f8] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-[.86em]"
        dangerouslySetInnerHTML={{ __html: scene.story }}
      />

      {scene.task && (
        <div className="mt-3 rounded-xl border border-teal/25 bg-teal-sk/40 px-3.5 py-2.5 text-[13.5px] font-semibold text-teal-d">
          {scene.task}
        </div>
      )}

      <div className="mt-5 grid gap-6 lg:grid-cols-[1.15fr_.85fr]">
        <div className="min-w-0">
          <PivotPlayground key={scene.id} preset={scene.preset} />
        </div>
        <div className="flex min-w-0 flex-col gap-4">
          <TierTabs tiers={scene.tiers} />
          {scene.why && <WhyList items={scene.why} />}
        </div>
      </div>
    </div>
  );
}

export default function PivotLesson() {
  const scenes = PIVOT_SCENES.map((s) => ({ id: s.id, tag: s.tag, node: s.node }));
  const sceneIcons = PIVOT_SCENES.map((s) => SCENE_ICONS[s.node]);
  const mindNodes = PIVOT_MIND.map((label, i) => ({ Icon: NODE_ICONS[i] ?? Database, label }));

  const head = (
    <header className="relative px-1 pb-1 pt-2 text-center">
      <span className="inline-flex items-center gap-2 rounded-full bg-gradient-to-br from-teal-sk to-[#e9fbf8] px-4 py-2 text-[12.5px] font-black uppercase tracking-wider text-teal-d shadow-soft">
        <Table2 size={15} strokeWidth={2.6} /> Pivot Table
      </span>
      <h1 className="mx-auto mt-3 max-w-3xl bg-gradient-to-r from-ink via-ink to-teal-d bg-clip-text text-[clamp(24px,3.6vw,38px)] font-black leading-tight tracking-tight text-transparent">
        Thành thạo Pivot Table
      </h1>
      <p className="mx-auto mt-1.5 max-w-2xl text-[clamp(14px,1.8vw,16px)] text-soft">
        Báo cáo 4.994 dòng dữ liệu bằng cách kéo thả, không cần một công thức nào.
      </p>
    </header>
  );

  return (
    <LessonScaffold
      scenes={scenes}
      sceneIcons={sceneIcons}
      mindNodes={mindNodes}
      renderScene={(i) => <PivotScene scene={PIVOT_SCENES[i]} />}
      head={head}
    />
  );
}
