<file path="src/lib/excel.ts">
import type { Row } from "../data/types";

/** Running COUNTIF: how many times SRC[i] code has appeared up to and including row i. */
export function sttOf(src: Row[], i: number): number {
  let c = 0;
  for (let k = 0; k <= i; k++) if (src[k][0] === src[i][0]) c++;
  return c;
}

/** Composite key = code & runningCount, e.g. "L1A" & 2 -> "L1A2". */
export function keyOf(src: Row[], i: number): string {
  return src[i][0] + sttOf(src, i);
}

/** VLOOKUP by composite key: find value for code appearing at n-th occurrence. */
export function lookupKey(src: Row[], code: string, n: number): number | null {
  for (let i = 0; i < src.length; i++) {
    if (keyOf(src, i) === code + n) return src[i][1];
  }
  return null;
}

/** Max columns in the result matrix (1..MAXN). */
export const MAXN = 3;

/** Rows in the source start at excel row 2 (row 1 is the header). */
export const ROW0 = 2;
