import { useEffect, useRef, useState } from "react";
import { motion } from "framer-motion";
import { ChevronDown } from "lucide-react";
import { Lightbulb as LightbulbGlow } from "@phosphor-icons/react";
import type { PeterStep } from "./steps";
import TiersPanel from "./TiersPanel";
import CurveDemo from "./CurveDemo";
import SignalsDemo from "./SignalsDemo";
import ScriptDemo from "./ScriptDemo";
import RadialGauge from "./RadialGauge";

/** RichText — quét sáng dần các cụm nhấn mạnh (<b>, <code>) như bài cute-format. */
function RichText({ html, className }: { html: string; className?: string }) {
  const ref = useRef<HTMLParagraphElement | null>(null);
  useEffect(() => {
    const root = ref.current;
    if (!root) return;
    if (
      typeof window !== "undefined" &&
      window.matchMedia?.("(prefers-reduced-motion: reduce)").matches
    ) {
      return;
    }
    const marks = Array.from(root.querySelectorAll("b, strong, code")) as HTMLElement[];
    if (marks.length < 2) return;
    const delay = marks.length <= 6 ? 0.7 : marks.length <= 12 ? 0.55 : 0.45;
    const cycle = Math.max(5, marks.length * delay + 2.2);
    marks.forEach((el, i) => {
      el.classList.add("ff-read");
      el.style.setProperty("--ff-cycle", cycle.toFixed(2) + "s");
      el.style.setProperty("--ff-read-delay", (i * delay).toFixed(2) + "s");
    });
    return () => {
      marks.forEach((el) => {
        el.classList.remove("ff-read");
        el.style.removeProperty("--ff-cycle");
        el.style.removeProperty("--ff-read-delay");
      });
    };
  }, [html]);
  return <p ref={ref} className={className} dangerouslySetInnerHTML={{ __html: html }} />;
}

/**
 * Một khung ảnh dạng ô truyện tranh (comic panel): viền mực dày, đổ bóng cứng
 * lệch, số ô kiểu tem tròn khi step có nhiều ảnh, caption dạng hộp lời kể.
 */
function FrameFigure({
  src,
  caption,
  index,
  total,
}: {
  src: string;
  caption?: string;
  index: number;
  total: number;
}) {
  const showBadge = total > 1;
  return (
    <figure className="comic-panel group relative overflow-hidden">
      <img
        src={src}
        alt={caption ?? `frame ${index + 1}`}
        loading="lazy"
        className="frame-breath block w-full"
      />
      {showBadge && (
        <span className="comic-num" aria-hidden="true">
          {index + 1}
        </span>
      )}
      {total === 1 && caption && <figcaption className="comic-cap">{caption}</figcaption>}
    </figure>
  );
}

/** Render một bước của bài Peter Principle. */
export default function StepView({ step }: { step: PeterStep }) {
  const [open, setOpen] = useState<number | null>(0);
  const single = step.images.length === 1;

  return (
    <motion.div
      key={step.id}
      initial={{ opacity: 0, y: 16 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.4, ease: [0.2, 0.7, 0.2, 1] }}
    >
      <div className="mb-1 flex items-center gap-4">
        <div className="float-3d grid h-[58px] w-[58px] shrink-0 place-items-center rounded-2xl bg-[rgb(var(--violet)/0.14)] text-violet-tx shadow-soft ring-1 ring-inset ring-[rgb(var(--violet)/0.2)]">
          <LightbulbGlow size={30} weight="duotone" aria-hidden="true" />
        </div>
        <div>
          <span className="badge-glow inline-block rounded-full bg-violet-sk px-2.5 py-0.5 text-[11.5px] font-extrabold uppercase tracking-wide text-violet-tx">
            {step.tag}
          </span>
          <h2 className="mt-1.5 text-[clamp(20px,2.7vw,27px)] font-black leading-tight tracking-tight text-ink">
            {step.title}
          </h2>
        </div>
      </div>

      <div className="mt-5 grid gap-6 lg:grid-cols-[1.05fr_.95fr]">
        <div className="min-w-0 space-y-3">
          {single ? (
            <div className="scene-3d">
              <FrameFigure src={step.images[0]} caption={step.caption} index={0} total={1} />
            </div>
          ) : (
            <>
              {/* Stack dọc: mỗi ảnh là một ô truyện tranh full cột trái. */}
              <div className="scene-3d flex flex-col gap-5">
                {step.images.map((src, i) => (
                  <FrameFigure key={i} src={src} index={i} total={step.images.length} />
                ))}
              </div>
              <p className="comic-note">{step.caption}</p>
            </>
          )}

          {step.demo === "curve" && <CurveDemo />}
          {step.demo === "selfcheck" && <SignalsDemo />}
          {step.demo === "scripts" && <ScriptDemo />}

          {step.stats && <RadialGauge items={step.stats} />}
        </div>

        <div className="flex min-w-0 flex-col gap-4">
          <RichText
            html={step.story}
            className="max-w-none text-[clamp(15px,1.5vw,16.5px)] text-[#333c54] [&_b]:text-ink [&_code]:rounded [&_code]:bg-[#eef1f8] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-[.86em]"
          />

          {step.tiers && <TiersPanel tiers={step.tiers} />}

          {step.why && (
            <div className="space-y-2">
              {step.why.map(([q, a], i) => {
                const on = open === i;
                return (
                  <div key={i} className="overflow-hidden rounded-xl border border-line bg-white/70">
                    <button
                      onClick={() => setOpen(on ? null : i)}
                      className="flex w-full items-center justify-between gap-2 px-4 py-2.5 text-left text-[13.5px] font-extrabold text-ink transition hover:bg-white"
                    >
                      {q}
                      <ChevronDown
                        size={16}
                        strokeWidth={2.8}
                        className={"shrink-0 transition-transform " + (on ? "rotate-180" : "")}
                      />
                    </button>
                    {on && (
                      <p className="border-t border-line px-4 py-2.5 text-[13.5px] leading-relaxed text-[#39445a]">
                        {a}
                      </p>
                    )}
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>

      <div className="comic-bubble mt-8 flex items-center gap-3 px-5 py-4">
        <span className="grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-[rgb(var(--honey))] text-ink ring-2 ring-ink">
          <LightbulbGlow size={20} weight="fill" aria-hidden="true" />
        </span>
        <span className="text-[15px] font-extrabold text-ink">{step.summary}</span>
      </div>
    </motion.div>
  );
}
