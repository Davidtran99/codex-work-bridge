import { useState } from "react";
import { AnimatePresence, motion } from "framer-motion";
import { Search, FileText, ShieldCheck, Wrench } from "lucide-react";

type Mode = "query" | "lint";

interface Cite { note: string; line: string; }
const ANSWER: Cite[] = [
  { note: "concept/AI coding agent.md", line: "Guardrails — ràng buộc hành vi để agent không tự ý phá code." },
  { note: "entity/Claude Code.md", line: "Sandbox — chạy trong môi trường cô lập, xin phép trước khi ghi." },
  { note: "concept/Model Context Protocol.md", line: "Human-in-the-loop — luôn có bước con người duyệt hành động rủi ro." },
];

const LINT: { kind: "dup" | "orphan" | "fix"; text: string }[] = [
  { kind: "dup", text: "2 note trùng khái niệm 'AI agent' (concept/ và entity/) — gợi ý gộp." },
  { kind: "orphan", text: "note 'summary/old-link.md' không còn liên kết tới đâu — link hỏng." },
  { kind: "fix", text: "chuẩn hoá tên: 'clau code' → 'Claude Code' cho khớp entity." },
];

export default function QueryDemo({ initialMode = "query" }: { initialMode?: Mode }) {
  const [mode, setMode] = useState<Mode>(initialMode);
  const [run, setRun] = useState(false);

  return (
    <section className="card-frost rounded-2xl p-4">
      <div className="mb-3 flex gap-1.5">
        {(["query", "lint"] as Mode[]).map((m) => (
          <button
            key={m}
            onClick={() => { setMode(m); setRun(false); }}
            className={
              "flex-1 rounded-lg border px-2 py-1.5 text-[12.5px] font-extrabold transition " +
              (mode === m
                ? "border-indigo bg-indigo text-white"
                : "border-line bg-white text-soft hover:border-indigo hover:text-indigo-tx")
            }
          >
            {m === "query" ? "Truy vấn (Query)" : "Bảo trì (Lint)"}
          </button>
        ))}
      </div>

      {mode === "query" ? (
        <>
          <div className="flex items-center gap-2 rounded-xl border border-line bg-[#fbfcff] px-3 py-2.5">
            <Search size={16} className="text-indigo-tx" />
            <span className="text-[14px] font-bold text-ink">
              "Làm sao giữ một AI coding agent an toàn?"
            </span>
          </div>
          <button
            onClick={() => setRun(true)}
            className="mt-2.5 w-full rounded-lg border border-indigo bg-indigo px-3 py-2 text-[13px] font-extrabold text-white transition hover:brightness-110"
          >
            Hỏi Claude (chỉ dùng note của bạn)
          </button>
          <AnimatePresence>
            {run && (
              <motion.div
                initial={{ opacity: 0, y: 8 }}
                animate={{ opacity: 1, y: 0 }}
                className="mt-3 space-y-2"
              >
                <div className="flex items-center gap-1.5 text-[12px] font-extrabold uppercase tracking-wide text-grass-tx">
                  <ShieldCheck size={14} /> Trả lời có trích nguồn, không ra internet
                </div>
                {ANSWER.map((c, i) => (
                  <motion.div
                    key={i}
                    initial={{ opacity: 0, x: -8 }}
                    animate={{ opacity: 1, x: 0 }}
                    transition={{ delay: 0.12 * i }}
                    className="rounded-lg border border-indigo/20 bg-indigo-sk/40 px-3 py-2"
                  >
                    <p className="text-[13.5px] text-[#39445a]">{c.line}</p>
                    <p className="mt-1 flex items-center gap-1 font-mono text-[11.5px] text-indigo-tx">
                      <FileText size={12} /> {c.note}
                    </p>
                  </motion.div>
                ))}
              </motion.div>
            )}
          </AnimatePresence>
        </>
      ) : (
        <>
          <button
            onClick={() => setRun(true)}
            className="w-full rounded-lg border border-indigo bg-indigo px-3 py-2 text-[13px] font-extrabold text-white transition hover:brightness-110"
          >
            Chạy Lint — quét dọn kho note
          </button>
          <AnimatePresence>
            {run && (
              <motion.ul
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                className="mt-3 space-y-2"
              >
                {LINT.map((l, i) => (
                  <motion.li
                    key={i}
                    initial={{ opacity: 0, x: -8 }}
                    animate={{ opacity: 1, x: 0 }}
                    transition={{ delay: 0.12 * i }}
                    className="flex items-start gap-2 rounded-lg border border-amber/30 bg-amber-sk/40 px-3 py-2 text-[13.5px] text-[#4a3a12]"
                  >
                    <Wrench size={14} className="mt-0.5 shrink-0 text-amber-tx" />
                    <span>{l.text}</span>
                  </motion.li>
                ))}
                <li className="rounded-lg bg-[#f4f6ff] px-3 py-2 text-[12.5px] text-soft">
                  Claude báo cáo, hỏi bạn duyệt trước khi xoá/gộp — bạn vẫn nắm quyền, agent chỉ lo bảo trì.
                </li>
              </motion.ul>
            )}
          </AnimatePresence>
        </>
      )}
    </section>
  );
}
