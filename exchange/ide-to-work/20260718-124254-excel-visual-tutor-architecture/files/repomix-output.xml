<file path="src/lessons/cute-format/CuteDemo.tsx">
import { useMemo, useState } from "react";
import { motion } from "framer-motion";
import { Star, StarHalf, RotateCcw } from "lucide-react";

/** Employee row for the live sandbox. */
interface Emp {
  id: number;
  name: string;
  revenue: number;
}

const START: Emp[] = [
  { id: 1, name: "Lan", revenue: 168 },
  { id: 2, name: "Bình", revenue: 92 },
  { id: 3, name: "Cường", revenue: 61 },
  { id: 4, name: "Dung", revenue: 145 },
  { id: 5, name: "Hải", revenue: 80 },
];

/** Apply the same rules the lesson teaches. */
function rank(rev: number): { label: string; stars: "full" | "half" | "empty"; tone: string } {
  if (rev >= 150) return { label: "Xuất sắc", stars: "full", tone: "excellent" };
  if (rev >= 80) return { label: "Đạt", stars: "half", tone: "pass" };
  return { label: "Kém", stars: "empty", tone: "weak" };
}

function Stars({ kind }: { kind: "full" | "half" | "empty" }) {
  const color =
    kind === "full" ? "text-amber-500" : kind === "half" ? "text-amber-400" : "text-gray-300";
  if (kind === "half") {
    return (
      <span className={"inline-flex " + color} aria-label="nửa sao">
        <StarHalf size={18} strokeWidth={2} fill="currentColor" />
      </span>
    );
  }
  return (
    <span className={"inline-flex " + color} aria-label={kind === "full" ? "sao đầy" : "sao rỗng"}>
      <Star size={18} strokeWidth={2} fill={kind === "full" ? "currentColor" : "none"} />
    </span>
  );
}

/**
 * Live sandbox: drag each revenue slider and watch the label (Custom Format),
 * the star (Icon Set) and the zebra stripe (MOD(ROW(),2)) update together —
 * exactly the rules taught in the lesson.
 */
export default function CuteDemo() {
  const [emps, setEmps] = useState<Emp[]>(START);
  const [hideGrid, setHideGrid] = useState(true);
  const [zebra, setZebra] = useState(true);

  const setRev = (id: number, v: number) =>
    setEmps((prev) => prev.map((e) => (e.id === id ? { ...e, revenue: v } : e)));

  const rows = useMemo(
    () => emps.map((e, i) => ({ ...e, even: i % 2 === 1, ...rank(e.revenue) })),
    [emps],
  );

  return (
    <div className="rounded-2xl border border-[rgb(var(--violet)/0.25)] bg-white/70 p-4 sm:p-5">
      <div className="mb-3 flex flex-wrap items-center justify-between gap-3">
        <h3 className="text-[15px] font-black text-ink">Sân chơi: kéo doanh thu, xem bảng tự đổi</h3>
        <div className="flex items-center gap-2">
          <button
            onClick={() => setZebra((v) => !v)}
            className={
              "rounded-full border px-3 py-1 text-[12px] font-extrabold transition " +
              (zebra
                ? "border-[rgb(var(--violet))] bg-[rgb(var(--violet-sk))] text-[rgb(var(--violet-tx))]"
                : "border-line bg-white text-soft")
            }
          >
            Sọc MOD {zebra ? "BẬT" : "TẮT"}
          </button>
          <button
            onClick={() => setHideGrid((v) => !v)}
            className={
              "rounded-full border px-3 py-1 text-[12px] font-extrabold transition " +
              (hideGrid
                ? "border-[rgb(var(--violet))] bg-[rgb(var(--violet-sk))] text-[rgb(var(--violet-tx))]"
                : "border-line bg-white text-soft")
            }
          >
            Ẩn lưới {hideGrid ? "BẬT" : "TẮT"}
          </button>
          <button
            onClick={() => setEmps(START)}
            className="inline-flex items-center gap-1 rounded-full border border-line bg-white px-3 py-1 text-[12px] font-extrabold text-soft transition hover:border-teal hover:text-teal-d"
          >
            <RotateCcw size={13} strokeWidth={2.8} /> Reset
          </button>
        </div>
      </div>

      <div
        className={
          "overflow-hidden rounded-xl " +
          (hideGrid ? "" : "[&_*]:!border-[rgb(203_190_165)]")
        }
      >
        <table className="w-full border-collapse text-[13.5px]">
          <thead>
            <tr className="bg-[rgb(var(--violet)/0.12)] text-[rgb(var(--violet-tx))]">
              <th className="border border-[rgb(var(--violet)/0.2)] px-3 py-2 text-left font-black">Nhân viên</th>
              <th className="border border-[rgb(var(--violet)/0.2)] px-3 py-2 text-left font-black">Doanh thu</th>
              <th className="border border-[rgb(var(--violet)/0.2)] px-3 py-2 text-left font-black">Đánh giá</th>
              <th className="border border-[rgb(var(--violet)/0.2)] px-3 py-2 text-center font-black">Sao</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => {
              const stripe = zebra && r.even ? "bg-[rgb(var(--violet)/0.06)]" : "bg-white";
              const labelTone =
                r.tone === "excellent"
                  ? "text-green-700 font-black"
                  : r.tone === "pass"
                    ? "text-amber-700 font-bold"
                    : "text-red-600 font-bold";
              return (
                <tr key={r.id} className={stripe}>
                  <td className="border border-line px-3 py-2 font-bold text-ink">{r.name}</td>
                  <td className="border border-line px-3 py-2">
                    <div className="flex items-center gap-2">
                      <input
                        type="range"
                        min={0}
                        max={220}
                        value={r.revenue}
                        onChange={(e) => setRev(r.id, Number(e.target.value))}
                        className="h-1.5 w-24 cursor-pointer accent-[rgb(var(--violet))]"
                        aria-label={"Doanh thu của " + r.name}
                      />
                      <span className="w-9 text-right font-mono font-bold text-ink">{r.revenue}</span>
                    </div>
                  </td>
                  <td className="border border-line px-3 py-2">
                    <motion.span
                      key={r.label}
                      initial={{ opacity: 0, y: -4 }}
                      animate={{ opacity: 1, y: 0 }}
                      transition={{ duration: 0.2 }}
                      className={labelTone}
                    >
                      {r.label}
                    </motion.span>
                  </td>
                  <td className="border border-line px-3 py-2 text-center">
                    <Stars kind={r.stars} />
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <p className="mt-3 text-[12.5px] leading-relaxed text-soft">
        Kéo thanh doanh thu: cột <b>Đánh giá</b> đổi chữ theo mã <code className="rounded bg-[#eef1f8] px-1 py-0.5">[&ge;150]"Xuất sắc";[&ge;80]"Đạt";"Kém"</code>,
        cột <b>Sao</b> đổi đầy / nửa / rỗng theo Icon Set, còn nút trên bật/tắt sọc <code className="rounded bg-[#eef1f8] px-1 py-0.5">=MOD(ROW(),2)=0</code> và lưới — đúng 3 mẹo trong bài.
      </p>
    </div>
  );
}
