import { WIKI_MIND, WIKI_STEPS } from "./steps";

const STEP_ICONS: LucideIcon[] = [
  Archive, BookOpen, Bot, GitBranch, BrainCircuit, FolderTree,
  FileSearch, Boxes, Network, Library, SearchCheck, Wrench,
];

/** Bài học tương tác: dựng LLM Wiki cá nhân bằng Obsidian và Claude Code. */
export default function WikiLesson() {
  const scenes = WIKI_STEPS.map((step, index) => ({
    id: step.id, tag: step.tag, node: index,
  }));
  const mindNodes = WIKI_MIND.map((label, index) => ({
    Icon: STEP_ICONS[index] ?? BrainCircuit, label,
  }));

  const head = (
    <header className="relative px-1 pb-1 pt-2 text-center">
      <span className="inline-flex items-center gap-2 rounded-full bg-gradient-to-br from-indigo-sk to-[#f1f2ff] px-4 py-2 text-[12.5px] font-black uppercase tracking-wider text-indigo-tx shadow-soft">
        <BrainCircuit size={16} strokeWidth={2.6} /> Knowledge system · LLM Wiki
      </span>
      <h1 className="headline-grad headline-reveal mx-auto mt-3 max-w-4xl text-[clamp(26px,3.8vw,42px)] font-extrabold leading-[1.08] tracking-tight">
