import { useState } from "react";
import { AnimatePresence, motion } from "framer-motion";
import type { Tiers } from "./steps";

/** Tab panel: Dễ hiểu / Kỹ thuật / Chuyên sâu. */
export default function TiersPanel({ tiers }: { tiers: Tiers }) {
  const [t, setT] = useState<keyof Tiers>("easy");
  const tabs: { k: keyof Tiers; label: string }[] = [
    { k: "easy", label: "Dễ hiểu" },
    { k: "tech", label: "Sâu hơn" },
    { k: "deep", label: "Ứng dụng" },
  ];
  return (
    <section className="card-frost rounded-2xl p-4">
      <div className="mb-3 flex gap-1.5">
        {tabs.map((x) => (
          <button
            key={x.k}
            onClick={() => setT(x.k)}
            className={
              "flex-1 rounded-lg border px-2 py-1.5 text-[12.5px] font-extrabold transition " +
              (t === x.k
                ? "border-violet bg-violet text-white"
                : "border-line bg-white text-soft hover:border-violet hover:text-violet-tx")
            }
          >
            {x.label}
          </button>
        ))}
      </div>
      <AnimatePresence mode="wait">
        <motion.div
          key={t}
          initial={{ opacity: 0, y: 8 }}
          animate={{ opacity: 1, y: 0 }}
          exit={{ opacity: 0, y: -6 }}
          transition={{ duration: 0.22 }}
          className="min-h-[80px] rounded-xl border border-line bg-[#fbfcff] p-3.5 text-[14.5px] leading-relaxed text-[#39445a]"
        >
          {tiers[t]}
        </motion.div>
      </AnimatePresence>
    </section>
  );
}
