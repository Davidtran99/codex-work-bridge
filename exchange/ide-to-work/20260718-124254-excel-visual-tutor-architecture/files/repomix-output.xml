<file path="_avif_trial.mjs">
import sharp from "sharp";
import { readdirSync, statSync } from "fs";
import { join } from "path";

const dirs = [
  "src/lessons/cute-format/frames",
  "src/lessons/peter-principle/frames",
  "src/lessons/pq-merge/frames",
];
const files = [];
for (const d of dirs) {
  for (const f of readdirSync(d)) {
    if (f.endsWith(".avif")) files.push(join(d, f));
  }
}
const kb = (n) => (n / 1024).toFixed(1);
let orig = 0;
for (const f of files) orig += statSync(f).size;

const trials = [
  { w: 1100, q: 45, e: 6 },
  { w: 1100, q: 50, e: 6 },
  { w: 1280, q: 45, e: 6 },
];
for (const t of trials) {
  let total = 0;
  for (const f of files) {
    const buf = await sharp(f)
      .resize({ width: t.w, withoutEnlargement: true })
      .avif({ quality: t.q, effort: t.e })
      .toBuffer();
    total += buf.length;
  }
  console.log(`w=${t.w} q=${t.q} e=${t.e} -> ${kb(total)} KB (was ${kb(orig)} KB, -${(100-total/orig*100).toFixed(0)}%)`);
}
