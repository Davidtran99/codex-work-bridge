<file path="src/hooks/useSimAnim.ts">
import { useCallback, useEffect, useRef, useState } from "react";
import type { Row, TableKind } from "../data/types";
import { frameCount } from "../lib/grid";

/** Drives step-by-step simulation for a scene's table. */
export function useSimAnim(table: TableKind, src: Row[], uniq: string[]) {
  const total = frameCount(table, src, uniq);
  const [step, setStep] = useState(-1);
  const [playing, setPlaying] = useState(false);
  const timer = useRef<number | null>(null);

  const clear = useCallback(() => {
    if (timer.current !== null) {
      window.clearTimeout(timer.current);
      timer.current = null;
    }
  }, []);

  // reset whenever the scene (table) changes
  useEffect(() => {
    clear();
    setStep(-1);
    setPlaying(false);
    return clear;
  }, [table, clear]);

  // advance while playing
  useEffect(() => {
    if (!playing) return;
    if (step >= total - 1) {
      setPlaying(false);
      return;
    }
    timer.current = window.setTimeout(() => setStep((s) => s + 1), 720);
    return clear;
  }, [playing, step, total, clear]);

  const play = useCallback(() => {
    if (total === 0) return;
    setStep((s) => (s >= total - 1 ? -1 : s));
    setPlaying(true);
  }, [total]);

  const stepForward = useCallback(() => {
    clear();
    setPlaying(false);
    setStep((s) => Math.min(s + 1, total - 1));
  }, [total, clear]);

  const reset = useCallback(() => {
    clear();
    setPlaying(false);
    setStep(-1);
  }, [clear]);

  return { step, playing, total, play, stepForward, reset };
}
