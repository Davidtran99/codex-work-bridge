import cubeJson from "./cube.json";

/** One aggregated group: [kv, np, sp, yr, sumRevenue, count]. */
type Group = [number, number, number, number, number, number];

interface Cube {
  dims: { kv: string[]; np: string[]; sp: string[]; yr: number[] };
  groups: Group[];
  rawCount: number;
  grand: number;
}

export const CUBE = cubeJson as unknown as Cube;

/** Field keys available to drag into pivot zones. */
export type FieldKey = "kv" | "np" | "sp" | "yr";

export const FIELD_LABEL: Record<FieldKey, string> = {
  kv: "Khu vực",
  np: "Nhà phân phối",
  sp: "Sản phẩm",
  yr: "Năm",
};

/** Column index of each field inside a Group tuple. */
const FIELD_COL: Record<FieldKey, 0 | 1 | 2 | 3> = { kv: 0, np: 1, sp: 2, yr: 3 };

export function fieldValues(f: FieldKey): string[] {
  if (f === "yr") return CUBE.dims.yr.map(String);
  return CUBE.dims[f];
}

export type Agg = "sum" | "avg" | "count" | "pct";

export const AGG_LABEL: Record<Agg, string> = {
  sum: "Tổng (Sum)",
  avg: "Trung bình (Average)",
  count: "Đếm (Count)",
  pct: "% tổng thể",
};

export interface PivotConfig {
  rows: FieldKey[];
  cols: FieldKey[];
  agg: Agg;
  filters: Partial<Record<FieldKey, Set<string>>>;
}

export interface PivotResult {
  rowKeys: string[][];        // each row = tuple of label parts (by rows fields)
  colKeys: string[][];        // each col = tuple of label parts (by cols fields)
  cells: number[][];          // [rowIndex][colIndex]
  rowTotals: number[];
  colTotals: number[];
  grand: number;
  rowFields: FieldKey[];
  colFields: FieldKey[];
}

/** Label parts for a group along the given fields. */
function keyOf(g: Group, fields: FieldKey[]): string[] {
  return fields.map((f) => fieldValues(f)[g[FIELD_COL[f]]]);
}

function passFilters(g: Group, filters: PivotConfig["filters"]): boolean {
  for (const f of Object.keys(filters) as FieldKey[]) {
    const allowed = filters[f];
    if (!allowed || allowed.size === 0) continue;
    const val = fieldValues(f)[g[FIELD_COL[f]]];
    if (!allowed.has(val)) return false;
  }
  return true;
}

/** Ordered unique tuples for a set of fields, following dims order. */
function orderedKeys(fields: FieldKey[], present: Set<string>): string[][] {
  if (fields.length === 0) return [[]];
  const lists = fields.map(fieldValues);
  const out: string[][] = [];
  const walk = (depth: number, acc: string[]) => {
    if (depth === fields.length) {
      if (present.has(acc.join("␟"))) out.push([...acc]);
      return;
    }
    for (const v of lists[depth]) walk(depth + 1, [...acc, v]);
  };
  walk(0, []);
  return out;
}

function aggregate(sum: number, count: number, agg: Agg, grand: number): number {
  switch (agg) {
    case "sum": return sum;
    case "avg": return count ? sum / count : 0;
    case "count": return count;
    case "pct": return grand ? (sum / grand) * 100 : 0;
  }
}

export function computePivot(cfg: PivotConfig): PivotResult {
  const rowPresent = new Set<string>();
  const colPresent = new Set<string>();

  // accumulate sum + count per (rowKey, colKey)
  const acc = new Map<string, { sum: number; count: number }>();
  let grandSum = 0;
  let grandCount = 0;

  for (const g of CUBE.groups) {
    if (!passFilters(g, cfg.filters)) continue;
    const rk = keyOf(g, cfg.rows).join("␟");
    const ck = keyOf(g, cfg.cols).join("␟");
    rowPresent.add(rk);
    colPresent.add(ck);
    const mapKey = rk + "❙" + ck;
    const cur = acc.get(mapKey) ?? { sum: 0, count: 0 };
    cur.sum += g[4];
    cur.count += g[5];
    acc.set(mapKey, cur);
    grandSum += g[4];
    grandCount += g[5];
  }

  const rowKeys = orderedKeys(cfg.rows, rowPresent);
  const colKeys = orderedKeys(cfg.cols, colPresent);
  const grandAgg = aggregate(grandSum, grandCount, cfg.agg, grandSum);

  const cells: number[][] = [];
  const rowTotals: number[] = [];
  const colSums = new Array(colKeys.length).fill(0);
  const colCounts = new Array(colKeys.length).fill(0);

  rowKeys.forEach((rk, ri) => {
    const rowStr = rk.join("␟");
    let rSum = 0;
    let rCount = 0;
    const rowCells: number[] = [];
    colKeys.forEach((ck, ci) => {
      const cell = acc.get(rowStr + "❙" + ck.join("␟")) ?? { sum: 0, count: 0 };
      rowCells.push(aggregate(cell.sum, cell.count, cfg.agg, grandSum));
      rSum += cell.sum;
      rCount += cell.count;
      colSums[ci] += cell.sum;
      colCounts[ci] += cell.count;
    });
    cells.push(rowCells);
    rowTotals.push(aggregate(rSum, rCount, cfg.agg, grandSum));
    ri;
  });

  const colTotals = colKeys.map((_, ci) =>
    aggregate(colSums[ci], colCounts[ci], cfg.agg, grandSum),
  );

  return {
    rowKeys,
    colKeys,
    cells,
    rowTotals,
    colTotals,
    grand: grandAgg,
    rowFields: cfg.rows,
    colFields: cfg.cols,
  };
}
