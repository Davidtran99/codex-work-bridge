<file path="src/lessons/pq-merge/MergePlayground.tsx">
import { useMemo, useState } from "react";
import { AnimatePresence, motion } from "framer-motion";
import { Plus, RotateCcw, Trash2, Table2, Layers, ArrowDown } from "lucide-react";
import { SHEETS, type Province } from "./data";

const REGION_ACCENT: Record<string, string> = {
  "Bắc": "--teal",
  "Trung": "--honey",
  "Nam": "--violet",
};

function fmt(n: number): string {
  return n.toLocaleString("vi-VN", { maximumFractionDigits: 2 });
}

interface Extra extends Province {
  id: number;
}

/**
 * Mô phỏng Power Query Append: ba bảng nguồn (đã "biến thành Table" + tạo query)
 * được nối dọc thành một query "Toàn quốc", rồi Pivot gộp theo khu vực. Người học
 * thêm/bớt một tỉnh ở nguồn rồi bấm Refresh để thấy Pivot tự cập nhật — đúng
 * thông điệp cuối video.
 */
export default function MergePlayground() {
  // các dòng người dùng thêm vào một sheet nguồn (chưa refresh)
  const [pending, setPending] = useState<Extra[]>([]);
  // ảnh chụp dữ liệu tại lần Refresh gần nhất (query kết quả chỉ thấy cái này)
  const [loaded, setLoaded] = useState<Extra[]>([]);
  const [seq, setSeq] = useState(1);
  const [dirty, setDirty] = useState(false);

  // nguồn hiện tại (thời gian thực) = dữ liệu gốc + pending
  const liveRows: Province[] = useMemo(
    () => [...SHEETS.flatMap((s) => s.rows), ...pending],
    [pending],
  );

  // query "Toàn quốc" chỉ phản ánh dữ liệu ở lần refresh gần nhất
  const queryRows: Province[] = useMemo(
    () => [...SHEETS.flatMap((s) => s.rows), ...loaded],
    [loaded],
  );

  // Pivot: tổng GDP + số tỉnh theo khu vực, từ queryRows
  const pivot = useMemo(() => {
    const order = ["Bắc", "Trung", "Nam"];
    const map = new Map<string, { sum: number; count: number }>();
    for (const r of queryRows) {
      const cur = map.get(r.region) ?? { sum: 0, count: 0 };
      cur.sum += r.gdp;
      cur.count += 1;
      map.set(r.region, cur);
    }
    const rows = order
      .filter((k) => map.has(k))
      .map((k) => ({ region: k, ...map.get(k)! }));
    const grand = rows.reduce(
      (acc, r) => ({ sum: acc.sum + r.sum, count: acc.count + r.count }),
      { sum: 0, count: 0 },
    );
    return { rows, grand };
  }, [queryRows]);

  function addProvince() {
    const names = ["Gia Lai mới", "Tỉnh demo", "Khu KT mới", "Đặc khu", "Tỉnh X"];
    const name = names[pending.length % names.length] + " " + seq;
    setPending((p) => [
      ...p,
      { id: seq, region: "Bắc", name, gdp: 100 },
    ]);
    setSeq((s) => s + 1);
    setDirty(true);
  }

  function removeProvince(id: number) {
    setPending((p) => p.filter((x) => x.id !== id));
    setDirty(true);
  }

  function refresh() {
    setLoaded(pending);
    setDirty(false);
  }

  function reset() {
    setPending([]);
    setLoaded([]);
    setDirty(false);
  }

  const liveCount = liveRows.length;
  const queryCount = queryRows.length;

  return (
    <div className="rounded-2xl border border-line bg-gradient-to-b from-[#fdfbf6] to-[#f7f3ea] p-4 shadow-[inset_0_1px_0_#fff]">
      <div className="mb-3 flex items-center justify-between gap-2">
        <div className="text-[12.5px] font-extrabold text-soft">
          Ba sheet nguồn nối dọc thành một query, Pivot gộp lại. Thêm/xoá tỉnh rồi bấm Refresh để thấy nó tự cập nhật.
        </div>
        <button
          onClick={reset}
          className="inline-flex shrink-0 items-center gap-1.5 rounded-lg bg-[#efe8d8] px-2.5 py-1.5 text-[12px] font-extrabold text-soft transition hover:text-ink"
        >
          <RotateCcw size={13} strokeWidth={2.6} /> Đặt lại
        </button>
      </div>

      <div className="grid gap-3 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
        {/* LEFT: 3 source sheets */}
        <div className="flex flex-col gap-2.5">
          <div className="text-[11px] font-extrabold uppercase tracking-wide text-soft">
            3 sheet nguồn (mỗi sheet là 1 Table + 1 query)
          </div>
          {SHEETS.map((s) => {
            const extra = pending.filter((p) => p.region === s.key);
            const total =
              s.rows.reduce((a, p) => a + p.gdp, 0) +
              extra.reduce((a, p) => a + p.gdp, 0);
            return (
              <div
                key={s.key}
                className="rounded-xl border border-line bg-white/75 p-2.5"
                style={{ borderLeft: `4px solid rgb(var(${REGION_ACCENT[s.key]}))` }}
              >
                <div className="flex items-center justify-between">
                  <span className="inline-flex items-center gap-1.5 text-[12.5px] font-extrabold text-ink">
                    <Table2 size={13} strokeWidth={2.6} style={{ color: `rgb(var(${REGION_ACCENT[s.key]}))` }} />
                    {s.label}
                    <span className="rounded bg-[#eef1f8] px-1.5 py-0.5 text-[10px] font-bold text-soft">
                      ô {s.anchor}
                    </span>
                  </span>
                  <span className="text-[11.5px] font-bold text-soft">
                    {s.rows.length + extra.length} tỉnh · {fmt(total)} tỉ $
                  </span>
                </div>
                {extra.length > 0 && (
                  <div className="mt-1.5 flex flex-wrap gap-1">
                    <AnimatePresence>
                      {extra.map((p) => (
                        <motion.button
                          key={p.id}
                          initial={{ opacity: 0, scale: 0.7 }}
                          animate={{ opacity: 1, scale: 1 }}
                          exit={{ opacity: 0, scale: 0.7 }}
                          onClick={() => removeProvince(p.id)}
                          title="Xoá dòng này khỏi nguồn"
                          className="inline-flex items-center gap-1 rounded-md bg-grass-sk px-1.5 py-0.5 text-[10.5px] font-bold text-grass-tx transition hover:bg-rose-sk hover:text-rose"
                        >
                          + {p.name} ({fmt(p.gdp)}) <Trash2 size={10} strokeWidth={2.6} />
                        </motion.button>
                      ))}
                    </AnimatePresence>
                  </div>
                )}
              </div>
            );
          })}

          <button
            onClick={addProvince}
            className="inline-flex items-center justify-center gap-1.5 rounded-xl border border-dashed border-teal/50 bg-teal-sk/40 px-3 py-2 text-[12.5px] font-extrabold text-teal-d transition hover:bg-teal-sk"
          >
            <Plus size={14} strokeWidth={2.8} /> Thêm 1 tỉnh vào Miền Bắc (100 tỉ $)
          </button>

          <div className="flex items-center justify-center gap-1.5 text-[11px] font-bold text-soft">
            <Layers size={13} strokeWidth={2.4} /> Append: nối dọc 3 Table thành 1 query
            <ArrowDown size={13} strokeWidth={2.4} />
          </div>
        </div>

        {/* RIGHT: appended query + pivot */}
        <div className="flex flex-col gap-2.5">
          <div className="flex items-center justify-between gap-2">
            <span className="text-[11px] font-extrabold uppercase tracking-wide text-soft">
              Query "Toàn quốc" + Pivot
            </span>
            <button
              onClick={refresh}
              className={
                "inline-flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 text-[12px] font-extrabold text-white transition " +
                (dirty ? "cta-pulse bg-teal shadow-soft" : "bg-[#c9cdd6]")
              }
            >
              <RotateCcw size={13} strokeWidth={2.8} /> Refresh
            </button>
          </div>

          {dirty && (
            <div className="rounded-lg border border-honey/40 bg-honey/10 px-2.5 py-1.5 text-[11.5px] font-bold text-[rgb(var(--amber-tx))]">
              Nguồn có {liveCount} dòng, nhưng query mới thấy {queryCount} dòng. Bấm Refresh để đồng bộ.
            </div>
          )}

          <div className="overflow-hidden rounded-xl border border-line bg-white shadow-soft">
            <table className="w-full border-collapse text-[13px]">
              <thead>
                <tr>
                  <th className="border border-line bg-[#f3efe6] px-3 py-1.5 text-left font-extrabold text-soft">
                    Khu vực
                  </th>
                  <th className="border border-line bg-[#eef3fa] px-3 py-1.5 text-right font-extrabold text-ink">
                    Tổng GDP (tỉ $)
                  </th>
                  <th className="border border-line bg-[#eef3fa] px-3 py-1.5 text-right font-extrabold text-ink">
                    Số tỉnh
                  </th>
                </tr>
              </thead>
              <tbody>
                {pivot.rows.map((r) => (
                  <tr key={r.region}>
                    <td className="border border-line px-3 py-1.5 font-bold text-ink">
                      <span
                        className="mr-1.5 inline-block h-2 w-2 rounded-full align-middle"
                        style={{ backgroundColor: `rgb(var(${REGION_ACCENT[r.region]}))` }}
                      />
                      Miền {r.region}
                    </td>
                    <td className="border border-line px-3 py-1.5 text-right font-bold tabular-nums text-ink">
                      {fmt(r.sum)}
                    </td>
                    <td className="border border-line px-3 py-1.5 text-right tabular-nums text-soft">
                      {r.count}
                    </td>
                  </tr>
                ))}
                <tr>
                  <td className="border border-line bg-honey/15 px-3 py-1.5 font-extrabold text-ink">
                    Toàn quốc
                  </td>
                  <td className="border border-line bg-honey/10 px-3 py-1.5 text-right font-extrabold tabular-nums text-ink">
                    {fmt(pivot.grand.sum)}
                  </td>
                  <td className="border border-line bg-honey/10 px-3 py-1.5 text-right font-extrabold tabular-nums text-ink">
                    {pivot.grand.count}
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <p className="text-[11.5px] leading-relaxed text-soft">
            Query kết quả là <b>ảnh chụp</b> của nguồn tại lần Refresh gần nhất. Đó là lý do thêm dữ liệu xong phải Refresh — giống hệt Power Query thật.
          </p>
        </div>
      </div>
    </div>
  );
}
