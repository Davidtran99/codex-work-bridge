<file path="src/components/Button.tsx">
import type { ButtonHTMLAttributes, ReactNode } from "react";

type Variant = "primary" | "soft" | "ghost" | "honey";

interface Props extends ButtonHTMLAttributes<HTMLButtonElement> {
  variant?: Variant;
  icon?: ReactNode;
  iconRight?: ReactNode;
  children?: ReactNode;
}

/**
 * Tactile "book key" button: a colored face sitting on a darker base edge.
 * Pressing pushes the face down onto the edge (translateY), like a real key.
 * Primary/honey get an ink sheen sweep on hover (theme: ink on paper).
 */
const FACE: Record<Variant, string> = {
  primary:
    "btn-sheen bg-gradient-to-b from-teal to-teal-d text-white " +
    "shadow-[0_4px_0_rgb(var(--teal-edge)),0_9px_18px_rgb(var(--teal)/0.32)] " +
    "hover:brightness-[1.05] active:translate-y-[3px] " +
    "active:shadow-[0_1px_0_rgb(var(--teal-edge)),0_3px_8px_rgb(var(--teal)/0.30)]",
  honey:
    "btn-sheen bg-gradient-to-b from-amber to-honey text-white " +
    "shadow-[0_4px_0_rgb(var(--amber-edge)),0_9px_18px_rgb(var(--honey)/0.32)] " +
    "hover:brightness-[1.05] active:translate-y-[3px] " +
    "active:shadow-[0_1px_0_rgb(var(--amber-edge)),0_3px_8px_rgb(var(--honey)/0.30)]",
  soft:
    "bg-gradient-to-b from-white to-[#f4efe4] text-ink border border-[rgb(var(--paper-line)/0.7)] " +
    "shadow-[0_4px_0_rgb(var(--paper-line)/0.55),0_6px_14px_rgb(20_26_43/0.08)] " +
    "hover:from-white hover:to-[#efe8d8] active:translate-y-[3px] " +
    "active:shadow-[0_1px_0_rgb(var(--paper-line)/0.55),0_2px_6px_rgb(20_26_43/0.08)]",
  ghost:
    "bg-transparent text-soft hover:text-ink hover:bg-[rgb(var(--paper-line)/0.16)] " +
    "active:translate-y-[1px]",
};

export default function Button({
  variant = "primary",
  icon,
  iconRight,
  children,
  className = "",
  disabled,
  ...rest
}: Props) {
  return (
    <button
      {...rest}
      disabled={disabled}
      className={
        "group relative inline-flex select-none items-center justify-center gap-2 rounded-2xl px-4 py-2.5 " +
        "text-[14px] font-extrabold tracking-tight transition-all duration-100 ease-out " +
        "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal/60 focus-visible:ring-offset-2 " +
        "focus-visible:ring-offset-[rgb(var(--paper))] " +
        "disabled:pointer-events-none disabled:opacity-45 disabled:shadow-none disabled:translate-y-0 " +
        FACE[variant] +
        " " +
        className
      }
    >
      {icon && (
        <span className="grid place-items-center transition-transform duration-150 group-hover:-translate-x-0.5 group-active:scale-90">
          {icon}
        </span>
      )}
      {children}
      {iconRight && (
        <span className="grid place-items-center transition-transform duration-150 group-hover:translate-x-0.5 group-active:scale-90">
          {iconRight}
        </span>
      )}
    </button>
  );
}
