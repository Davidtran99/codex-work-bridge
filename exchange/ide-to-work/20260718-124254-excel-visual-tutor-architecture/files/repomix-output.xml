/* ============================================================
 * formulaFlow — công thức tô màu + pop TỰ ĐỘNG theo THỨ TỰ ĐỌC.
 *
 * Port từ office-exam-coach (formulaReading.tsx). Cải tiến cho
 * web bài giảng excel-visual-tutor:
 *  - Không ép 1 hàng: cho phép wrap tự nhiên (bài giảng không phải chat).
 *  - Bỏ auto-scale/ResizeObserver: layout ổn định, khỏi tính lại.
 *  - `STEP_DELAY` THÍCH ỨNG theo độ dài công thức (dài → chậm hơn).
 *  - Tự phát hiện `prefers-reduced-motion` → tắt loop sạch sẽ.
 *  - Con trỏ đọc "▸" tuỳ chọn nhảy tới token đang đọc (đồng bộ pha).
 *  - Xuất `computeSyntaxReadingRank` + `mapAiStepsToRank` để dùng
 *    lại cho danh sách "bước đọc" (đồng bộ nhịp với popup).
 * ============================================================ */
import {
  useEffect,
  useMemo,
  useState,
  type CSSProperties,
} from "react";

/* ── Types ─────────────────────────────────────────────────── */
export type FormulaTok = { cls: string; value: string };
export interface FormulaReadingStep {
  fragment: string;
  explain?: string;
}

/* Hàm điều kiện đọc "điều kiện → verdict → nhánh". Mọi hàm khác đọc inside-out. */
const DECISION_FUNCS = new Set([
  "IF", "IFS", "IFERROR", "IFNA", "IFNULL", "SWITCH",
]);

/* ── Tokenize ──────────────────────────────────────────────── */
export function tokenizeFormula(formula: string): FormulaTok[] {
  const re =
    /('[^']*'![^\s;)]+|\$?[A-Z]{1,3}\$?\d+(?::\$?[A-Z]{1,3}\$?\d+)?|"[^"]*"|[A-Z]{2,}(?=\s*\()|[0-9]+(?:\.[0-9]+)?|[();,><=!&+\-*/]|;)/gi;
  const out: FormulaTok[] = [];
  let last = 0;
  let depth = 0;
  let m: RegExpExecArray | null;
  while ((m = re.exec(formula)) !== null) {
    if (m.index > last)
      out.push({ cls: "ff-tok-default", value: formula.slice(last, m.index) });
    const tok = m[0];
    let cls = "ff-tok-default";
    if (tok === "(") { cls = `ff-paren ff-paren-d${depth % 3}`; depth += 1; }
    else if (tok === ")") { depth = Math.max(0, depth - 1); cls = `ff-paren ff-paren-d${depth % 3}`; }
    else if (tok.includes("!")) cls = "ff-tok-sheet";
    else if (/^[A-Z]{2,}$/i.test(tok)) cls = "ff-tok-func";
    else if (/^\$?[A-Z]{1,3}\$?\d+/i.test(tok)) cls = "ff-tok-ref";
    else if (tok.startsWith('"')) cls = "ff-tok-string";
    else if (/^[0-9]/.test(tok)) cls = "ff-tok-num";
    else if (/^[;,><=!&+\-*/]$/.test(tok)) cls = "ff-tok-punct";
    out.push({ cls, value: tok });
    last = m.index + tok.length;
  }
  if (last < formula.length)
    out.push({ cls: "ff-tok-default", value: formula.slice(last) });
  return out;
}

/* ── Syntax reading rank (inside-out, IF-first) ────────────── */
export function computeSyntaxReadingRank(toks: FormulaTok[]): number[] {
  const n = toks.length;
  if (n === 0) return [];
  const identity = () => Array.from({ length: n }, (_, i) => i);

  const kindOf = (i: number): "func" | "lp" | "rp" | "sep" | "other" => {
    const t = toks[i];
    if (t.cls.startsWith("ff-paren")) return t.value === "(" ? "lp" : "rp";
    if (t.cls === "ff-tok-func") return "func";
    if (t.value === ";" || t.value === ",") return "sep";
    return "other";
  };
  const isWs = (i: number) =>
    toks[i].cls === "ff-tok-default" && toks[i].value.trim() === "";

  function parseGroup(start: number): { order: number[]; next: number } {
    const inner: number[] = [];
    let p = start + 1;
    let close = -1;
    while (p < n) {
      const k = kindOf(p);
      if (k === "rp") { close = p; p++; break; }
      if (k === "func") { const r = parseCall(p); inner.push(...r.order); p = r.next; continue; }
      if (k === "lp") { const r = parseGroup(p); inner.push(...r.order); p = r.next; continue; }
      inner.push(p); p++;
    }
    return { order: [start, ...inner, ...(close >= 0 ? [close] : [])], next: p };
  }

  function parseCall(start: number): { order: number[]; next: number } {
    const name = toks[start].value.toUpperCase();
    let p = start + 1;
    const headWs: number[] = [];
    while (p < n && isWs(p)) { headWs.push(p); p++; }
    if (p >= n || kindOf(p) !== "lp") return { order: [start, ...headWs], next: p };
    const lp = p; p++;
    const args: number[][] = [];
    const seps: number[] = [];
    let cur: number[] = [];
    let rp = -1;
    while (p < n) {
      const k = kindOf(p);
      if (k === "rp") { rp = p; p++; break; }
      if (k === "sep") { args.push(cur); cur = []; seps.push(p); p++; continue; }
      if (k === "func") { const r = parseCall(p); cur.push(...r.order); p = r.next; continue; }
      if (k === "lp") { const r = parseGroup(p); cur.push(...r.order); p = r.next; continue; }
      cur.push(p); p++;
    }
    args.push(cur);
    const head = [start, ...headWs, lp];
    const tail = rp >= 0 ? [rp] : [];
    const order: number[] = [];
    if (DECISION_FUNCS.has(name)) {
      order.push(...(args[0] ?? []));
      order.push(...head);
      for (let a = 1; a < args.length; a++) {
        if (seps[a - 1] !== undefined) order.push(seps[a - 1]);
        order.push(...args[a]);
      }
      order.push(...tail);
    } else {
      for (let a = 0; a < args.length; a++) {
        order.push(...args[a]);
        if (seps[a] !== undefined) order.push(seps[a]);
      }
      order.push(...head);
      order.push(...tail);
    }
    return { order, next: p };
  }

  const order: number[] = [];
  let p = 0;
  while (p < n) {
    const k = kindOf(p);
    if (k === "func") { const r = parseCall(p); order.push(...r.order); p = r.next; continue; }
    if (k === "lp") { const r = parseGroup(p); order.push(...r.order); p = r.next; continue; }
    order.push(p); p++;
  }
  let ok = order.length === n;
  if (ok) {
    const seen = new Array(n).fill(false);
    for (const i of order) { if (i < 0 || i >= n || seen[i]) { ok = false; break; } seen[i] = true; }
  }
  const finalOrder = ok ? order : identity();
  const rank = new Array(n).fill(0);
  finalOrder.forEach((tokIdx, k) => { rank[tokIdx] = k; });
  return rank;
}

/* ── AI-provided reading steps → per-token rank ────────────── */
function normFrag(s: string): string {
  return s.replace(/\s+/g, "").toLowerCase();
}
export function mapAiStepsToRank(
  toks: FormulaTok[],
  steps: FormulaReadingStep[],
): { rank: number[]; stepOfTok: number[] } | null {
  if (!steps.length) return null;
  const n = toks.length;
  const nt = toks.map((t) => normFrag(t.value));
  const startAt: number[] = [];
  let acc = 0;
  for (let i = 0; i < n; i++) { startAt.push(acc); acc += nt[i].length; }
  const joined = nt.join("");
  if (!joined.length) return null;
  const stepOfTok = new Array(n).fill(-1);
  let cursor = 0;
  let matched = 0;
  steps.forEach((s, si) => {
    const f = normFrag(s.fragment || "");
    if (!f) return;
    const at = joined.indexOf(f, cursor);
    if (at < 0) return;
    const end = at + f.length;
    matched += 1;
    for (let i = 0; i < n; i++) {
      const s0 = startAt[i];
      const e0 = s0 + nt[i].length;
      if (nt[i].length === 0) continue;
      const ov = Math.min(e0, end) - Math.max(s0, at);
      if (ov > 0 && ov * 2 >= nt[i].length && stepOfTok[i] === -1) stepOfTok[i] = si;
    }
    cursor = end;
  });
  if (matched < Math.min(2, steps.length)) return null;
  let last = 0;
  for (let i = 0; i < n; i++) {
    if (stepOfTok[i] === -1) stepOfTok[i] = last; else last = stepOfTok[i];
  }
  const rank = new Array(n).fill(0);
  Array.from({ length: n }, (_, i) => i)
    .sort((a, b) => (stepOfTok[a] !== stepOfTok[b] ? stepOfTok[a] - stepOfTok[b] : a - b))
    .forEach((tokIdx, k) => { rank[tokIdx] = k; });
  return { rank, stepOfTok };
}

/* ── Reduced motion hook ───────────────────────────────────── */
function usePrefersReducedMotion(): boolean {
  const [r, setR] = useState(() =>
    typeof window !== "undefined" &&
    window.matchMedia?.("(prefers-reduced-motion: reduce)").matches === true,
  );
  useEffect(() => {
    if (typeof window === "undefined") return;
    const mq = window.matchMedia("(prefers-reduced-motion: reduce)");
    const on = () => setR(mq.matches);
    mq.addEventListener?.("change", on);
    return () => mq.removeEventListener?.("change", on);
  }, []);
  return r;
}

/* ── FormulaFlow component ─────────────────────────────────── */
export interface FormulaFlowProps {
  formula: string;
  steps?: FormulaReadingStep[];
  /** Show a leading "=" like Excel. */
  showEq?: boolean;
  /** Extra class on wrapper. */
  className?: string;
  /** true => phối màu cho nền tối (kính hiển vi). */
  onDark?: boolean;
}

/** Adaptive step delay (seconds). Longer formulas read slower per token. */
function adaptiveDelay(slots: number): number {
  if (slots <= 6) return 0.42;
  if (slots <= 12) return 0.36;
  if (slots <= 20) return 0.30;
  return 0.26;
}

/**
 * FormulaFlow.
 *  - Không có `steps`: chế độ CSS-loop — token sáng lần lượt theo thứ tự đọc
 *    cú pháp (inside-out), highlight nền quét ngang, lặp vô hạn.
 *  - Có `steps` (kịch bản đọc do người soạn viết): chế độ GUIDED — một timer
 *    JS duy nhất điều khiển "bước đang đọc"; các token thuộc bước đó sáng lên
 *    ĐỒNG BỘ với một dòng chú thích "đang đọc … → nghĩa là …" bên dưới.
 */
export function FormulaFlow({
  formula,
  steps,
  showEq,
  className,
  onDark,
}: FormulaFlowProps) {
  const reduced = usePrefersReducedMotion();
  const clean = formula.replace(/^\s*=\s*/, "");
  const guided = !!(steps && steps.length);

  const { toks, slotOf, stepOfTok, cycleSec, delaySec } = useMemo(() => {
    const toks = tokenizeFormula(clean);
    const ai = guided ? mapAiStepsToRank(toks, steps!) : null;
    const rank = ai ? ai.rank : computeSyntaxReadingRank(toks);
    const readable = toks
      .map((t, i) => ({ i, empty: t.value.trim() === "" }))
      .filter((r) => !r.empty)
      .map((r) => r.i)
      .sort((a, b) => rank[a] - rank[b]);
    const slotOf = new Map<number, number>();
    readable.forEach((i, sl) => slotOf.set(i, sl));
    const slots = readable.length;
    const delay = adaptiveDelay(slots);
    const cycle = Math.max(3, slots * delay + 2.4);
    return {
      toks,
      slotOf,
      stepOfTok: ai ? ai.stepOfTok : null,
      cycleSec: cycle,
      delaySec: delay,
    };
  }, [clean, steps, guided]);

  const eq = showEq ?? /^\s*=/.test(formula);

  // ── GUIDED: timer JS đi qua từng bước, caption + highlight đồng bộ ──
  const [active, setActive] = useState(0);
  const nSteps = steps?.length ?? 0;
  useEffect(() => {
    if (!guided || reduced || nSteps <= 1) return;
    // mỗi bước giữ 2.6s; nghỉ 1.4s cuối vòng trước khi lặp lại
    const HOLD = 2600;
    const id = setInterval(() => {
      setActive((a) => (a + 1) % nSteps);
    }, HOLD);
    return () => clearInterval(id);
  }, [guided, reduced, nSteps]);

  // reset khi đổi công thức
  useEffect(() => { setActive(0); }, [clean]);

  if (guided) {
    const activeExplain = steps![active]?.explain;
    return (
      <span className={"ff-flow ff-guided " + (onDark ? "ff-on-dark " : "") + (className || "")}>
        <span className="ff-line">
          {eq && <span className="ff-eq">=</span>}
          {toks.map((t, i) => {
            const st = stepOfTok ? stepOfTok[i] : -1;
            const on = !reduced && st === active;
            const cls =
              t.value.trim() === ""
                ? t.cls
                : t.cls + (on ? " ff-here" : st === -1 ? "" : " ff-dim");
            return (
              <span key={i} className={cls}>
                {on && <span className="ff-underline" aria-hidden="true" />}
                {t.value}
              </span>
            );
          })}
        </span>

        {!reduced && nSteps > 1 && (
          <span className="ff-dots" aria-hidden="true">
            {steps!.map((_, i) => (
              <span
                key={i}
                className={
                  "ff-dot" + (i === active ? " ff-dot-on" : i < active ? " ff-dot-done" : "")
                }
              />
            ))}
          </span>
        )}

        {!reduced && activeExplain && (
          <span key={active} className="ff-caption">
            <span className="ff-caption-step">{active + 1}</span>
            <span className="ff-caption-text">{activeExplain}</span>
          </span>
        )}
      </span>
    );
  }

  // ── DEFAULT: CSS-loop quét ngang theo thứ tự cú pháp ──
  return (
    <span
      className={"ff-flow " + (onDark ? "ff-on-dark " : "") + (className || "")}
      style={{
        "--ff-cycle": cycleSec.toFixed(2) + "s",
        "--ff-delay": delaySec.toFixed(2) + "s",
        "--ff-slots": String(Math.max(1, slotOf.size)),
      } as CSSProperties}
    >
      {eq && <span className="ff-eq">=</span>}
      {toks.map((t, i) => {
        if (t.value.trim() === "" || reduced) {
          return (
            <span key={i} className={t.cls}>
              {t.value}
            </span>
          );
        }
        const slot = slotOf.get(i) ?? 0;
        return (
          <span
            key={i}
            className={"ff-pop " + t.cls}
            style={{ "--ff-slot": String(slot) } as CSSProperties}
          >
            {t.value}
          </span>
        );
      })}
    </span>
  );
}
