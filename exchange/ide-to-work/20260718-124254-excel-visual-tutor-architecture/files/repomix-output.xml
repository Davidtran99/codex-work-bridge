import type { FormulaReadingStep } from "../../lib/formulaFlow";
import img01 from "./frames/01-data.avif";
import img02 from "./frames/02-equals.avif";
import img03 from "./frames/03-format-cells.avif";
import img04 from "./frames/04-custom-code.avif";
import img05 from "./frames/05-text-result.avif";
import img06 from "./frames/06-icon-set.avif";
import img07 from "./frames/07-star-live.avif";
import img08 from "./frames/08-borders.avif";
import img09 from "./frames/09-gridlines.avif";
import img10 from "./frames/10-mod-rule.avif";
import img11 from "./frames/11-new-employee.avif";
import img12 from "./frames/12-format-painter.avif";
import type { SimMode } from "./CuteSim";

/** A colored formula token: [text, groupIndex|null]. groupIndex links to a MicroChip below. */
export type CuteFToken = [text: string, group: number | null];

/** A microscope chip: a formula part, its meaning, an accent color, and the grid column it lights up. */
export type CuteMicroChip = [label: string, desc: string, color: string, col: "A" | "B" | "C" | "D" | null];

/** Three explanation depths for the tabbed panel. */
export interface CuteTiers {
  easy: string;   // plain-language teacher voice
  tech: string;   // how Excel actually processes it
  deep: string;   // edge cases / pro insight / real-world reach
}

/** One teaching step: a real video frame + cleaned narration + the technique. */
export interface CuteStep {
  id: string;
  tag: string;        // short chip label
  title: string;      // step heading
  image?: string;     // imported frame (inlined by vite-plugin-singlefile)
  demo?: boolean;     // if set, render the interactive sandbox instead of an image
  sim?: SimMode;      // if set, render an auto-running Excel-like grid demo under the image
  caption: string;    // what you see in the frame
  story: string;      // teacher's point, HTML allowed (b/code)
  formula?: string;   // the exact code / formula, if any
  chips?: [label: string, desc: string][]; // formula breakdown
  ftokens?: CuteFToken[];   // formula split into hoverable colored tokens (microscope)
  micro?: CuteMicroChip[];  // microscope chips; hovering lights up the linked grid column
  tiers?: CuteTiers;        // 3-depth explanation (Dễ hiểu / Kỹ thuật / Chuyên sâu)
  why?: [q: string, a: string][];
  /** Optional AI-suggested reading steps: FormulaFlow pops tokens in this order. */
  readingSteps?: FormulaReadingStep[];
  summary: string;    // the "aha" takeaway
}

export const CUTE_STEPS: CuteStep[] = [
  {
    id: "goal",
    tag: "Mục tiêu",
    title: "Bảng đánh giá vừa thông minh, vừa đẹp",
    image: img01,
    caption: "Danh sách 10 nhân viên với doanh thu theo tháng, cần xếp loại Xuất sắc / Đạt / Kém.",
    story:
      "Ta có <b>doanh thu</b> của 10 nhân viên. Quy tắc: <code>&ge; 150</code> là <b>Xuất sắc</b>, <code>&ge; 80</code> là <b>Đạt</b>, còn lại là <b>Kém</b>. Mục tiêu không chỉ ra kết quả đúng, mà làm bảng <b>tự đổi chữ, tự gắn sao, tự kẻ sọc</b> — nhìn phát hiểu ngay.",
    why: [
      ["Vì sao không chỉ dùng IF?", "IF cho ra chữ, nhưng cả video này là mẹo định dạng: hiện chữ mà vẫn giữ số để tính, gắn sao, tô màu tự động. Đó là phần IF không làm được."],
