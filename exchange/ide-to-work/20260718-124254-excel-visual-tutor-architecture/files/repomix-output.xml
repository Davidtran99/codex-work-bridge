<file path="tools/compress-frames.mjs">
#!/usr/bin/env node
/**
 * Nén tất cả JPG trong src/lessons/<*>/frames/ về AVIF + WebP fallback.
 * Cách chạy: node tools/compress-frames.mjs
 *
 * Chiến lược:
 *   - resize max chiều rộng 1280px (đủ Retina cho khung cột trái ~640px)
 *   - AVIF q=52, effort=6  ~ tốt nhất về nén
 *   - WebP q=78            ~ fallback cho Safari <16
 *   - JPG cũ được xoá sau khi convert (giữ tên file mới với 2 đuôi)
 *   - Sinh file re-export .ts để giữ nguyên import quen thuộc trong steps.ts
 */
import { readdir, stat, mkdir, writeFile, rm } from "node:fs/promises";
import { join, dirname, basename, extname } from "node:path";
import { fileURLToPath } from "node:url";
import sharp from "sharp";

const ROOT = join(dirname(fileURLToPath(import.meta.url)), "..");
const LESSONS = join(ROOT, "src", "lessons");
const MAX_W = 1280;
const AVIF_Q = 52;
const WEBP_Q = 78;

/** Trả về mọi file jpg trực tiếp trong thư mục frames/ (bỏ qua thư mục con _orig-360p). */
async function listFrames(framesDir) {
  const items = await readdir(framesDir, { withFileTypes: true });
  return items
    .filter((it) => it.isFile() && /\.(jpe?g)$/i.test(it.name))
    .map((it) => join(framesDir, it.name));
}

/** Convert 1 file: sinh .avif + .webp cạnh file gốc, sau đó xoá jpg. */
async function convertOne(jpgPath) {
  const base = jpgPath.replace(/\.jpe?g$/i, "");
  const src = sharp(jpgPath, { failOn: "none" }).rotate();
  const meta = await src.metadata();
  const w = meta.width && meta.width > MAX_W ? MAX_W : meta.width;

  await src
    .clone()
    .resize({ width: w, withoutEnlargement: true })
    .avif({ quality: AVIF_Q, effort: 6 })
    .toFile(base + ".avif");

  await src
    .clone()
    .resize({ width: w, withoutEnlargement: true })
    .webp({ quality: WEBP_Q, effort: 6, smartSubsample: true })
    .toFile(base + ".webp");

  await rm(jpgPath);

  return {
    name: basename(base),
  };
}

async function processLesson(lessonDir) {
  const framesDir = join(lessonDir, "frames");
  try {
    const st = await stat(framesDir);
    if (!st.isDirectory()) return null;
  } catch {
    return null;
  }
  const files = await listFrames(framesDir);
  if (files.length === 0) return null;
  console.log(`\n[${basename(lessonDir)}] ${files.length} ảnh`);
  const results = [];
  for (const f of files) {
    const before = (await stat(f)).size;
    const { name } = await convertOne(f);
    const afterAvif = (await stat(join(framesDir, name + ".avif"))).size;
    const afterWebp = (await stat(join(framesDir, name + ".webp"))).size;
    console.log(
      `  ${name}: ${(before / 1024).toFixed(0)}K → avif ${(afterAvif / 1024).toFixed(0)}K · webp ${(afterWebp / 1024).toFixed(0)}K`,
    );
    results.push({ name, before, afterAvif, afterWebp });
  }
  return { framesDir, results };
}

async function main() {
  const lessons = await readdir(LESSONS, { withFileTypes: true });
  let totalBefore = 0;
  let totalAvif = 0;
  let totalWebp = 0;
  for (const l of lessons) {
    if (!l.isDirectory()) continue;
    const out = await processLesson(join(LESSONS, l.name));
    if (!out) continue;
    for (const r of out.results) {
      totalBefore += r.before;
      totalAvif += r.afterAvif;
      totalWebp += r.afterWebp;
    }
  }
  console.log("\n────────────────────────────");
  console.log(`Tổng JPG cũ:  ${(totalBefore / 1024 / 1024).toFixed(2)} MB`);
  console.log(`Tổng AVIF:    ${(totalAvif / 1024 / 1024).toFixed(2)} MB`);
  console.log(`Tổng WebP:    ${(totalWebp / 1024 / 1024).toFixed(2)} MB`);
  console.log(
    `Tiết kiệm (AVIF): ${(100 - (totalAvif / totalBefore) * 100).toFixed(1)}%`,
  );
}

main().catch((e) => {
  console.error(e);
  process.exit(1);
});
</file>

