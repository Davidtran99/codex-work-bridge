<file path="src/components/SimPanel.tsx">
import { useMemo } from "react";
import { Play, StepForward, RotateCcw, Table2 } from "lucide-react";
import type { Scene } from "../data/types";
import { SRC, UNIQ } from "../data/scenes";
import { buildGrid } from "../lib/grid";
import { sttOf, keyOf, lookupKey, MAXN } from "../lib/excel";
import { useSimAnim } from "../hooks/useSimAnim";
import ExcelGrid from "./ExcelGrid";
import Button from "./Button";

/** Per-table labels: [caption, playLabel, stepLabel]. */
const META: Record<string, [cap: string, play: string, step: string]> = {
  countif_anim: ["Xem vùng đếm lớn dần theo từng dòng", "Chạy từng dòng", "Dòng tiếp"],
  key_anim: ["Xem khoá riêng được ghép từng dòng", "Ghép từng dòng", "Dòng tiếp"],
  frame_build: ["Dựng khung: đánh số cột rồi điền mã", "Dựng khung", "Bước tiếp"],
  vlookup_anim: ["Xem VLOOKUP trải kết quả ra từng ô", "Dò từng ô", "Ô tiếp"],
  iferror_anim: ["Xem IFERROR dọn từng ô lỗi", "Dò từng ô", "Ô tiếp"],
  condfmt_anim: ["Xem chữ #N/A bị tô trắng cho tàng hình", "Tô trắng lỗi", "Ô tiếp"],
  test_wrong: ["Nhập mã sai và xem bảng phản ứng", "Nhập mã sai", "Xem"],
};

function noteFor(scene: Scene, step: number): string {
  const m = scene.table;
  if (step < 0) return "Bấm nút bên dưới để chạy mô phỏng.";
  if (m === "countif_anim") {
    const i = step;
    return `Vùng đếm giờ là $A$2:A${i + 2}. Mã ${SRC[i][0]} tính tới đây đã hiện ${sttOf(SRC, i)} lần, ghi ${sttOf(SRC, i)}.`;
  }
  if (m === "key_anim") {
    const i = step;
    return `${SRC[i][0]} & ${sttOf(SRC, i)} = khoá ${keyOf(SRC, i)}.`;
  }
  if (m === "frame_build") {
    return step < MAXN
      ? `Gõ tay số ${step + 1} ở hàng tiêu đề. Cứ đánh dư ra cho chắc.`
      : "Điền mỗi mã một dòng vào cột G. Khung đã sẵn sàng để đổ công thức.";
  }
  if (m === "vlookup_anim" || m === "iferror_anim") {
    const ci = Math.floor(step / MAXN);
    const n = (step % MAXN) + 1;
    const code = UNIQ[ci];
    const v = lookupKey(SRC, code, n);
    if (v == null) {
      return m === "iferror_anim"
        ? `Khoá ${code + n} không có, IFERROR trả ô trống.`
        : `Khoá ${code + n} không tồn tại, trả #N/A.`;
    }
    return `Ô ${code} cột ${n} dò khoá ${code + n}, lấy về ${v}.`;
  }
  if (m === "condfmt_anim") {
    return `Ô #N/A thứ ${step + 1} vừa bị tô chữ trắng. Giá trị vẫn còn, chỉ trùng màu nền nên tàng hình.`;
  }
  if (m === "test_wrong") {
    return "Đã thay mã đầu thành L9X. Không khoá nào khớp nên cả hàng để trống, bảng không vỡ.";
  }
  return "";
}

interface Props {
  scene: Scene;
  hlGroup: number | null;
}

export default function SimPanel({ scene, hlGroup }: Props) {
  const { step, playing, play, stepForward, reset } = useSimAnim(scene.table, SRC, UNIQ);
  const hasAnim = scene.table in META;
  const effStep = hasAnim ? step : -1;

  const model = useMemo(
    () => buildGrid(scene.table, SRC, UNIQ, { step: effStep, spot: scene.spot }),
    [scene.table, scene.spot, effStep],
  );

  const meta = META[scene.table];
  const cap = meta ? meta[0] : "Bảng mô phỏng";

  return (
    <div className="rounded-2xl border border-line bg-gradient-to-b from-[#fbfcff] to-[#f6f8fd] p-4 shadow-[inset_0_1px_0_#fff]">
      <div className="mb-3 flex items-center gap-1.5 text-[12.5px] font-extrabold text-soft">
        <Table2 size={15} strokeWidth={2.4} className="text-teal-d" /> {cap}
      </div>

      <div className="overflow-x-auto">
        <ExcelGrid model={model} hlGroup={hlGroup} />
      </div>

      {meta && (
        <>
          <div className="mt-3 flex flex-wrap gap-2">
            <Button
              variant="primary"
              onClick={play}
              disabled={playing}
              icon={<Play size={16} strokeWidth={2.6} className="fill-current" />}
            >
              {meta[1]}
            </Button>
            <Button
              variant="soft"
              onClick={stepForward}
              icon={<StepForward size={16} strokeWidth={2.6} />}
            >
              {meta[2]}
            </Button>
            <Button
              variant="soft"
              onClick={reset}
              icon={<RotateCcw size={16} strokeWidth={2.6} />}
            >
              Làm lại
            </Button>
          </div>
          <p className="mt-2.5 min-h-[22px] text-[13px] text-soft" aria-live="polite">
            {noteFor(scene, effStep)}
          </p>
        </>
      )}
    </div>
  );
}
</file>

<file path="src/components/Tiers.tsx">
import { useState } from "react";
import { motion, AnimatePresence } from "framer-motion";
import type { Tiers as TiersData } from "../data/types";

const TABS: { key: keyof TiersData; label: string }[] = [
  { key: "easy", label: "Dễ hiểu" },
  { key: "tech", label: "Kỹ thuật" },
  { key: "deep", label: "Chuyên sâu" },
];

export default function Tiers({ tiers }: { tiers: TiersData }) {
  const [active, setActive] = useState<keyof TiersData>("easy");
  return (
    <section className="card-frost rounded-2xl p-4">
      <div className="mb-3 flex gap-1.5">
        {TABS.map((t) => (
          <button
            key={t.key}
            onClick={() => setActive(t.key)}
            className={
              "flex-1 rounded-lg border px-2 py-1.5 text-[12.5px] font-extrabold transition " +
              (active === t.key
                ? "border-teal bg-teal text-white"
                : "border-line bg-white text-soft hover:border-teal hover:text-teal-d")
            }
          >
            {t.label}
          </button>
        ))}
      </div>
      <AnimatePresence mode="wait">
        <motion.div
          key={active}
          initial={{ opacity: 0, y: 8 }}
          animate={{ opacity: 1, y: 0 }}
