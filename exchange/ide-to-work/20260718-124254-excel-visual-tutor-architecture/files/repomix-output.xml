<file path="src/components/LessonScaffold.tsx">
import { useCallback, useEffect, useRef, useState } from "react";
import { AnimatePresence, motion, useReducedMotion } from "framer-motion";
import { ChevronLeft, ChevronRight } from "lucide-react";
import type { LucideIcon } from "lucide-react";
import MindMap, { type MindNodeView } from "./MindMap";
import Button from "./Button";
import SceneProgressRing from "./SceneProgressRing";

export interface ScaffoldScene {
  id: string;
  tag: string;
  node: number;
}

interface Props {
  scenes: ScaffoldScene[];
  sceneIcons: (LucideIcon | undefined)[];
  mindNodes: MindNodeView[];
  renderScene: (index: number) => React.ReactNode;
  /** slot rendered above the scene nav (title block) */
  head?: React.ReactNode;
  wide?: boolean;
  tone?: "teal" | "indigo";
}

/**
 * Shared lesson shell: sticky mind map, scene chips, progress, direction-aware
 * scene transitions, prev/next + keyboard nav. Any scene-based lesson plugs in.
 */
export default function LessonScaffold({
  scenes,
  sceneIcons,
  mindNodes,
  renderScene,
  head,
  wide = false,
  tone = "teal",
}: Props) {
  const [cur, setCur] = useState(0);
  const dir = useRef(1);
  const sectionRef = useRef<HTMLElement>(null);
  const reduce = useReducedMotion();

  const go = useCallback(
    (i: number) => {
      if (i < 0 || i >= scenes.length) return;
      setCur((prev) => {
        dir.current = i >= prev ? 1 : -1;
        return i;
      });
      // Always bring the lesson card (its heading) to the top of the viewport,
      // regardless of how tall the content or the page is. Double rAF lets the
      // new scene commit + layout settle before we measure.
      const scrollToLesson = () => {
        const el = sectionRef.current;
        if (!el) return;
        const top = el.getBoundingClientRect().top + window.scrollY - 12;
        window.scrollTo({ top: Math.max(top, 0), behavior: reduce ? "auto" : "smooth" });
      };
      requestAnimationFrame(() => requestAnimationFrame(scrollToLesson));
    },
    [scenes.length, reduce],
  );

  useEffect(() => {
    const onKey = (e: KeyboardEvent) => {
      const t = e.target as HTMLElement;
      if (t && (t.tagName === "INPUT" || t.tagName === "TEXTAREA")) return;
      if (e.key === "ArrowRight") go(cur + 1);
      if (e.key === "ArrowLeft") go(cur - 1);
    };
    window.addEventListener("keydown", onKey);
    return () => window.removeEventListener("keydown", onKey);
  }, [cur, go]);

  const variants = {
    enter: (d: number) =>
      reduce
        ? { opacity: 0 }
        : { opacity: 0, rotateY: d * 22, x: d * 60, z: -140, scale: 0.94 },
    center: { opacity: 1, rotateY: 0, x: 0, z: 0, scale: 1 },
    exit: (d: number) =>
      reduce
        ? { opacity: 0 }
        : { opacity: 0, rotateY: -d * 22, x: -d * 60, z: -140, scale: 0.94 },
  };
  const activeNode = scenes[cur].node;

  return (
    <div className="mx-auto max-w-[1760px] px-[clamp(16px,3vw,46px)] pb-16">
      {head}
      <div className={wide ? "mt-4" : "mt-4 grid items-start gap-6 lg:grid-cols-[296px_1fr]"}>
        {!wide && <div className="hidden lg:block">
          <MindMap
            nodes={mindNodes}
            activeNode={activeNode}
            tone={tone}
            onJump={(node) => {
              const idx = scenes.findIndex((s) => s.node === node);
              if (idx >= 0) go(idx);
            }}
          />
        </div>}

        <main className="min-w-0">
          <nav
            aria-label="Các cảnh"
            className={
              "mb-3 flex-wrap gap-1.5 " + (wide ? "flex" : "flex lg:hidden")
            }
          >
            {scenes.map((s, i) => {
              const Icon = sceneIcons[i];
              const on = i === cur;
              return (
                <button
                  key={s.id}
                  onClick={() => go(i)}
                  aria-current={on}
                  className={
                    "chip-3d inline-flex items-center gap-1.5 whitespace-nowrap rounded-full border px-3 py-1.5 text-[12.5px] font-extrabold " +
                    (on
                      ? tone === "indigo"
                        ? "chip-active border-indigo bg-indigo text-white"
                        : "chip-active border-ink bg-ink text-white"
                      : tone === "indigo"
                        ? "border-line bg-white/80 text-soft hover:border-indigo hover:text-indigo-tx"
                        : "border-line bg-white/80 text-soft hover:border-teal hover:text-teal-d")
                  }
                >
                  {Icon && <Icon size={14} strokeWidth={2.6} />} {s.tag}
                </button>
              );
            })}
          </nav>


          <div className="scene-3d">
            <section
              ref={sectionRef}
              className="glass relative scroll-mt-3 overflow-hidden rounded-[20px] border border-line p-[28px_clamp(20px,2.4vw,34px)_26px] shadow-lift"
            >
              <span className={`absolute inset-x-0 top-0 z-10 h-[5px] bg-gradient-to-r ${tone === "indigo" ? "from-indigo via-indigo-tx to-violet" : "from-teal via-teal-d to-honey"}`} />
              <AnimatePresence mode="wait" custom={dir.current} initial={false}>
                <motion.div
                  key={scenes[cur].id}
                  custom={dir.current}
                  variants={variants}
                  initial="enter"
                  animate="center"
                  exit="exit"
                  style={{ transformStyle: "preserve-3d" }}
                  transition={{ duration: reduce ? 0 : 0.5, ease: [0.2, 0.7, 0.2, 1] }}
                >
                  {renderScene(cur)}
                </motion.div>
              </AnimatePresence>
            </section>
          </div>

          <div className="mt-5 flex items-center justify-between gap-3">
            <Button
              variant="soft"
              onClick={() => go(cur - 1)}
              disabled={cur === 0}
              icon={<ChevronLeft size={17} strokeWidth={2.8} />}
            >
              Trước
            </Button>
            <SceneProgressRing cur={cur} total={scenes.length} />
            <Button
              variant="primary"
              className="cta-pulse"
              onClick={() => go(cur + 1)}
              disabled={cur === scenes.length - 1}
              iconRight={<ChevronRight size={17} strokeWidth={2.8} className="nudge-x" />}
            >
              Tiếp
            </Button>
          </div>
        </main>
      </div>
    </div>
  );
}
</file>

