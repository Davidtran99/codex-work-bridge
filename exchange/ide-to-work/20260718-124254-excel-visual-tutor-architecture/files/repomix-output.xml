import { describe, it, expect } from "vitest";
import { sttOf, keyOf, lookupKey } from "./excel";
import type { Row } from "../data/types";

// Dataset đúng như SPEC.md và data/pay.json:
//   L1A xuất hiện 3 lần (12, 20, 30)
//   L2A xuất hiện 2 lần (20, 14)
//   L1B xuất hiện 1 lần (10)
const SRC: Row[] = [
  ["L1A", 12],
  ["L2A", 20],
  ["L1A", 20],
  ["L1B", 10],
  ["L2A", 14],
  ["L1A", 30],
];

describe("sttOf — running COUNTIF của mã theo hàng", () => {
  it("đếm đúng số lần xuất hiện tới hàng i (bao gồm hàng đó)", () => {
    // Hàng của L1A: idx 0, 2, 5 → 1, 2, 3
    expect(sttOf(SRC, 0)).toBe(1);
    expect(sttOf(SRC, 2)).toBe(2);
    expect(sttOf(SRC, 5)).toBe(3);
    // Hàng của L2A: idx 1, 4 → 1, 2
    expect(sttOf(SRC, 1)).toBe(1);
    expect(sttOf(SRC, 4)).toBe(2);
    // Hàng của L1B: idx 3 → 1
    expect(sttOf(SRC, 3)).toBe(1);
  });
});

describe("keyOf — khoá tổ hợp code & runningCount", () => {
  it("ghép chuỗi đúng dạng '<code><n>'", () => {
    expect(keyOf(SRC, 0)).toBe("L1A1");
    expect(keyOf(SRC, 2)).toBe("L1A2");
    expect(keyOf(SRC, 5)).toBe("L1A3");
    expect(keyOf(SRC, 1)).toBe("L2A1");
    expect(keyOf(SRC, 4)).toBe("L2A2");
    expect(keyOf(SRC, 3)).toBe("L1B1");
  });
});

describe("lookupKey — VLOOKUP theo khoá tổ hợp (SPEC oracle)", () => {
  it("L1A trả 12, 20, 30 theo thứ tự xuất hiện", () => {
    expect(lookupKey(SRC, "L1A", 1)).toBe(12);
    expect(lookupKey(SRC, "L1A", 2)).toBe(20);
    expect(lookupKey(SRC, "L1A", 3)).toBe(30);
  });

  it("L2A trả 20, 14", () => {
    expect(lookupKey(SRC, "L2A", 1)).toBe(20);
    expect(lookupKey(SRC, "L2A", 2)).toBe(14);
  });

  it("L1B chỉ có 1 giá trị = 10", () => {
    expect(lookupKey(SRC, "L1B", 1)).toBe(10);
  });

  it("N vượt số lần xuất hiện → null (để IFERROR bắt)", () => {
    expect(lookupKey(SRC, "L1A", 4)).toBeNull();
    expect(lookupKey(SRC, "L2A", 3)).toBeNull();
    expect(lookupKey(SRC, "L1B", 2)).toBeNull();
    expect(lookupKey(SRC, "KHONG_TON_TAI", 1)).toBeNull();
  });
});
