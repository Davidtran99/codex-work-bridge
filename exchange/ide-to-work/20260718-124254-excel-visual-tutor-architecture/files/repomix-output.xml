import { useCallback, useEffect, useState } from "react";
import { ArrowLeft } from "lucide-react";
import LessonPicker from "./components/LessonPicker";
import { findLesson } from "./lessons/registry";

/** Read the current lesson id from the URL (?lesson=<id>). */
function readLessonId(): string | null {
  return new URLSearchParams(window.location.search).get("lesson");
}

export default function App() {
  const [lessonId, setLessonId] = useState<string | null>(readLessonId);

  // keep state in sync with browser back/forward
  useEffect(() => {
    const onPop = () => setLessonId(readLessonId());
    window.addEventListener("popstate", onPop);
    return () => window.removeEventListener("popstate", onPop);
  }, []);

  const openLesson = useCallback((id: string) => {
    const url = new URL(window.location.href);
    url.searchParams.set("lesson", id);
    window.history.pushState({}, "", url);
    setLessonId(id);
    window.scrollTo({ top: 0, behavior: "auto" });
  }, []);

  const goHome = useCallback(() => {
    const url = new URL(window.location.href);
    url.searchParams.delete("lesson");
    window.history.pushState({}, "", url);
    setLessonId(null);
    window.scrollTo({ top: 0, behavior: "auto" });
  }, []);

  const lesson = findLesson(lessonId);

  return (
    <>
      <div className="aurora" aria-hidden="true">
        <span className="blob3" />
      </div>

      {lesson ? (
        <>
          <div className="mx-auto max-w-[1760px] px-[clamp(16px,3vw,46px)] pt-5">
            <button
              onClick={goHome}
              className="inline-flex items-center gap-1.5 rounded-full border border-line bg-white/80 px-3.5 py-1.5 text-[13px] font-extrabold text-soft transition hover:-translate-x-0.5 hover:border-teal hover:text-teal-d focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal/60"
            >
              <ArrowLeft size={15} strokeWidth={2.8} /> Tất cả bài học
            </button>
          </div>
          <lesson.Component />
        </>
      ) : (
        <LessonPicker onPick={openLesson} />
      )}
    </>
  );
}
